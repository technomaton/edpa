# Kashealth pilot — edpa.yaml seed
#
# Po `cp` do .edpa/config/edpa.yaml stačí 1 edit (project.name).
# Sekce `sync` je pre-filled na kashealth/kas-platform-v1; sekce
# `field_ids` / `option_ids` / `github_project_id` se naplní automaticky
# až `project_setup.py` proběhne (a auto-commit STEP 9b je perzistuje).

project:
  name: "Medical Platform + Datový e-shop"
  description: "OMOP datový e-shop a anonymizační pipeline pro CDC výzkum"
  domain: "kashealth.cz"

  funding:
    program: "OP TAK"
    registration: "CZ.01.01.01/01/24_062/0007440"
    period_start: "2024-01-01"
    period_end: "2026-12-31"

  organizations:
    - name: "ČVUT FBMI"
      legal_name: "České vysoké učení technické v Praze, Fakulta biomedicínského inženýrství"
      role: "primary"
      tax_id: "68407700"           # ICO
      vat_id: "CZ68407700"         # DIC
      address:
        street: "Sítná 3105"
        city: "Kladno"
        postal_code: "272 01"
        country: "CZ"
      contact:
        email: "info@fbmi.cvut.cz"
        phone: "+420 224 359 999"
        website: "https://fbmi.cvut.cz"

    - name: "Medicalc software s.r.o."
      legal_name: "Medicalc software s.r.o."
      role: "partner"
      tax_id: ""                   # ICO — doplnit z ARES
      vat_id: ""                   # DIC — doplnit
      address:
        street: ""
        city: ""
        postal_code: ""
        country: "CZ"
      contact:
        email: ""
        phone: ""
        website: "https://medicalc.com"

governance:
  methodology: "EDPA 1.12.0"
  # Calculation mode:
  #   gates  (default) — credits per status transition on Initiative/Epic/Feature
  #                      + Story=Done. Doporučeno po validaci A/B vs simple.
  #   simple — only items with status=Done count. Audit-conservative;
  #            v 1. PI pilotu je rozumné spustit oba módy paralelně
  #            (viz KASHEALTH-PILOT.md § 9).
  #   full   — same as simple but adds richer audit metadata to snapshot.
  calculation_mode: "gates"
  audit_mode: "full"   # always store full signal trail in snapshots

naming:
  pi_pattern: "PI-{year}-{pi_num}"
  iteration_pattern: "PI-{year}-{pi_num}.{iter_num}"
  branch_pattern: "{type}/{item_id}-{description}"
  item_prefixes:
    initiative: "I"
    epic: "E"
    feature: "F"
    story: "S"
    task: "T"
    defect: "D"

# Native GitHub Issue Types (org-level).
# Pokud chybí v org → `python3 plugin/edpa/scripts/issue_types.py setup --org kashealth`.
issue_types:
  Initiative: "Strategic business initiative with investment funding"
  Epic: "Large body of work decomposed into features"
  Feature: "A service provided by the system that fulfills a stakeholder need"
  Story: "A small, deliverable unit of value completed within an iteration"
  Defect: "A defect in existing functionality"
  Task: "Technical work without user-facing value"

labels:
  Enabler: "Infrastructure, research, technical debt"

sync:
  github_org: "kashealth"
  github_repo: "kas-platform-v1"
  # Vše níže (`github_project_id`, `field_ids`, `option_ids`,
  # `github_project_number`) se naplní automaticky při project_setup.py.
  # NEEDITUJTE ručně.
