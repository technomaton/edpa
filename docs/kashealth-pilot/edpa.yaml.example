# Kashealth pilot — edpa.yaml seed (V2, local-first)
#
# Po `cp` do .edpa/config/edpa.yaml stačí 1 edit (zkontrolovat
# project.name). V2 je local-first: `.edpa/backlog/**/*.md` je source
# of truth, GitHub je volitelný. Žádná sekce `sync:` / `field_ids` /
# `github_project_id` se NEVYTVÁŘÍ — V2 neprovisuje GitHub Project ani
# org Issue Types. governance.methodology auto-stampne install.sh /
# project_setup.py na nainstalovanou verzi pluginu.

project:
  name: "Medical Platform + Datový e-shop"
  description: "OMOP datový e-shop a anonymizační pipeline pro CDC výzkum"
  domain: "kashealth.cz"

  funding:
    program: "OP TAK"
    registration: "CZ.01.01.01/01/24_062/0007440"
    period_start: "2024-01-01"
    period_end: "2026-12-31"

  organizations:
    - name: "ČVUT FBMI"
      legal_name: "České vysoké učení technické v Praze, Fakulta biomedicínského inženýrství"
      role: "primary"
      tax_id: "68407700"           # ICO
      vat_id: "CZ68407700"         # DIC
      address:
        street: "Sítná 3105"
        city: "Kladno"
        postal_code: "272 01"
        country: "CZ"
      contact:
        email: "info@fbmi.cvut.cz"
        phone: "+420 224 359 999"
        website: "https://fbmi.cvut.cz"

    - name: "Medicalc software s.r.o."
      legal_name: "Medicalc software s.r.o."
      role: "partner"
      tax_id: "26350513"           # ICO (ARES, RES status: AKTIVNI, DPH: AKTIVNI)
      vat_id: "CZ26350513"         # DIC
      address:                      # sídlo z ARES — pro fakturace + grant reporty
        street: "Pod Švabinami 434/13"
        city: "Plzeň"
        postal_code: "312 00"
        country: "CZ"
      contact:
        email: "medicalc@medicalc.cz"
        phone: "+420 377 259 020"
        website: "https://medicalc.cz"

governance:
  # Auto-stamped na nainstalovanou verzi pluginu install.shem /
  # project_setup.pym. Single calculation path: engine kredituje Done
  # Stories + Feature/Epic/Initiative status transitions z git history
  # + yaml_edit structural signals nad .edpa/backlog/<typ>/<id>.md
  # v okně iterace. Žádný simple/full/gates mode selector, žádný
  # audit_mode — snapshoty vždy nesou plný signals[] audit trail.
  methodology: "EDPA 2.1.8"

naming:
  pi_pattern: "PI-{year}-{pi_num}"
  iteration_pattern: "PI-{year}-{pi_num}.{iter_num}"
  branch_pattern: "{type}/{item_id}-{description}"
  item_prefixes:
    initiative: "I"
    epic: "E"
    feature: "F"
    story: "S"
    task: "T"
    defect: "D"
    event: "EV"

# Issue Types jsou v V2 jen popisná metadata pro dokumenty/board —
# EDPA je NEPROVISUJE do GitHub org (issue_types.py byl odstraněn).
# GitHub je volitelný; bez něj má tato sekce čistě dokumentační účel.
issue_types:
  Initiative: "Strategic business initiative with investment funding"
  Epic: "Large body of work decomposed into features"
  Feature: "A service provided by the system that fulfills a stakeholder need"
  Story: "A small, deliverable unit of value completed within an iteration"
  Defect: "A defect in existing functionality"
  Task: "Technical work without user-facing value"

# Enabler je label klasifikace (Business vs Enabler), ne Issue Type.
labels:
  Enabler: "Infrastructure, research, technical debt"
