# Kashealth pilot — people.yaml seed
#
# 4 členové z kashealth org membership (k 2026-05-06):
#   - jurby          → Jaroslav Urbánek (Lead Architect, ČVUT FBMI)
#   - martinturyna   → Martin Turyna (Dev, ČVUT FBMI)
#   - dmatousek22    → Daniel Matoušek (Dev, FČVUT FBMI)
#   - sirTurbisCZ    → Ondřej Tůma (DevSecOps, ČVUT FBMI)
#
# DOPLNIT před prvním PI:
#   - name (full)
#   - email (preferovaně @kashealth.cz pro M365 license parity)
#   - role z {Arch, Dev, DevSecOps, QA, PO, PM, BO, SME, SRE, Ops}
#   - fte (0.0..1.0) (máme HPP na 1.0 FTE, ale k tomu máme ještě DPP na 5 hodin v měsíci (Urbánek) a 7 hod v měsíci (ostatní), takže bych to připočítal vždy jednu iteraci v měsíci, aby se tam vešlo s využitím možnosti přetížit alokaci)
#   - capacity_per_iteration (hours per 1-week iteration; FTE * 40)
#   - availability {confirmed, partial, unavailable}
#
# POZN. — sazby (hourly_rate / MD rates) zde nejsou. EDPA dnes nikde
# nečte hourly_rate field a item-costs.xlsx nemá sloupce hourly_rate
# ani cost (jen Item, Level, JS, Person, CW, Score, Ratio, Hours).
# Sazby držte v separátním (privátním) registru — dle smluv —
# ne v EDPA configu, který může skončit v public repu.
#
# Kadenci (iteration_weeks / pi_iterations) nastav per-PI v `pi:` bloku
# .edpa/iterations/PI-*.yaml, ne tady. Viz docs/cadence.md.

teams:
  - id: "kashealth"
    planning_factor: 0.8
    # Buffer 20 % na support, incidenty, neplánovanou práci.
    # EDPA výpočet vždy používá 100 % capacity — planning_factor je
    # jen heuristika pro PI Planning, ne pro DerivedHours.

people:
  - id: urbanek-jaroslav
    name: "Jaroslav Urbánek"
    role: Arch
    team: "kashealth"
    fte: 1.0
    capacity_per_iteration: 40       # FTE × 40 (1-week iter)
    email: "jaroslav.urbanek@kashealth.cz"
    github: "jurby"
    availability: confirmed

  - id: turyna-martin
    name: "Martin Turyna"
    role: Dev
    team: "kashealth"
    fte: 1.0
    capacity_per_iteration: 40
    email: "martin.turyna@kashealth.cz"
    github: "martinturyna"
    availability: confirmed

  - id: matousek-daniel
    name: "Daniel Matoušek"
    role: Dev
    team: "kashealth"
    fte: 1.0
    capacity_per_iteration: 40
    email: "daniel.matousek@kashealth.cz"
    github: "dmatousek22"
    availability: confirmed

  - id: tuma-ondrej
    name: "Ondřej Tůma"
    role: DevSecOps
    team: "kashealth"
    fte: 1.0
    capacity_per_iteration: 40
    email: "ondrej.tuma@kashealth.cz"
    github: "sirTurbisCZ"
    availability: confirmed

# ─────────────────────────────────────────────────────────────────────
# Multi-role (volitelně, v1.11+)
# ─────────────────────────────────────────────────────────────────────
# Pokud má někdo dva kontrakty (např. full-time Dev + part-time PM),
# vytvořte pro každý kontrakt zvlášť entry s distinct id (např.
# `smith-dev` + `smith-pm`). Auto-detekce routuje podle github: pole;
# když oba kontrakty sdílí stejný GH login, vyhraje první entry. Pro
# rozdělení kontribucí mezi kontrakty použijte manuální directivu
# `/contribute @smith-pm weight:N` v PR/issue/commit bodies.
#
# Pozn.: pre-v1.11 mělo evidence_default / evidence_scope pole pro
# automatické routování podle item-ID patternů. v1.11 to dropla
# (jednodušší schema, žádné dead-code větve v engine). Pokud bys chtěl
# scope routing zpět, dej vědět pro v1.14 design discussion.
# Plný příklad v plugin/edpa/templates/people.yaml.tmpl § "MULTI-ROLE".
# ─────────────────────────────────────────────────────────────────────

# Backlog item evidence schema (v1.11):
#   contributors[].person                = person id z people[].id výše
#   contributors[].cw                    = per-item share (Σ napříč osobami = 1.0)
#   contributors[].contribution_score    = raw suma signal weights (audit input)
#   contributors[].signals[]             = audit trail (type/ref/weight/detected_at)
#
# Engine v v1.11 čte cw přímo bez další transformace. Auto-populates
# přes detect_contributors.py (z real PR/commit/review evidence).
# Manuální override přes `/contribute @person weight:N` (additive signal,
# detail v docs/contribute-directive.md).
#
# Plný appendix backlog story formats v docs/KASHEALTH-PILOT.md +
# docs/audit-references.md (canonical audit ref taxonomy per signal type).
