# Kashealth pilot — people.yaml seed
#
# 4 členové z kashealth org membership (k 2026-05-06):
#   - jurby          → Jaroslav Urbánek (Lead Architect, ČVUT FBMI)
#   - martinturyna   → Martin Turyna (Dev, ČVUT FBMI)
#   - dmatousek22    → ? Matoušek (Dev, FBMI/Medicalc)
#   - sirTurbisCZ    → ? Tuma (DevSecOps, Medicalc)
#
# DOPLNIT před prvním PI:
#   - name (full)
#   - email (preferovaně @kashealth.cz pro M365 license parity)
#   - role z {Arch, Dev, DevSecOps, QA, PM}
#   - fte (0.0..1.0)
#   - capacity_per_iteration (hours per 1-week iteration; FTE * 40)
#   - hourly_rate (CZK/h, viz docs/examples/governance-kashealth/governance-reseni-v3.md)
#   - availability {confirmed, partial, unavailable}

cadence:
  # AI-native default per EDPA: 1-week delivery iteration × 5 (4 delivery + 1 IP).
  # Pokud preferujete classic SAFe (2-week iter × 5 = 10 weeks), nastavte
  # iteration_weeks: 2 a pi_weeks: 10.
  iteration_weeks: 1
  pi_weeks: 5
  delivery_iterations_per_pi: 4
  ip_iterations_per_pi: 1

teams:
  - id: "kashealth"
    planning_factor: 0.8
    # Buffer 20 % na support, incidenty, neplánovanou práci.
    # EDPA výpočet vždy používá 100 % capacity — planning_factor je
    # jen heuristika pro PI Planning, ne pro DerivedHours.

people:
  - id: jurby
    name: "Jaroslav Urbánek"
    role: Arch
    team: "kashealth"
    fte: 0.5             # ← UPRAVTE
    capacity_per_iteration: 20  # FTE × 40 (1-week iter)
    email: "urbanek.jaroslav@gmail.com"   # ← preferovaně @kashealth.cz
    github: "jurby"
    hourly_rate: 2400    # CZK/h, dle governance-reseni-v3.md
    availability: confirmed

  - id: turyna
    name: "Martin Turyna"
    role: Dev
    team: "kashealth"
    fte: 1.0             # ← UPRAVTE
    capacity_per_iteration: 40
    email: ""             # ← DOPLNIT
    github: "martinturyna"
    hourly_rate: 1800
    availability: confirmed

  - id: matousek
    name: "? Matoušek"   # ← DOPLNIT plné jméno
    role: Dev
    team: "kashealth"
    fte: 1.0             # ← UPRAVTE
    capacity_per_iteration: 40
    email: ""             # ← DOPLNIT
    github: "dmatousek22"
    hourly_rate: 1800
    availability: confirmed

  - id: tuma
    name: "? Tuma"       # ← DOPLNIT plné jméno
    role: DevSecOps
    team: "kashealth"
    fte: 1.0             # ← UPRAVTE
    capacity_per_iteration: 40
    email: ""             # ← DOPLNIT
    github: "sirTurbisCZ"
    hourly_rate: 2000
    availability: confirmed

# ─────────────────────────────────────────────────────────────────────
# Multi-role (volitelně) — pokud má někdo dva kontrakty (např. full-time
# Dev + part-time PM), vytvořte pro každý kontrakt zvlášť entry s
# odlišným id a odpovídajícím evidence_default / evidence_scope.
# Příklad v plugin/edpa/templates/people.yaml.tmpl § "MULTI-ROLE".
# ─────────────────────────────────────────────────────────────────────

# Backlog item evidence schema:
#   contributors[].as = evidence role: owner | key | reviewer | consulted
#                       (NE job role z people[].role výše)
#   contributors[].cw = 0..1 manuální contribution weight
#
# Plný example backlog story v docs/KASHEALTH-PILOT.md § 5.
