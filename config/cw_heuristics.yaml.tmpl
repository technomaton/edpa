# EDPA Contribution Weight Heuristics v1.0.0
# Calibrated via Monte Carlo simulation (1000 scenarios, 68,156 records)
# + multi-scenario validation (8 scenarios, 569 pairs)
# + full 2-PI simulation (172 ground truth records)
# MAD reduction: 7.9% (Monte Carlo) / 13.2% (combined)
#
# These defaults work for most teams. Auto-calibration (after 1st PI) will
# further optimize them for your specific team composition.

version: "1.0.0"

# Minimum evidence score to be considered a contributor
evidence_threshold: 1.0

# CW assigned per evidence role (highest signal wins)
# Generic defaults — conservative, suitable for teams without role data
role_weights:
  owner: 1.0           # assignee on issue — stable across all 1000 scenarios
  key: 0.6             # PR author, explicit /contribute — stable
  reviewer: 0.25       # PR reviewer, commit author — generic default
  consulted: 0.15      # issue/PR comment only — generic default

# Per-role overrides (applied when team member's role is known)
# Validated by Monte Carlo (1000 scenarios, p<0.001 for all biases)
# These correct for systematic biases: Git measures activity, not value
role_overrides:
  BO:                    # Business Owner — strategic decisions not visible in Git
    consulted: 0.30      # Monte Carlo: median=0.30, n=1,597, 74.4% corrected, p<0.001
    reviewer: 0.35       # Monte Carlo: median=0.35, n=341, 61.0% corrected, p<0.001
  PM:                    # Product Manager — requirements, AC, stakeholder mgmt
    consulted: 0.20      # Monte Carlo: median=0.20, n=6,304, 59.7% corrected, p<0.001
    reviewer: 0.25       # Monte Carlo: median=0.25, n=1,213, 45.6% corrected, p<0.001
  Arch:                  # Architect — design reviews, mentoring, architecture
    reviewer: 0.30       # Monte Carlo: median=0.30, n=3,120, 55.4% corrected, p<0.001
    key: 0.60            # stable (median=0.60, 15.8% corrected)
    owner: 1.00          # stable
  Dev:                   # Developer — best calibrated by auto-detection
    owner: 1.00          # Monte Carlo: median=1.00, n=18,472, only 5.1% corrected
    key: 0.60            # Monte Carlo: median=0.60, n=15,078, 15.0% corrected
    reviewer: 0.25       # Monte Carlo: median=0.25, n=6,392, 25.0% corrected
  DevSecOps:             # DevSecOps — infra work sometimes invisible to Git
    reviewer: 0.25       # Monte Carlo: median=0.25, n=1,275, 40.2% corrected
    key: 0.60            # stable
    owner: 1.00          # stable
  QA:                    # QA/Test — many test commits ≠ ownership
    key: 0.60            # Monte Carlo: median=0.60, n=2,966 (25.9% corrected down)
    reviewer: 0.25       # Monte Carlo: median=0.25, n=6,642, stable

# Evidence signals and their scoring weights
signals:
  assignee: 4.0             # GitHub issue assignee
  contribute_command: 3.0    # /contribute @person weight:X
  pr_author: 2.0            # PR author referencing item
  commit_author: 1.0        # Commit message with S-XXX/F-XXX/E-XXX
  pr_reviewer: 1.0          # Approved/reviewed PR referencing item
  issue_comment: 0.5        # Meaningful comment on issue/PR

# Rules
rules:
  - "Highest signal determines CW (no summing)"
  - "Manual override (/contribute) takes precedence over auto-detection"
  - "Commit count does NOT convert to time — only signals relevance"
  - "In Progress items are excluded from EDPA calculation"
  - "Role overrides apply when team member role is known from capacity.yaml"

# Calibration metadata
calibration:
  method: "Monte Carlo + multi-scenario + 2-PI simulation"
  monte_carlo:
    scenarios: 1000
    records: 68156
    mad_reduction: "7.9%"
    confidence: "HIGH (p<0.001 for all biases)"
  multi_scenario:
    scenarios: 8
    types: ["Startup (5)", "Enterprise (12)", "DevOps-heavy (7)", "Research (6)", "Consultancy (8)", "AI-Native (5)", "Regulated (9)", "kashealth (7)"]
    records: 569
    mad_reduction: "16.3%"
  simulation:
    pis: 2
    iterations: 10
    commits: 510
    ground_truth_records: 172
    mad_trend: "0.0412 → 0.0333 (↓19.2%)"
  calibrated_at: "2026-03-22"
  key_findings:
    - "BO/PM/Arch systematically undervalued — Git measures activity, not value"
    - "Dev is perfectly calibrated — Git signals match real contribution"
    - "QA slightly overvalued at 'key' level (test commits ≠ co-ownership)"
    - "All biases statistically significant (p<0.001, Monte Carlo 68k records)"
    - "Generic role_weights kept conservative; role_overrides carry corrections"
