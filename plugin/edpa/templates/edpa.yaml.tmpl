# EDPA Project Configuration
# Edit this file to match your project. Only `project.name` is read by the
# engine today (other fields populate audit metadata, snapshots, and
# document generators). All optional fields default to empty strings.

project:
  name: "My Project"                          # ← Display name (required)
  description: ""                              # Free-text project description
  domain: ""                                   # Optional domain URL (e.g., myproject.cz)

  # Optional: external funding info (grants, subsidies, contracts).
  # Drop this whole `funding:` block if the project has no external
  # funding instrument. Used by document generators (grant reports,
  # invoice headers) to reference the funding context.
  funding:
    program: ""                                # Funding program (e.g., "OP TAK", "Horizon Europe", "ARPA-H")
    registration: ""                           # Grant/contract registration number
    period_start: ""                           # YYYY-MM-DD (optional; project funding period start)
    period_end: ""                             # YYYY-MM-DD (optional; project funding period end)

  # Organizations involved in delivery — for audit trail, invoicing,
  # and document generation. Each entry's identification + address
  # populates reports and invoices without re-keying.
  #
  # Field naming notes (generic, internationally portable):
  #   tax_id   → company / entity identifier
  #              (CZ: ICO, USA: EIN, UK: CRN, EU: national tax ID)
  #   vat_id   → VAT / sales-tax identifier
  #              (CZ: DIC, EU: VAT-ID with country prefix e.g. DE123456789,
  #               UK: VAT, USA: typically empty)
  #   role     → free string; common values:
  #              primary | partner | subcontractor | client | consortium-lead
  #              (use whatever taxonomy your reporting requires)
  #   country  → ISO 3166-1 alpha-2 (e.g., "CZ", "US", "DE", "UK")
  organizations:
    - name: ""                                 # Display name (e.g., "Acme Corp")
      legal_name: ""                           # Full legal name on official documents
      role: "primary"
      tax_id: ""
      vat_id: ""
      address:
        street: ""
        city: ""
        postal_code: ""
        country: ""
      contact:
        email: ""
        phone: ""
        website: ""
    - name: ""                                 # Partner organization (optional; remove block if N/A)
      legal_name: ""
      role: "partner"
      tax_id: ""
      vat_id: ""
      address:
        street: ""
        city: ""
        postal_code: ""
        country: ""
      contact:
        email: ""
        phone: ""
        website: ""

governance:
  # Auto-stamped to the installed plugin version by install.sh / project_setup.py.
  methodology: "EDPA 2.1.8"
  # v1.14: single calculation path. v1.17: extended with yaml_edit
  # signals — every commit on .edpa/backlog/<typ>/<id>.md in the
  # iteration window contributes structural credit (create / block_add
  # / list_grow / scalar_change / lines_volume / contributors_rebalance
  # / revert). v1.17 also fixes Bug A (Defects were silently dropped
  # at engine.py level filter). The pre-v1.14 simple/full/gates mode
  # selector remains dropped — gates was a strict superset of simple
  # (degenerated to Done-only when no transitions). audit_mode field
  # also dropped — snapshots always carry the full signals[] audit trail.

# Plugin upgrade behavior (v1.22.1+)
#
# When the EDPA plugin updates (`/plugin update edpa`), Claude Code's
# SessionStart hook compares the bundled plugin VERSION against the
# project's `.edpa/engine/VERSION` and re-vendors scripts/schemas/
# templates when they diverge. No manual `/edpa:setup` re-run needed.
#
# Set `auto_update_engine: false` to disable this. You then must run
# `/edpa:setup` manually after each `/plugin update` to refresh
# `.edpa/engine/`. Useful when you have local patches on the vendored
# engine you don't want overwritten, or strict environments that
# forbid silent file mutation.
#
# Default behavior (flag absent or `true`): auto-update on session start.
# auto_update_engine: false

naming:
  pi_pattern: "PI-{year}-{pi_num}"            # e.g., PI-2026-1
  iteration_pattern: "PI-{year}-{pi_num}.{iter_num}"  # e.g., PI-2026-1.3
  branch_pattern: "{type}/{item_id}-{description}"    # e.g., feature/S-200-omop-parser
  item_prefixes:
    initiative: "I"
    epic: "E"
    feature: "F"
    story: "S"
    task: "T"
    defect: "D"
    event: "EV"                                  # PI events (system demo, retro, planning)

# Native GitHub Issue Types (org-level, not labels)
issue_types:
  Initiative: "Business case, investment proposal"
  Epic: "Strategic goal, 6-9 months"
  Feature: "Must fit within a Planning Interval"
  Story: "Delivered in an iteration"
  Defect: "Defect in existing functionality"
  Task: "Technical work"

# Enabler is a label classification (Business vs Enabler), not an Issue Type
# An Epic can be labeled "Enabler" to mark it as Enabler Epic (SAFe)
labels:
  Enabler: "Infrastructure, research, technical debt"
