{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/edpa/scripts/hooks/install_deps.sh",
            "timeout": 30,
            "statusMessage": "EDPA — checking Python deps"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/edpa/scripts/hooks/update_engine.sh",
            "timeout": 20,
            "statusMessage": "EDPA — checking engine version"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/edpa/scripts/hooks/validate_on_save.sh",
            "timeout": 10,
            "statusMessage": "Validating syntax..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/edpa/scripts/hooks/edpa_post_commit.sh",
            "timeout": 10,
            "statusMessage": "EDPA commit info"
          }
        ]
      }
    ]
  }
}
