---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const isEn = currentPath.startsWith('/en/') || currentPath === '/en';
const prefix = isEn ? '/en' : '';

const links = [
  { href: `${prefix}/`, label: 'EDPA' },
  { href: `${prefix}/dashboard/`, label: 'Dashboard' },
  { href: `${prefix}/presentation/`, label: isEn ? 'Presentation' : 'Prezentace' },
  { href: `${prefix}/methodology/`, label: isEn ? 'Methodology' : 'Metodika' },
  { href: `${prefix}/evaluation/`, label: isEn ? 'Evaluation' : 'Evaluace' },
];

const switchPath = isEn
  ? currentPath.replace(/^\/en(\/|$)/, '/')
  : `/en${currentPath}`;
---
<header class="site-header">
  <div class="container header-inner">
    <a href={`${prefix}/`} class="logo">
      <span class="logo-text">EDPA</span>
      <span class="logo-version">v1.0.0</span>
    </a>
    <nav class="main-nav">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || (link.href !== `${prefix}/` && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="lang-switch">
      <a href={switchPath} class="lang-link">{isEn ? 'CS' : 'EN'}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8, 10, 16, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bd);
    height: 56px;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }
  .logo-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--ac), var(--cy));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .logo-version {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--t3);
    padding: 2px 5px;
    background: var(--s2);
    border-radius: 4px;
  }
  .main-nav {
    display: flex;
    gap: 4px;
  }
  .nav-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--t2);
    padding: 6px 12px;
    border-radius: 6px;
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-link:hover { background: var(--s2); color: var(--t1); }
  .nav-link.active { background: rgba(99, 102, 241, 0.12); color: var(--ac2); }
  .lang-switch {
    margin-left: 8px;
  }
  .lang-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    color: var(--t3);
    padding: 4px 8px;
    border: 1px solid var(--bd);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .lang-link:hover {
    color: var(--ac2);
    border-color: var(--ac);
  }
  @media (max-width: 768px) {
    .main-nav { display: none; }
  }
</style>
