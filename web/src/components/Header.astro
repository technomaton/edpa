---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const isEn = currentPath.startsWith('/en/') || currentPath === '/en';
const prefix = isEn ? '/en' : '';

const links = [
  { href: `${prefix}/`, label: 'EDPA' },
  { href: `${prefix}/dashboard/`, label: 'Dashboard' },
  { href: `${prefix}/presentation/`, label: isEn ? 'Presentation' : 'Prezentace' },
  { href: `${prefix}/methodology/`, label: isEn ? 'Methodology' : 'Metodika' },
  { href: `${prefix}/evaluation/`, label: isEn ? 'Evaluation' : 'Evaluace' },
];

const switchPath = isEn
  ? currentPath.replace(/^\/en(\/|$)/, '/')
  : `/en${currentPath}`;
---
<header class="site-header" role="banner">
  <div class="container header-inner">
    <a href={`${prefix}/`} class="logo">
      <span class="logo-text">EDPA</span>
      <span class="logo-version">v1.0.0</span>
    </a>
    <nav class="main-nav" aria-label="Main navigation">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || (link.href !== `${prefix}/` && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="lang-switch">
      <a href={switchPath} class="lang-link" aria-label="Switch language">{isEn ? 'CS' : 'EN'}</a>
    </div>
    <button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
  <div class="mobile-menu" aria-label="Mobile navigation">
    {links.map(link => (
      <a
        href={link.href}
        class:list={['mobile-nav-link', { active: currentPath === link.href || (link.href !== `${prefix}/` && currentPath.startsWith(link.href)) }]}
      >
        {link.label}
      </a>
    ))}
    <div class="mobile-lang-switch">
      <a href={switchPath} class="lang-link" aria-label="Switch language">{isEn ? 'CS' : 'EN'}</a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', initHamburger);
  document.addEventListener('DOMContentLoaded', initHamburger);

  function initHamburger() {
    const btn = document.querySelector('.hamburger');
    const menu = document.querySelector('.mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('open');
      btn.classList.toggle('open', isOpen);
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8, 10, 16, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bd);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }
  .logo-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--ac), var(--cy));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .logo-version {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--t3);
    padding: 2px 5px;
    background: var(--s2);
    border-radius: 4px;
  }
  .main-nav {
    display: flex;
    gap: 4px;
  }
  .nav-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--t2);
    padding: 6px 12px;
    border-radius: 6px;
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-link:hover { background: var(--s2); color: var(--t1); }
  .nav-link.active { background: rgba(99, 102, 241, 0.12); color: var(--ac2); }
  .lang-switch {
    margin-left: 8px;
  }
  .lang-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    color: var(--t3);
    padding: 4px 8px;
    border: 1px solid var(--bd);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .lang-link:hover {
    color: var(--ac2);
    border-color: var(--ac);
  }
  /* Hamburger button — hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    background: none;
    border: 1px solid var(--bd);
    border-radius: 6px;
    padding: 6px 7px;
    cursor: pointer;
    margin-left: 8px;
  }
  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--t2);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }
  .hamburger.open .hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open .hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile dropdown menu — hidden by default */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--s1);
    border-top: 1px solid var(--bd);
    border-bottom: 1px solid var(--bd);
    padding: 8px 24px 12px;
  }
  .mobile-menu.open {
    display: flex;
  }
  .mobile-nav-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--t2);
    padding: 10px 0;
    border-bottom: 1px solid var(--bd);
    text-decoration: none;
    transition: color 0.15s;
  }
  .mobile-nav-link:last-of-type {
    border-bottom: none;
  }
  .mobile-nav-link:hover { color: var(--t1); }
  .mobile-nav-link.active { color: var(--ac); }
  .mobile-lang-switch {
    padding-top: 10px;
    border-top: 1px solid var(--bd);
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .main-nav { display: none; }
    .lang-switch { display: none; }
    .hamburger { display: flex; }
  }
</style>
