---

<Layout title="Průvodce — od nuly k prvnímu reportu" description="Interaktivní průvodce EDPA frameworkem: 12 kroků od instalace po první výkaz.">

  <!-- Progress bar -->
  <div class="guide-progress" id="guideProgress">
    <div class="progress-track">
      {phases.map(phase => (
        <div class="progress-phase" style={`--phase-color: ${phase.color}`}>
          <span class="phase-label">{phase.label}</span>
          <div class="phase-dots">
            {phase.steps.map(s => (
              <span class="phase-dot" data-step={s}></span>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </div>

  <!-- Hero -->
  <section class="section guide-hero">
    <div class="container">
      <p class="tag">Step-by-Step Guide</p>
      <h1 class="guide-title">Od nuly k prvnímu reportu</h1>
      <p class="guide-subtitle">
        10 kroků, které vás provedou celým EDPA frameworkem —
        od instalace po kalibrovaný výkaz hodin.
      </p>
      <a href="#step-1" class="btn btn-primary">Začít průvodce</a>
    </div>
  </section>

  <!-- Steps -->
  {steps.map((step, i) => (
    <section class="guide-step" id={`step-${step.num}`} style={`--step-color: ${step.color}`}>
      <div class="container">
        <div class="step-header">
          <span class="step-number" style={`color: ${step.color}`}>{String(step.num).padStart(2, '0')}</span>
          <div>
            <h2 class="step-title">{step.title}</h2>
            <p class="step-desc">{step.desc}</p>
          </div>
        </div>

        <div class="step-content">
          <div class="step-code">
            {step.claude && (
              <div class="cmd-tabs">
                <button class="cmd-tab active" data-tab="claude">Claude Code</button>
                <button class="cmd-tab" data-tab="cli">CLI</button>
              </div>
            )}
            {step.claude && (
              <div class="cmd-panel" data-panel="claude">
                <div class="code-header">
                  <span class="code-dot red"></span>
                  <span class="code-dot yellow"></span>
                  <span class="code-dot green"></span>
                  <span class="code-label">claude code (doporuceno)</span>
                </div>
                <pre><code>{step.claude}</code></pre>
              </div>
            )}
            <div class={step.claude ? "cmd-panel" : undefined} data-panel={step.claude ? "cli" : undefined} style={step.claude ? "display:none" : undefined}>
              <div class="code-header">
                <span class="code-dot red"></span>
                <span class="code-dot yellow"></span>
                <span class="code-dot green"></span>
                <span class="code-label">terminal</span>
              </div>
              <pre><code>{step.code}</code></pre>
            </div>
          </div>

          <div class="step-result">
            <div class="result-label">Ocekavany vystup</div>
            <pre><code>{step.result}</code></pre>
          </div>
        </div>

        <div class="step-nav">
          {i > 0 && (
            <a href={`#step-${steps[i - 1].num}`} class="btn btn-secondary step-prev-btn">Zpet</a>
          )}
          {i < steps.length - 1 ? (
            <a href={`#step-${steps[i + 1].num}`} class="btn btn-primary step-next-btn">Dalsi krok &rarr;</a>
          ) : (
            <a href="/" class="btn btn-primary step-next-btn">Hotovo — zpet na EDPA</a>
          )}
        </div>
      </div>
    </section>
  ))}

</Layout>

<script>
  function initGuideProgress() {
    const sections = document.querySelectorAll('.guide-step');
    const dots = document.querySelectorAll('.phase-dot');
    const fill = document.getElementById('progressFill');
    if (!sections.length || !fill) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          const num = parseInt(id.replace('step-', ''));
          const pct = (num / 10) * 100;
          fill.style.width = pct + '%';
          dots.forEach(d => {
            const ds = parseInt(d.getAttribute('data-step') || '0');
            d.classList.toggle('active', ds <= num);
          });
        }
      });
    }, { threshold: 0.3 });

    sections.forEach(s => observer.observe(s));
  }
  function initCmdTabs() {
    document.querySelectorAll('.cmd-tabs').forEach(tabs => {
      tabs.querySelectorAll('.cmd-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const parent = tabs.closest('.step-code');
          if (!parent) return;
          const target = btn.getAttribute('data-tab');
          tabs.querySelectorAll('.cmd-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          parent.querySelectorAll('.cmd-panel').forEach(p => {
            (p as HTMLElement).style.display = p.getAttribute('data-panel') === target ? '' : 'none';
          });
        });
      });
    });
  }
  document.addEventListener('DOMContentLoaded', () => { initGuideProgress(); initCmdTabs(); });
  document.addEventListener('astro:page-load', () => { initGuideProgress(); initCmdTabs(); });
</script>

<style>
  /* Progress bar — sticky top */
  .guide-progress {
    position: sticky;
    top: 56px;
    z-index: 90;
    background: rgba(8, 10, 16, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bd);
    padding: 10px 24px 8px;
  }
  .progress-track {
    display: flex;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto 8px;
  }
  .progress-phase {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .phase-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--phase-color);
    opacity: 0.7;
  }
  .phase-dots {
    display: flex;
    gap: 6px;
  }
  .phase-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--s3);
    transition: background 0.3s, box-shadow 0.3s;
  }
  .phase-dot.active {
    background: var(--phase-color);
    box-shadow: 0 0 8px var(--phase-color);
  }
  .progress-bar {
    max-width: 1200px;
    margin: 0 auto;
    height: 3px;
    background: var(--s2);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--ac), var(--cy), var(--gn), var(--yl));
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  /* Hero */
  .guide-hero {
    text-align: center;
    padding: 80px 0 60px;
  }
  .guide-title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    margin: 12px 0;
    background: linear-gradient(135deg, var(--t1), var(--ac3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .guide-subtitle {
    font-size: 17px;
    color: var(--t2);
    max-width: 600px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }

  /* Steps */
  .guide-step {
    padding: 64px 0;
    border-left: 3px solid var(--step-color);
    margin-left: 24px;
    scroll-margin-top: 120px;
  }
  @media (max-width: 768px) {
    .guide-step {
      margin-left: 0;
      border-left: none;
      border-top: 3px solid var(--step-color);
    }
  }
  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 28px;
  }
  .step-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
    opacity: 0.85;
    flex-shrink: 0;
  }
  .step-title {
    font-size: 26px;
    font-weight: 700;
    color: var(--t1);
    margin-bottom: 6px;
  }
  .step-desc {
    font-size: 15px;
    color: var(--t2);
    line-height: 1.6;
    max-width: 640px;
  }

  /* Code block */
  .step-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 900px) {
    .step-content {
      grid-template-columns: 1fr;
    }
  }
  .step-code {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
  }
  .code-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--s2);
    border-bottom: 1px solid var(--bd);
  }
  .code-dot {
    width: 10px;
    height: 10px;
