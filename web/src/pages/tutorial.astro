<script>
  function initTutorial() {
    // ---- Intersection Observer: fade-in elements ----
    const fadeEls = document.querySelectorAll('.fade-in');
    const fadeObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          fadeObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    fadeEls.forEach(el => fadeObs.observe(el));

    // ---- Terminal lines: staggered reveal ----
    const terminalBodies = document.querySelectorAll('.terminal-body');
    const termObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          revealTerminal(entry.target);
          termObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    terminalBodies.forEach(el => termObs.observe(el));

    function revealTerminal(container: Element) {
      const items = container.querySelectorAll('[data-delay]');
      items.forEach(item => {
        const delay = parseInt(item.getAttribute('data-delay') || '0', 10);
        setTimeout(() => {
          item.classList.add('shown');
        }, delay * 350);
      });
    }

    // ---- MAD bar widths ----
    const madBars = document.querySelectorAll('.mad-bar');
    madBars.forEach(bar => {
      const w = bar.getAttribute('data-width') || '100';
      (bar as HTMLElement).style.setProperty('--bar-w', w);
    });

    // ---- Counter animation ----
    const counters = document.querySelectorAll('.counter');
    const counterObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          counterObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(el => counterObs.observe(el));

    function animateCounter(el: HTMLElement) {
      const target = parseFloat(el.getAttribute('data-target') || '0');
      const decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);
      const duration = 1200;
      const start = performance.now();

      function update(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        // ease-out cubic
        const ease = 1 - Math.pow(1 - progress, 3);
        const current = target * ease;
        el.textContent = current.toFixed(decimals);
        if (progress < 1) {
          requestAnimationFrame(update);
        }
      }
      requestAnimationFrame(update);
    }
  }

  // Support both initial load and Astro page transitions
  document.addEventListener('DOMContentLoaded', initTutorial);
  document.addEventListener('astro:page-load', initTutorial);
</script>
