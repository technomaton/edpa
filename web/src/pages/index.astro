---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Evidence-Driven Proportional Allocation">

  <!-- Hero Section -->
  <section class="hero section">
    <div class="container hero-inner">
      <p class="tag">Evidence-Driven Proportional Allocation</p>
      <h1 class="hero-headline">Čas se neměří — odvozuje se</h1>
      <p class="hero-subtitle">
        EDPA v2.2 nahrazuje ruční timesheety automatickým odvozením hodin
        z GitHub delivery evidence. Matematická garance, nulová administrativa.
      </p>
      <div class="grid grid-4 hero-stats">
        <div class="card accent">
          <p class="stat-label">Timesheety</p>
          <p class="stat-value">Zero</p>
          <p class="stat-desc">Žádné ruční logování</p>
        </div>
        <div class="card green">
          <p class="stat-label">Garance</p>
          <p class="stat-value">Sum = Capacity</p>
          <p class="stat-desc">Matematicky zaručeno</p>
        </div>
        <div class="card cyan">
          <p class="stat-label">Analytika</p>
          <p class="stat-value">Dual-view</p>
          <p class="stat-desc">Per-person i per-item</p>
        </div>
        <div class="card yellow">
          <p class="stat-label">Kalibrace</p>
          <p class="stat-value">Self-tuning</p>
          <p class="stat-desc">Auto-kalibrace (Karpathy loop)</p>
        </div>
      </div>
      <div class="hero-actions">
        <a href="/dashboard/" class="btn btn-primary">Dashboard demo</a>
        <a href="/presentation/" class="btn btn-secondary">Prezentace</a>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="section" id="problem">
    <div class="container">
      <p class="tag">Kontext</p>
      <h2 class="section-title">Proč potřebujeme EDPA?</h2>
      <div class="grid grid-4 problem-grid">
        <div class="card orange">
          <h3 class="card-heading">Nepřesnost</h3>
          <p class="card-text">
            Ruční timesheety jsou subjektivní. Lidé odhadují, zaokrouhlují,
            zapomínají. Data neodpovídají realitě.
          </p>
        </div>
        <div class="card orange">
          <h3 class="card-heading">Auditní noční můra</h3>
          <p class="card-text">
            Při kontrole OP TAK nelze zpětně prokázat, kdo na čem pracoval.
            Chybí evidence, chybí průkaznost.
          </p>
        </div>
        <div class="card orange">
          <h3 class="card-heading">Administrativní zátěž</h3>
          <p class="card-text">
            Vyplňování výkazů zabírá čas, který by mohl jít do vývoje.
            Nikdo nemá rád timesheety.
          </p>
        </div>
        <div class="card orange">
          <h3 class="card-heading">Žádný per-item pohled</h3>
          <p class="card-text">
            Tradiční systémy ukazují pouze osobní výkazy. Kolik stál
            konkrétní deliverable? Nelze zjistit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution / How it Works -->
  <section class="section" id="solution">
    <div class="container">
      <p class="tag">Řešení</p>
      <h2 class="section-title">Jak EDPA funguje</h2>
      <div class="formula">Score = JobSize × ContributionWeight × RelevanceSignal
DerivedHours = (Score / ΣScores) × Capacity

Garance: Σ DerivedHours = Capacity — vždy, bez výjimky.</div>
      <p class="desc">
        Systém se skládá ze tří oddělených vrstev, které spolupracují
        na automatickém odvození pracovních hodin.
      </p>
      <div class="grid grid-3 layers-grid">
        <div class="card accent">
          <h3 class="card-heading">Operational Metadata</h3>
          <p class="layer-source">GitHub Issues + Projects</p>
          <p class="card-text">
            Živá delivery data. Hierarchie, status, Job Size, WSJF.
            Vše co tým již denně používá.
          </p>
        </div>
        <div class="card cyan">
          <h3 class="card-heading">Capacity Registry</h3>
          <p class="layer-source">YAML config v repo</p>
          <p class="card-text">
            Kapacita, role, FTE. Potvrzeno při Iteration Planning.
            Jediný manuální vstup do systému.
          </p>
        </div>
        <div class="card green">
          <h3 class="card-heading">Evidence &amp; Reporting</h3>
          <p class="layer-source">/snapshots &middot; /reports &middot; /signed</p>
          <p class="card-text">
            Frozen snapshoty, výkazy, BankID podpisy. Immutable a
            auditovatelné.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Evidence Detection -->
  <section class="section" id="evidence">
    <div class="container">
      <p class="tag">Detekce evidence</p>
      <h2 class="section-title">Signály z GitHubu</h2>
      <p class="desc">
        EDPA automaticky detekuje příspěvky vývojářů z GitHub aktivit.
        Každý signál má přiřazenou váhu (prioritu) a odpovídající ContributionWeight.
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Signál</th>
              <th>Priorita</th>
              <th>CW</th>
              <th>Popis</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>Assignee</code></td>
              <td class="td-priority">+4</td>
              <td class="td-cw">1.0</td>
              <td>Hlavní řešitel issue</td>
            </tr>
            <tr>
              <td><code>/contribute</code></td>
              <td class="td-priority">+3</td>
              <td class="td-cw">0.6</td>
              <td>Explicitní přihlášení ke spolupráci</td>
            </tr>
            <tr>
              <td><code>PR author</code></td>
              <td class="td-priority">+2</td>
              <td class="td-cw">0.6</td>
              <td>Autor pull requestu</td>
            </tr>
            <tr>
              <td><code>Commit</code></td>
              <td class="td-priority">+1</td>
              <td class="td-cw">0.25</td>
              <td>Commit v relevantní větvi</td>
            </tr>
            <tr>
              <td><code>PR reviewer</code></td>
              <td class="td-priority">+1</td>
              <td class="td-cw">0.25</td>
              <td>Code review pull requestu</td>
            </tr>
            <tr>
              <td><code>Comment</code></td>
              <td class="td-priority">+0.5</td>
              <td class="td-cw">0.15</td>
              <td>Komentář v issue nebo PR</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Dual-View -->
  <section class="section" id="dual-view">
    <div class="container">
      <p class="tag">Dual-View analytika</p>
      <h2 class="section-title">Dva pohledy, jeden dataset</h2>
      <div class="grid grid-2 dual-grid">
        <div class="card green">
          <h3 class="dual-title dual-title-green">Per-Person</h3>
          <p class="dual-question">
            Jak se kapacita člověka rozloží napříč položkami?
          </p>
          <div class="formula dual-formula">DerivedHours = (Score / ΣScores) × Capacity
Garance: Σ = Capacity</div>
          <p class="dual-usecase">Výkaz pro OP TAK</p>
        </div>
        <div class="card cyan">
          <h3 class="dual-title dual-title-cyan">Per-Item</h3>
          <p class="dual-question">
            Kolik lidí a hodin stál item X?
          </p>
          <div class="formula dual-formula dual-formula-cyan">ItemShare = DerivedHours[P] / Σ DerivedHours[*]
Garance: Σ podílů = 100%</div>
          <p class="dual-usecase">Nákladová alokace per deliverable</p>
        </div>
      </div>
      <div class="note">
        Oba pohledy vychází ze stejných dat (CW, JobSize, Capacity).
        Žádná duplikace, žádný konflikt.
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="section" id="features">
    <div class="container">
      <p class="tag">Klíčové vlastnosti</p>
      <h2 class="section-title">Proč EDPA funguje</h2>
      <div class="grid grid-3 features-grid">
        <div class="card accent">
          <h3 class="card-heading">Zero manual input</h3>
          <p class="card-text">
            Žádné timesheety. Výkaz je vedlejší produkt dodávky.
            Tým pracuje, systém počítá.
          </p>
        </div>
        <div class="card green">
          <h3 class="card-heading">Matematická garance</h3>
          <p class="card-text">
            Σ DerivedHours = Capacity. Vždy.
            Proporcionální alokace zajišťuje konzistenci.
          </p>
        </div>
        <div class="card cyan">
          <h3 class="card-heading">Dual-view analytika</h3>
          <p class="card-text">
            Per-person výkazy pro reporting. Per-item nákladové karty
            pro management. Jeden dataset.
          </p>
        </div>
        <div class="card yellow">
          <h3 class="card-heading">Audit-grade (BankID)</h3>
          <p class="card-text">
            Frozen snapshoty + BankID podpisy. Právně silnější
            než papírové výkazy.
          </p>
        </div>
        <div class="card accent">
          <h3 class="card-heading">Self-tuning</h3>
          <p class="card-text">
            Karpathy loop: compare → adjust → repeat.
            Systém se automaticky kalibruje na reálná data.
          </p>
        </div>
        <div class="card green">
          <h3 class="card-heading">GitHub-native</h3>
          <p class="card-text">
            GitHub Actions, branch naming conventions, issue tracking.
            Žádné externí nástroje.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section" id="cta">
    <div class="container cta-inner">
      <h2 class="section-title cta-title">Prozkoumejte EDPA</h2>
      <p class="cta-desc">
        Dashboard, case study, prezentace, metodika i evaluace — vše na jednom místě.
      </p>
      <div class="cta-links">
        <a href="/dashboard/" class="btn btn-primary">Dashboard demo</a>
        <a href="/dashboard/kashealth/" class="btn btn-secondary">kashealth.cz case study</a>
        <a href="/presentation/" class="btn btn-secondary">Prezentace</a>
        <a href="/methodology/" class="btn btn-secondary">Metodika</a>
        <a href="/evaluation/" class="btn btn-secondary">Evaluace &amp; testy</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero { padding-top: 100px; padding-bottom: 60px; }
  .hero-inner { text-align: center; }
  .hero-headline {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(28px, 5vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    background: linear-gradient(135deg, var(--ac2), var(--cy));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    font-size: 16px;
    color: var(--t2);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto 32px;
  }
  .hero-stats { max-width: 900px; margin: 0 auto 32px; }
  .hero-stats .card { text-align: center; padding: 20px 16px; }
  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--t3);
    margin-bottom: 6px;
  }
  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 20px;
    font-weight: 700;
    color: var(--t1);
    margin-bottom: 4px;
  }
  .stat-desc {
    font-size: 12px;
    color: var(--t2);
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Section titles */
  .section-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
    color: var(--t1);
  }

  /* Shared card heading */
  .card-heading {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    color: var(--t1);
    margin-bottom: 8px;
  }
  .problem-grid .card-heading { color: var(--or); }
  .card-text {
    font-size: 13px;
    color: var(--t2);
    line-height: 1.6;
  }

  /* Section description */
  .desc {
    font-size: 14px;
    color: var(--t2);
    line-height: 1.6;
    max-width: 700px;
    margin-bottom: 24px;
  }

  /* Layer source label */
  .layer-source {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--t3);
    margin-bottom: 10px;
  }

  /* Evidence table */
  .table-wrap {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
  }
  .table-wrap table { margin: 0; }
  .td-priority, .td-cw {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
  }
  .td-priority { color: var(--yl); }
  .td-cw { color: var(--gn); }

  /* Dual-View */
  .dual-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .dual-title-green { color: var(--gn); }
  .dual-title-cyan { color: var(--cy); }
  .dual-question {
    font-size: 14px;
    color: var(--t2);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .dual-formula {
    font-size: 12px;
    margin: 12px 0;
  }
  .dual-formula-cyan {
    border-left-color: var(--cy);
    color: var(--cy);
  }
  .dual-usecase {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--ac3);
    margin-top: 8px;
  }

  /* CTA */
  .cta-section {
    text-align: center;
  }
  .cta-title {
    background: linear-gradient(135deg, var(--ac2), var(--cy));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cta-desc {
    font-size: 15px;
    color: var(--t2);
    line-height: 1.6;
    max-width: 540px;
    margin: 0 auto 24px;
  }
  .cta-links {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero { padding-top: 72px; padding-bottom: 40px; }
    .hero-headline { font-size: 26px; }
    .hero-stats { gap: 12px; }
    .dual-grid { gap: 16px; }
    .cta-links { flex-direction: column; align-items: center; }
  }
</style>
