---
import Layout from '../layouts/Layout.astro';
---
<Layout title="User Journey" description="Komiks: jak EDPA funguje v praxi — 8 panel&uring; ukazuje cestu od chaotických timesheetů k automatickým výkazům.">

<section class="section comic-page">
  <div class="container">
    <div class="page-header" style="text-align:center; margin-bottom:48px;">
      <div class="tag">User Journey</div>
      <h1 style="font-size:2rem; margin-bottom:8px;">Jak EDPA zachr&aacute;nila t&yacute;m</h1>
      <p style="color:var(--t2); max-width:540px; margin:0 auto;">P&#345;&iacute;b&#283;h jednoho t&yacute;mu v osmi panelech.</p>
    </div>

    <div class="comic-grid">

      <!-- ════════════════ PANEL 1 ════════════════ -->
      <article class="panel panel--cyan">
        <div class="panel__header">
          <span class="panel__number">1</span>
          <span class="panel__title">Pond&#283;l&iacute; r&aacute;no</span>
        </div>
        <div class="panel__body">
          <div class="bubble bubble--cyan">
            <span class="bubble__who"><span class="char-icon">&#x1F4CB;</span> Marie <span class="char-role">(PM)</span></span>
            <p>&bdquo;Kdo vyplnil timesheets za minul&yacute; t&yacute;den?&ldquo;</p>
          </div>
          <div class="bubble bubble--green">
            <span class="bubble__who"><span class="char-icon">&#x1F4BB;</span> Petr <span class="char-role">(Dev)</span></span>
            <p>&bdquo;J&aacute; zapomn&#283;l&hellip; asi 4h na S-200?&ldquo;</p>
          </div>
          <div class="bubble bubble--orange">
            <span class="bubble__who"><span class="char-icon">&#x1F4CA;</span> Jan <span class="char-role">(BO)</span></span>
            <p>&bdquo;J&aacute; nev&iacute;m co napsat, cel&yacute; den jsem pl&aacute;noval.&ldquo;</p>
          </div>
          <div class="panel__caption">Ka&#382;d&yacute; t&yacute;den stejn&yacute; p&#345;&iacute;b&#283;h.</div>
        </div>
      </article>

      <!-- ════════════════ PANEL 2 ════════════════ -->
      <article class="panel panel--indigo">
        <div class="panel__header">
          <span class="panel__number">2</span>
          <span class="panel__title">EDPA p&#345;ich&aacute;z&iacute;</span>
        </div>
        <div class="panel__body">
          <div class="bubble bubble--indigo">
            <span class="bubble__who"><span class="char-icon">&#x1F916;</span> EDPA Bot</span>
            <p>&bdquo;Co kdybych to ud&#283;lal za v&aacute;s?&ldquo;</p>
          </div>
          <div class="bubble bubble--cyan">
            <span class="bubble__who"><span class="char-icon">&#x1F4CB;</span> Marie <span class="char-role">(PM)</span></span>
            <p>&bdquo;Jak?&ldquo;</p>
          </div>
          <div class="bubble bubble--indigo">
            <span class="bubble__who"><span class="char-icon">&#x1F916;</span> EDPA Bot</span>
            <p>&bdquo;Sleduju Git. Kdo commitne, reviewuje, komentuje = pracuje.&ldquo;</p>
          </div>
        </div>
      </article>

      <!-- ════════════════ PANEL 3 ════════════════ -->
      <article class="panel panel--green">
        <div class="panel__header">
          <span class="panel__number">3</span>
          <span class="panel__title">T&yacute;m pracuje norm&aacute;ln&#283;</span>
        </div>
        <div class="panel__body">
          <div class="action-row">
            <span class="char-icon">&#x1F4BB;</span>
            <span class="action-who">Petr</span>
            <span class="action-does">commituje</span>
            <code>feat(S-200): implement OMOP parser</code>
          </div>
          <div class="action-row">
            <span class="char-icon">&#x1F3D7;&#xFE0F;</span>
            <span class="action-who">Jaroslav</span>
            <span class="action-does">reviewuje PR</span>
            <span class="action-badge action-badge--green">&#x2713; Approved</span>
          </div>
          <div class="action-row">
            <span class="char-icon">&#x2705;</span>
            <span class="action-who">Kate&#345;ina</span>
            <span class="action-does">pushuje testy</span>
            <span class="action-badge action-badge--yellow">14 pass</span>
          </div>
          <div class="panel__caption">&#381;&aacute;dn&eacute; timesheets. Jen pr&aacute;ce.</div>
        </div>
      </article>

      <!-- ════════════════ PANEL 4 ════════════════ -->
      <article class="panel panel--indigo">
        <div class="panel__header">
          <span class="panel__number">4</span>
          <span class="panel__title">Konec iterace</span>
        </div>
        <div class="panel__body">
          <div class="bubble bubble--cyan">
            <span class="bubble__who"><span class="char-icon">&#x1F4CB;</span> Marie <span class="char-role">(PM)</span></span>
            <div class="code-block">python scripts/edpa_engine.py \<br/>  --iteration PI-2026-1.1</div>
          </div>
          <div class="bubble bubble--indigo">
            <span class="bubble__who"><span class="char-icon">&#x1F916;</span> EDPA Bot</span>
            <p>&bdquo;Hotovo. 7 v&yacute;kaz&#367; vygenerov&aacute;no.&ldquo;</p>
            <div class="result-badge">440h = 440h &#x2713;</div>
          </div>
        </div>
      </article>

      <!-- ════════════════ PANEL 5 ════════════════ -->
      <article class="panel panel--green">
        <div class="panel__header">
          <span class="panel__number">5</span>
          <span class="panel__title">V&yacute;kaz Petra</span>
        </div>
        <div class="panel__body">
          <table class="mini-table">
            <thead><tr><th>Item</th><th>Popis</th><th>Hodiny</th></tr></thead>
            <tbody>
              <tr><td>S-200</td><td>OMOP parser</td><td class="num">26.7h</td></tr>
              <tr><td>S-201</td><td>Unit testy</td><td class="num">16.0h</td></tr>
              <tr><td>S-205</td><td>CI pipeline fix</td><td class="num">8.3h</td></tr>
              <tr><td>S-210</td><td>Code review</td><td class="num">9.0h</td></tr>
              <tr class="total"><td colspan="2">Celkem</td><td class="num">60.0h</td></tr>
            </tbody>
          </table>
          <div class="bubble bubble--green" style="margin-top:12px;">
            <span class="bubble__who"><span class="char-icon">&#x1F4BB;</span> Petr <span class="char-role">(Dev)</span></span>
            <p>&bdquo;To je p&#345;esn&#283; to co jsem d&#283;lal! Nic jsem nevypl&#328;oval!&ldquo;</p>
          </div>
        </div>
      </article>

      <!-- ════════════════ PANEL 6 ════════════════ -->
      <article class="panel panel--orange">
        <div class="panel__header">
          <span class="panel__number">6</span>
          <span class="panel__title">V&yacute;kaz Jana (BO)</span>
        </div>
        <div class="panel__body">
          <div class="bubble bubble--orange">
            <span class="bubble__who"><span class="char-icon">&#x1F4CA;</span> Jan <span class="char-role">(BO)</span></span>
            <p>&bdquo;Ale j&aacute; jsem jen komentoval issues&hellip;&ldquo;</p>
          </div>
          <div class="bubble bubble--indigo">
            <span class="bubble__who"><span class="char-icon">&#x1F916;</span> EDPA Bot</span>
            <p>&bdquo;Va&#353;e koment&aacute;&#345;e = strategick&aacute; rozhodnut&iacute;. CW&nbsp;=&nbsp;0.30.&ldquo;</p>
          </div>
          <table class="mini-table">
            <thead><tr><th>Item</th><th>Popis</th><th>Hodiny</th></tr></thead>
            <tbody>
              <tr><td>E-10</td><td>Epic &mdash; strategick&eacute; &#345;&iacute;zen&iacute;</td><td class="num">24.0h</td></tr>
              <tr><td>E-12</td><td>Epic &mdash; roadmap review</td><td class="num">16.0h</td></tr>
              <tr class="total"><td colspan="2">Celkem</td><td class="num">40.0h</td></tr>
            </tbody>
          </table>
          <div class="bubble bubble--orange" style="margin-top:12px;">
            <span class="bubble__who"><span class="char-icon">&#x1F4CA;</span> Jan</span>
            <p>&bdquo;To odpov&iacute;d&aacute;!&ldquo;</p>
          </div>
        </div>
      </article>

      <!-- ════════════════ PANEL 7 ════════════════ -->
      <article class="panel panel--purple">
        <div class="panel__header">
          <span class="panel__number">7</span>
          <span class="panel__title">Retrospektiva</span>
        </div>
        <div class="panel__body">
          <div class="bubble bubble--cyan">
            <span class="bubble__who"><span class="char-icon">&#x1F4CB;</span> Marie <span class="char-role">(PM)</span></span>
            <p>&bdquo;EDPA &#345;&iacute;k&aacute; Arch 13h na S-200. Souhlas&iacute;te?&ldquo;</p>
          </div>
          <div class="bubble bubble--purple">
            <span class="bubble__who"><span class="char-icon">&#x1F3D7;&#xFE0F;</span> Jaroslav <span class="char-role">(Arch)</span></span>
            <p>&bdquo;Sp&iacute;&#353; 17h, d&#283;lal jsem i architektonick&yacute; n&aacute;vrh.&ldquo;</p>
          </div>
          <div class="bubble bubble--indigo">
            <span class="bubble__who"><span class="char-icon">&#x1F916;</span> EDPA Bot</span>
            <p class="bot-action">*zapisuje*</p>
            <div class="calibration-box">
              Kalibrace: Arch reviewer<br/>
              <span class="cal-old">0.25</span> <span class="cal-arrow">&rarr;</span> <span class="cal-new">0.30</span>
            </div>
          </div>
        </div>
      </article>

      <!-- ════════════════ PANEL 8 ════════════════ -->
      <article class="panel panel--gradient">
        <div class="panel__header">
          <span class="panel__number">8</span>
          <span class="panel__title">O 3 m&#283;s&iacute;ce pozd&#283;ji</span>
        </div>
        <div class="panel__body">
          <div class="team-happy">
            <span title="Marie (PM)">&#x1F4CB;</span>
            <span title="Petr (Dev)">&#x1F4BB;</span>
            <span title="Jaroslav (Arch)">&#x1F3D7;&#xFE0F;</span>
            <span title="Jan (BO)">&#x1F4CA;</span>
            <span title="Kate&#345;ina (QA)">&#x2705;</span>
            <span title="EDPA Bot">&#x1F916;</span>
          </div>
          <div class="bubble bubble--cyan">
            <span class="bubble__who"><span class="char-icon">&#x1F4CB;</span> Marie <span class="char-role">(PM)</span></span>
            <p>&bdquo;Predictability <strong>86%</strong>. V&yacute;kazy p&#345;esn&eacute;. Nula timesheet&#367;.&ldquo;</p>
          </div>
          <div class="bubble bubble--indigo">
            <span class="bubble__who"><span class="char-icon">&#x1F916;</span> EDPA Bot</span>
            <p>&bdquo;Princip: <em>Kdo p&#345;isp&iacute;v&aacute;, dostane hodiny.</em>&ldquo;</p>
          </div>
          <div class="panel__caption finale-caption">&#x1F389; Konec. &#381;&aacute;dn&eacute; timesheety nebyly zran&#283;ny.</div>
        </div>
      </article>

    </div><!-- /comic-grid -->
  </div>
</section>

</Layout>

<style>
  /* ── Comic grid ── */
  .comic-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  @media (max-width: 820px) {
    .comic-grid { grid-template-columns: 1fr; gap: 20px; }
  }

  /* ── Panel ── */
  .panel {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* colour accents */
  .panel--cyan   { border-top: 3px solid var(--cy); }
  .panel--green  { border-top: 3px solid var(--gn); }
  .panel--indigo { border-top: 3px solid var(--ac); }
  .panel--orange { border-top: 3px solid var(--or); }
  .panel--purple { border-top: 3px solid #a78bfa;   }
  .panel--gradient {
    border-top: 3px solid transparent;
    border-image: linear-gradient(90deg, var(--cy), var(--gn), var(--ac), var(--or), #a78bfa) 1;
  }

  .panel__header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px 10px;
    border-bottom: 1px solid var(--bd);
    background: var(--s2);
  }
  .panel__number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    width: 24px; height: 24px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: var(--ac);
    color: #fff;
    flex-shrink: 0;
  }
  .panel__title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: var(--t1);
    letter-spacing: 0.3px;
  }
  .panel__body {
    padding: 16px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  /* ── Speech bubbles ── */
  .bubble {
    position: relative;
    background: var(--s2);
    border-radius: 10px;
    padding: 10px 14px;
    border-left: 3px solid var(--bd);
  }
  .bubble--cyan   { border-left-color: var(--cy); }
  .bubble--green  { border-left-color: var(--gn); }
  .bubble--indigo { border-left-color: var(--ac); }
  .bubble--orange { border-left-color: var(--or); }
  .bubble--purple { border-left-color: #a78bfa;   }
  .bubble--yellow { border-left-color: var(--yl); }

  .bubble__who {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--t2);
  }
  .bubble--cyan   .bubble__who { color: var(--cy); }
  .bubble--green  .bubble__who { color: var(--gn); }
  .bubble--indigo .bubble__who { color: var(--ac2); }
  .bubble--orange .bubble__who { color: var(--or); }
  .bubble--purple .bubble__who { color: #a78bfa;   }
  .bubble--yellow .bubble__who { color: var(--yl); }

  .char-icon {
    margin-right: 4px;
  }
  .char-role {
    font-weight: 400;
    opacity: 0.65;
    font-size: 10px;
  }

  .bubble p {
    font-size: 14px;
    line-height: 1.55;
    color: var(--t1);
  }

  /* ── Code blocks inside bubbles ── */
  .code-block {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    background: var(--bg);
    border: 1px solid var(--bd);
    border-radius: 6px;
    padding: 10px 12px;
    color: var(--gn);
    margin-top: 6px;
    line-height: 1.6;
    overflow-x: auto;
  }

  /* ── Action rows (panel 3) ── */
  .action-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--s2);
    border-radius: 8px;
    flex-wrap: wrap;
  }
  .action-who {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--t1);
    min-width: 70px;
  }
  .action-does {
    font-size: 13px;
    color: var(--t2);
    font-style: italic;
  }
  .action-row code {
    font-size: 11px;
    margin-left: auto;
  }
  .action-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    margin-left: auto;
  }
  .action-badge--green {
    background: rgba(52, 211, 153, 0.15);
    color: var(--gn);
  }
  .action-badge--yellow {
    background: rgba(251, 191, 36, 0.15);
    color: var(--yl);
  }

  /* ── Result badge (panel 4) ── */
  .result-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    margin-top: 8px;
    padding: 6px 14px;
    border-radius: 6px;
    background: rgba(52, 211, 153, 0.12);
    color: var(--gn);
    border: 1px solid rgba(52, 211, 153, 0.25);
  }

  /* ── Mini tables ── */
  .mini-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
  }
  .mini-table th {
    text-align: left;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--t3);
    padding: 6px 8px;
    border-bottom: 1px solid var(--bd);
  }
  .mini-table td {
    padding: 5px 8px;
    border-bottom: 1px solid rgba(42, 48, 80, 0.5);
    color: var(--t2);
  }
  .mini-table .num {
    text-align: right;
    color: var(--t1);
    font-weight: 600;
  }
  .mini-table .total td {
    border-top: 1px solid var(--bd);
    border-bottom: none;
    font-weight: 700;
    color: var(--t1);
    padding-top: 8px;
  }

  /* ── Calibration box (panel 7) ── */
  .bot-action {
    font-style: italic;
    color: var(--t3) !important;
    font-size: 13px !important;
  }
  .calibration-box {
    margin-top: 8px;
    padding: 10px 14px;
    background: var(--bg);
    border: 1px solid var(--bd);
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--t2);
    line-height: 1.7;
  }
  .cal-old {
    color: var(--rd);
    text-decoration: line-through;
  }
  .cal-arrow {
    color: var(--t3);
    margin: 0 4px;
  }
  .cal-new {
    color: var(--gn);
    font-weight: 700;
  }

  /* ── Team happy (panel 8) ── */
  .team-happy {
    display: flex;
    justify-content: center;
    gap: 16px;
    font-size: 28px;
    padding: 14px 0 8px;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-4px); }
  }

  /* ── Caption ── */
  .panel__caption {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-align: center;
    color: var(--t3);
    font-style: italic;
    padding-top: 8px;
    margin-top: auto;
    border-top: 1px dashed var(--bd);
  }
  .finale-caption {
    font-size: 13px;
    color: var(--yl);
    font-style: normal;
    font-weight: 600;
  }
</style>
