          <tr><td>3</td><td><strong>Iteration Close</strong></td><td>Manual dispatch</td><td>Snapshot + reports (MD/JSON/XLSX) + per-item</td></tr>
          <tr><td>4</td><td><strong>PI Close</strong></td><td>Manual dispatch</td><td>Iteration aggregation</td></tr>
          <tr><td>5</td><td><strong>Velocity Tracker</strong></td><td>Iter/PI close</td><td>Velocity JSON + dashboard</td></tr>
