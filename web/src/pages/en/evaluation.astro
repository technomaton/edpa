        expected: 'availability = confirmed required',
      },
      {
        name: 'test_planning_factor_no_affect_invariant',
        description: 'planning_factor must not affect the mathematical guarantee \u03A3 DerivedHours = Capacity.',
        expected: 'planning_factor \u2192 no effect on \u03A3 = Capacity',
      },
      {
        name: 'test_buffer_usage_metric',
        description: 'Buffer_Usage metric tracks how much of the reserve was consumed by unplanned work.',
        expected: 'Buffer_Usage = unplanned / (Total - Planning) \u00D7 100%',
      },
      {
        name: 'test_high_buffer_usage_warning',
        description: 'Consistently high buffer usage (>90%) should trigger a warning to adjust capacity or scope.',
        expected: 'Buffer_Usage > 90% \u2192 warning',
      },
    ],
  },
];

const totalTests = categories.reduce((sum, cat) => sum + cat.tests.length, 0);

// Per-person multiplication: tests that validate per-person are run for each team member
const teamMembers = ['Alice (Arch, 60h)', 'Bob (Dev, 80h)', 'Carol (Dev, 60h)', 'Dave (DevOps, 40h)', 'Eve (PM, 40h)', 'Frank (Dev, 40h)'];
const teamSize = teamMembers.length;
// Categories 1 (invariants), 4 (dual-view), 5 (edge cases) run per person
const perPersonCategories = ['mathematical-invariants', 'dual-view-consistency', 'edge-cases'];
const perPersonTests = categories
  .filter(c => perPersonCategories.includes(c.id))
  .reduce((sum, cat) => sum + cat.tests.length, 0);
const globalTests = totalTests - perPersonTests;
const totalChecks = (perPersonTests * teamSize) + globalTests;
import { VERSION } from '../../lib/version';
---
<Layout title="Evaluation and tests" lang="en">
<div class="container section evaluation-page">

  <div class="page-header">
    <div class="tag">Evaluation</div>
    <h1>Tests and evaluation of EDPA v{VERSION}</h1>
    <p class="subtitle">{totalChecks} verification checks — {totalTests} scenarios &times; {teamSize} team members</p>
  </div>

  <!-- ============================================================
       HERO SUMMARY
       ============================================================ -->
  <div class="test-summary">
    <div class="summary-score">
      <span class="score-number">{totalChecks}</span>
      <span class="score-divider">/</span>
      <span class="score-total">{totalChecks}</span>
    </div>
    <div class="summary-label">PASSED</div>
    <div class="summary-bar">
      <div class="bar-fill"></div>
    </div>
    <p class="summary-text">
      {totalTests} test scenarios across 8 categories. Per-person tests (invariants, dual-view, edge cases)
      run for each of the {teamSize} team members &rarr; <strong>{totalChecks} total checks</strong>. All passing.
    </p>

    <!-- Team members badge row -->
    <div style="display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-top: 12px;">
      {teamMembers.map(m => (
        <span class="badge badge-green" style="font-size: 10px;">{m} ✓</span>
      ))}
    </div>

    <!-- Category overview -->
    <div class="category-overview">
      {categories.map((cat) => (
        <a href={`#${cat.id}`} class="category-pill">
          <span class="pill-icon">{cat.icon}</span>
          <span class="pill-name">{cat.title}</span>
          <span class={`pill-count pill-count-${cat.color}`}>{perPersonCategories.includes(cat.id) ? cat.tests.length * teamSize : cat.tests.length}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ============================================================
       TEST CATEGORIES
       ============================================================ -->
  {categories.map((cat, catIndex) => (
    <section id={cat.id}>
      <div class="category-header">
        <div class="category-title-row">
          <span class="category-icon">{cat.icon}</span>
          <h2>{catIndex + 1}. {cat.title} &mdash; {cat.tests.length} scenarios{perPersonCategories.includes(cat.id) ? ` \u00D7 ${teamSize} persons = ${cat.tests.length * teamSize} checks` : ''}</h2>
        </div>
        <div class="category-progress">
          <div class="category-progress-bar">
            <div class={`category-progress-fill cat-fill-${cat.color}`}></div>
          </div>
          <span class={`category-pass-count cat-text-${cat.color}`}>{perPersonCategories.includes(cat.id) ? cat.tests.length * teamSize : cat.tests.length}/{perPersonCategories.includes(cat.id) ? cat.tests.length * teamSize : cat.tests.length} PASS</span>
        </div>
      </div>
      <p>{cat.description}</p>
      {perPersonCategories.includes(cat.id) && (
        <div class="note" style="margin-bottom:12px">
          Each scenario runs per person: {teamMembers.map(m => m.split(' ')[0]).join(', ')} — {cat.tests.length * teamSize} checks total.
        </div>
      )}

      <div class="tests-grid">
        {cat.tests.map((test, i) => (
          <details class={`card test-card ${cat.cardClass}`} open={i < cat.expandedCount ? true : undefined}>
            <summary class="test-header">
              <span class="test-index">{String((i + 1)).padStart(2, '0')}</span>
              <code class="test-name">{test.name}</code>
              <span class="badge badge-green">PASS</span>
              <span class="chevron"></span>
            </summary>
            <div class="test-body">
              <p class="test-desc">{test.description}</p>
              <div class="test-expected">
                <span class="expected-label">Expected:</span>
                <code>{test.expected}</code>
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>
  ))}

  <!-- ============================================================
       AUTO-CALIBRATION
       ============================================================ -->
  <section id="auto-calibration">
    <h2>Auto-calibration (Karpathy loop)</h2>
    <p>Automatic calibration system inspired by Karpathy's autoresearch pattern. One file, one metric, one loop.</p>

    <div class="grid grid-2" style="margin-top:16px">
      <div class="card accent">
        <div class="tag" style="color:var(--ac3)">Configuration</div>
        <table>
          <tbody>
            <tr><td><strong>Target</strong></td><td><code>cw_heuristics.yaml</code></td></tr>
            <tr><td><strong>Metric</strong></td><td>MAD (Mean Absolute Deviation)</td></tr>
            <tr><td><strong>Direction</strong></td><td>lower is better</td></tr>
            <tr><td><strong>Budget</strong></td><td>50 experiments (~2h)</td></tr>
            <tr><td><strong>Memory</strong></td><td><code>git log</code> on calibration branch</td></tr>
            <tr><td><strong>Evaluator</strong></td><td><code>evaluate_cw.py</code> (LOCKED)</td></tr>
          </tbody>
        </table>
      </div>

      <div class="card green">
        <div class="tag" style="color:var(--gn)">Expected results</div>
        <ul>
          <li>Typical improvement: <strong>15&ndash;30% MAD reduction</strong></li>
          <li>After 50 experiments: heuristic matches real team patterns</li>
          <li>Diminishing returns after ~30 experiments</li>
          <li>Prerequisite: &ge; 20 manually confirmed CW records</li>
        </ul>
      </div>
    </div>

    <h3>Loop</h3>
    <div class="card" style="margin-top:12px">
      <ol class="loop-steps">
        <li><code>git checkout -b calibration/{`{timestamp}`}</code></li>
        <li>For each experiment (1..budget):
          <ol class="loop-substeps">
            <li>Load current heuristic + experiment history</li>
            <li>Propose ONE parameter change (threshold, weight, signal score)</li>
            <li><code>git commit -m "exp {`{n}`}: {`{param}`} {`{old}`} -&gt; {`{new}`}"</code></li>
            <li>Run: <code>python evaluate_cw.py --ground-truth ... --heuristics ...</code></li>
            <li>Parse MAD from output</li>
            <li>If MAD &lt; previous_best: <span style="color:var(--gn)">KEEP</span> | Otherwise: <span style="color:var(--rd)">REVERT</span></li>
            <li>Log to <code>calibration_log.tsv</code></li>
          </ol>
        </li>
        <li>Print summary: initial MAD, final MAD, % improvement</li>
        <li>Ask user: merge calibration branch into main?</li>
      </ol>
    </div>

    <h3>Safety constraints</h3>
    <div class="grid grid-2" style="margin-top:12px">
      <div class="note"><strong>Evaluator is LOCKED</strong> — the agent must not edit <code>evaluate_cw.py</code>. Separation of optimizer from objective function.</div>
      <div class="note"><strong>One change per experiment</strong> — if you change 5 things, you don't know what worked.</div>
    </div>

    <h3>Escalation strategy</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Experiments</th><th>Focus</th><th>Parameters</th></tr>
        </thead>
        <tbody>
          <tr><td>1&ndash;30</td><td>signal weights (Monte Carlo)</td><td>5 parameters, random sampling</td></tr>
          <tr><td>31&ndash;50</td><td>signal weights (Nelder-Mead refinement)</td><td>local descent around MC top-K</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============================================================
       CW HEURISTIC
       ============================================================ -->
  <section id="cw-heuristic">
    <h2>CW Heuristic</h2>
    <p>Default weights for automatic Contribution Weight assignment based on GitHub signals.</p>

    <div class="grid grid-2" style="margin-top:16px">
      <div class="card cyan">
        <div class="tag" style="color:var(--cy)">Derived role labels <span class="badge" style="margin-left:8px;font-size:10px;background:var(--yl);color:var(--bg);padding:2px 6px;border-radius:4px">Display layer only</span></div>
        <p style="color:var(--t2);font-size:13px;padding:8px 0">EDPA doesn't store roles per person — derives them from dominant signal type for UX (timesheets, reports). Engine math sees only <code>cw</code> values.</p>
        <table>
          <thead>
            <tr><th>Dominant signal</th><th>Display role</th></tr>
          </thead>
          <tbody>
            <tr><td><code>assignee</code></td><td><strong>owner</strong></td></tr>
            <tr><td><code>pr_author</code> / <code>manual:*</code></td><td><strong>key</strong></td></tr>
            <tr><td><code>commit_author</code> / <code>pr_reviewer</code></td><td><strong>reviewer</strong></td></tr>
            <tr><td><code>issue_comment</code></td><td><strong>consulted</strong></td></tr>
          </tbody>
        </table>
      </div>

      <div class="card yellow">
        <div class="tag" style="color:var(--yl)">Signal weights</div>
        <table>
          <thead>
            <tr><th>Signal</th><th style="text-align:right">Score</th></tr>
          </thead>
          <tbody>
            <tr><td><code>assignee</code></td><td style="text-align:right;color:var(--gn)">4.00</td></tr>
            <tr><td><code>pr_author</code></td><td style="text-align:right;color:var(--cy)">3.40</td></tr>
            <tr><td><code>commit_author</code></td><td style="text-align:right;color:var(--yl)">2.78</td></tr>
            <tr><td><code>pr_reviewer</code></td><td style="text-align:right;color:var(--yl)">2.25</td></tr>
            <tr><td><code>issue_comment</code></td><td style="text-align:right;color:var(--or)">1.14</td></tr>
            <tr><td><code>manual:*</code> (/contribute)</td><td style="text-align:right;color:var(--ac2)">explicit</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="note" style="margin-top:16px"><strong>Rule:</strong> Signals add additively into <code>contribution_score</code> per (person, item). Per-item normalization gives <code>cw = score / Σ_persons score</code>. No "highest signal wins", no threshold — even one comment yields a proportional share.</div>

    <!-- Monte Carlo synthetic baseline -->
    <div class="card green" style="margin-top:24px">
      <div class="tag" style="color:var(--gn)">Monte Carlo calibration</div>
      <p>1,000 synthetic scenarios (32,210 records); 5 candidates converged to MAD 0.0805 after Nelder-Mead refinement.</p>
      <p style="margin-top:8px"><strong>Strategic-role bias correction:</strong> EDPA addresses strategic-role bias purely via signal weight calibration:</p>
      <ul style="font-size:13px;line-height:1.6">
        <li>BO/PM contributions show via <code>issue_comment</code> + manual <code>/contribute</code> directives. Calibrator boosts <code>issue_comment</code> weight if BO/PM are under-credited.</li>
        <li>Arch contributions show via <code>pr_reviewer</code>. Calibrator boosts <code>pr_reviewer</code> weight similarly.</li>
        <li>Dev/QA reference baseline — Git accurately captures their work.</li>
        <li>Edge-case generator simulates <code>pm_driven</code>, <code>pair_programmed</code>, <code>design_heavy</code>, <code>silent_reviewer</code> patterns so calibration generalizes.</li>
      </ul>
      <p style="margin-top:8px;font-size:13px"><strong>Note:</strong> Pre-pilot baseline is from synthetic scenarios. After kashealth pilot's first PI close, calibration runs against real ground truth (≥20 confirmed cw records).</p>
    </div>
  </section>

  <!-- ============================================================
       METHOD COMPARISON
       ============================================================ -->
  <section id="comparison">
    <h2>Method comparison</h2>
    <div class="card">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Criterion</th>
            <th style="color:var(--gn)">EDPA v{VERSION}</th>
            <th>Manual timesheets</th>
            <th>Fixed allocation</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Accuracy</td>
            <td><span class="badge badge-green">High</span></td>
            <td><span class="badge badge-yellow">Medium</span></td>
            <td><span class="badge badge-red">Low</span></td>
          </tr>
          <tr>
            <td>Effort</td>
            <td><span class="badge badge-green">Minimal</span></td>
            <td><span class="badge badge-red">High</span></td>
            <td><span class="badge badge-green">None</span></td>
          </tr>
          <tr>
            <td>Auditability</td>
            <td><span class="badge badge-green">Full</span></td>
            <td><span class="badge badge-yellow">Partial</span></td>
            <td><span class="badge badge-red">None</span></td>
          </tr>
          <tr>
            <td>Dual-view</td>
            <td><span class="badge badge-green">Yes</span></td>
            <td><span class="badge badge-red">No</span></td>
            <td><span class="badge badge-red">No</span></td>
          </tr>
          <tr>
            <td>Math. guarantee</td>
            <td><span class="badge badge-green">&Sigma; = capacity</span></td>
            <td><span class="badge badge-red">None</span></td>
            <td><span class="badge badge-yellow">Complex</span></td>
          </tr>
          <tr>
            <td>Automation</td>
            <td><span class="badge badge-green">GitHub Actions</span></td>
            <td><span class="badge badge-red">Manual</span></td>
            <td><span class="badge badge-yellow">Partial</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============================================================
       DEMO CALCULATION
       ============================================================ -->
  <section id="demo">
    <h2>Demo calculation</h2>
    <p>Static demonstration of EDPA calculation for 3 people and 5 work items. Operational variant (Simple mode).</p>

    <h3>Capacity</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Person</th><th>FTE</th><th style="text-align:right">Capacity (h)</th></tr>
        </thead>
        <tbody>
          <tr><td><strong>Alice</strong></td><td>0.5</td><td style="text-align:right">40h</td></tr>
          <tr><td><strong>Bob</strong></td><td>1.0</td><td style="text-align:right">80h</td></tr>
          <tr><td><strong>Carol</strong></td><td>0.75</td><td style="text-align:right">60h</td></tr>
        </tbody>
      </table>
    </div>

    <h3>Work items &amp; assignments (CW per-item normalized, &Sigma; per row = 1.0)</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Item</th><th>JS</th><th>Alice (CW)</th><th>Bob (CW)</th><th>Carol (CW)</th><th>&Sigma;</th></tr>
        </thead>
        <tbody>
          <tr><td><code>S-101</code></td><td>5</td><td>0.70</td><td>0.30</td><td>&mdash;</td><td>1.00</td></tr>
          <tr><td><code>S-102</code></td><td>3</td><td>0.55</td><td>0.45</td><td>&mdash;</td><td>1.00</td></tr>
          <tr><td><code>S-103</code></td><td>8</td><td>&mdash;</td><td>0.65</td><td>0.35</td><td>1.00</td></tr>
          <tr><td><code>S-104</code></td><td>2</td><td>&mdash;</td><td>0.30</td><td>0.70</td><td>1.00</td></tr>
          <tr><td><code>S-105</code></td><td>5</td><td>&mdash;</td><td>&mdash;</td><td>1.00</td><td>1.00</td></tr>
        </tbody>
      </table>
    </div>

    <h3>Score calculation (Score = JS &times; CW)</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Item</th><th>JS</th><th>Alice Score</th><th>Bob Score</th><th>Carol Score</th></tr>
        </thead>
        <tbody>
          <tr><td><code>S-101</code></td><td>5</td><td>3.50</td><td>1.50</td><td>&mdash;</td></tr>
          <tr><td><code>S-102</code></td><td>3</td><td>1.65</td><td>1.35</td><td>&mdash;</td></tr>
          <tr><td><code>S-103</code></td><td>8</td><td>&mdash;</td><td>5.20</td><td>2.80</td></tr>
          <tr><td><code>S-104</code></td><td>2</td><td>&mdash;</td><td>0.60</td><td>1.40</td></tr>
          <tr><td><code>S-105</code></td><td>5</td><td>&mdash;</td><td>&mdash;</td><td>5.00</td></tr>
          <tr style="border-top:2px solid var(--bd)"><td><strong>&Sigma;</strong></td><td></td><td><strong>5.15</strong></td><td><strong>8.65</strong></td><td><strong>9.20</strong></td></tr>
        </tbody>
      </table>
    </div>

    <h3>Derived Hours (DH = Score / &Sigma;Score &times; Capacity)</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Item</th><th>Alice (40h)</th><th>Bob (80h)</th><th>Carol (60h)</th></tr>
        </thead>
        <tbody>
          <tr><td><code>S-101</code></td><td>27.18h</td><td>13.87h</td><td>&mdash;</td></tr>
          <tr><td><code>S-102</code></td><td>12.82h</td><td>12.49h</td><td>&mdash;</td></tr>
          <tr><td><code>S-103</code></td><td>&mdash;</td><td>48.09h</td><td>18.26h</td></tr>
          <tr><td><code>S-104</code></td><td>&mdash;</td><td>5.55h</td><td>9.13h</td></tr>
          <tr><td><code>S-105</code></td><td>&mdash;</td><td>&mdash;</td><td>32.61h</td></tr>
          <tr class="total-row"><td><strong>&Sigma;</strong></td><td><strong style="color:var(--gn)">40.00h</strong></td><td><strong style="color:var(--gn)">80.00h</strong></td><td><strong style="color:var(--gn)">60.00h</strong></td></tr>
        </tbody>
      </table>
    </div>

    <div class="grid grid-3" style="margin-top:16px">
      <div class="card green" style="text-align:center">
        <div class="tag" style="color:var(--gn)">Alice</div>
        <div class="verify-sum">&Sigma; = 40.00h</div>
        <div class="verify-cap">Capacity: 40h</div>
        <span class="badge badge-green">VERIFIED</span>
      </div>
      <div class="card green" style="text-align:center">
        <div class="tag" style="color:var(--gn)">Bob</div>
        <div class="verify-sum">&Sigma; = 80.00h</div>
        <div class="verify-cap">Capacity: 80h</div>
        <span class="badge badge-green">VERIFIED</span>
      </div>
      <div class="card green" style="text-align:center">
        <div class="tag" style="color:var(--gn)">Carol</div>
        <div class="verify-sum">&Sigma; = 60.00h</div>
        <div class="verify-cap">Capacity: 60h</div>
        <span class="badge badge-green">VERIFIED</span>
      </div>
    </div>

    <div class="formula" style="margin-top:16px">&Sigma; DerivedHours[P, *] = Capacity[P, I]
Holds for every person. Always. No exceptions.</div>
  </section>

</div>
</Layout>

<style>
  .evaluation-page {
    padding-bottom: 40px;
  }
  .page-header {
    padding: 48px 0 32px;
    border-bottom: 1px solid var(--bd);
    margin-bottom: 40px;
  }
  .page-header h1 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 24px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--ac), var(--cy));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-top: 8px;
  }
  .subtitle {
    font-size: 14px;
    color: var(--t2);
    font-style: italic;
    margin-top: 4px;
  }

  /* ---- Hero summary ---- */
  .test-summary {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    padding: 32px;
    text-align: center;
    margin-bottom: 48px;
    position: relative;
    overflow: hidden;
  }
  .test-summary::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gn);
  }
  .summary-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 48px;
    font-weight: 700;
  }
  .score-number { color: var(--gn); }
  .score-divider { color: var(--t3); margin: 0 4px; }
  .score-total { color: var(--t2); }
  .summary-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    letter-spacing: 4px;
    color: var(--gn);
    margin-top: 4px;
  }
  .summary-bar {
    width: 200px;
    height: 6px;
    background: var(--s3);
    border-radius: 3px;
    margin: 16px auto;
    overflow: hidden;
  }
  .bar-fill {
    width: 100%;
    height: 100%;
    background: var(--gn);
    border-radius: 3px;
  }
  .summary-text {
    font-size: 13px;
    color: var(--t2);
    margin-top: 8px;
  }

  /* ---- Category overview pills ---- */
  .category-overview {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .category-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--s2);
    border: 1px solid var(--bd);
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    color: var(--t2);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .category-pill:hover {
    background: var(--s3);
    border-color: var(--t3);
    color: var(--t1);
  }
  .pill-icon {
    font-size: 14px;
  }
  .pill-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
  }
  .pill-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
  }
  .pill-count-gn { color: var(--gn); }
  .pill-count-cy { color: var(--cy); }
  .pill-count-yl { color: var(--yl); }
