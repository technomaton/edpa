---
import Layout from '../../layouts/Layout.astro';
import { VERSION } from '../../lib/version';
---
<Layout title="EDPA Playbook" lang="en" description="Complete guide for deploying EDPA — from empty repository to closing the first Planning Interval and calibrating heuristics.">
<div class="container section playbook-page">

  <div class="page-header">
    <div class="tag">Playbook</div>
    <h1>EDPA Playbook — From zero to first PI</h1>
    <p class="subtitle">Complete guide for deploying the EDPA methodology on a new project</p>
    <p class="meta">EDPA v{VERSION} &middot; March 2026</p>
  </div>

  <div class="methodology-layout">

  <aside class="sidebar-toc" id="sidebarToc">
    <div class="toc-title">Contents</div>
    <ol class="toc-list">
      <li><a href="#prerekvizity" class="toc-link" data-section="prerekvizity">Prerequisites</a></li>
      <li><a href="#faze-1" class="toc-link" data-section="faze-1">Phase 1: Infrastructure</a></li>
      <li><a href="#faze-2" class="toc-link" data-section="faze-2">Phase 2: First iteration</a></li>
      <li><a href="#faze-3" class="toc-link" data-section="faze-3">Phase 3: PI Close</a></li>
      <li><a href="#faze-4" class="toc-link" data-section="faze-4">Phase 4: Continuous operation</a></li>
      <li><a href="#checklist" class="toc-link" data-section="checklist">Checklist</a></li>
      <li><a href="#cli-reference" class="toc-link" data-section="cli-reference">CLI Reference</a></li>
      <li><a href="#architektura" class="toc-link" data-section="architektura">Architecture</a></li>
      <li><a href="#troubleshooting" class="toc-link" data-section="troubleshooting">Troubleshooting</a></li>
