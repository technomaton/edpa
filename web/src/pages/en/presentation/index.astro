---
import '../../../styles/global.css';
import '../../../styles/presentation.css';
import Header from '../../../components/Header.astro';

const title = 'EDPA Presentation — Generic';
const description = 'EDPA governance presentation — 20 slides covering methodology, evidence detection, dual-view and auto-calibration.';
import { VERSION } from '../../../lib/version';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | EDPA v{VERSION}</title>
</head>
<body class="presentation-body">
  <Header currentPath="/en/presentation/" />
  <div class="deck" id="deck"></div>
  <div class="pres-nav">
    <div class="nav-l"><a href="/en/" class="pres-exit" title="Back to website" style="color:var(--t3);text-decoration:none;margin-right:12px;font-family:'JetBrains Mono',monospace;font-size:12px;border:1px solid var(--bd);padding:4px 8px;border-radius:4px;">&larr; Web</a><span class="logo">EDPA v{VERSION}</span><span class="nav-label">&middot; Open Source Governance</span></div>
    <div class="nav-c" id="dots"></div>
    <div class="nav-r">
      <button class="pres-btn" id="btnPrev">&larr; Back</button>
      <span class="pg" id="pgN">1/20</span>
      <button class="pres-btn" id="btnNext">Next &rarr;</button>
    </div>
  </div>

<script>
import { initSlideDeck } from '../../../scripts/slide-engine';
import { VERSION } from '../../../lib/version';

const S=[

// 0: TITLE
`<div style="text-align:center;max-width:850px;margin:0 auto">
<div class="s-tag fade">Your project &middot; Evidence-driven governance for your team</div>
<div class="s-h1 fade d1" style="font-size:44px;background:linear-gradient(135deg,var(--ac2),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent">Complete governance solution</div>
<div class="fade d2" style="font-size:18px;color:var(--t2);margin:16px 0 6px">EDPA — Evidence-Driven Proportional Allocation</div>
<div class="fade d3" style="font-size:14px;color:var(--t3);font-style:italic;margin-bottom:24px">Capacity derivation from delivery evidence</div>
<div class="sg sg4 fade d4" style="max-width:700px;margin:0 auto">
<div class="sc a" style="text-align:center;padding:12px"><div class="sc-t">Dependencies</div><div style="font-size:12px;color:var(--ac2)">Just git locally</div></div>
<div class="sc c" style="text-align:center;padding:12px"><div class="sc-t">Methodology</div><div style="font-size:12px;color:var(--cy)">EDPA v${VERSION}</div></div>
<div class="sc g" style="text-align:center;padding:12px"><div class="sc-t">Skills</div><div style="font-size:12px;color:var(--gn)">4 composable</div></div>
<div class="sc y" style="text-align:center;padding:12px"><div class="sc-t">Local-first</div><div style="font-size:12px;color:var(--yl)"><code>.edpa/</code> in git</div></div>
</div>
<div class="fade d5" style="margin-top:20px;font-size:12px;color:var(--t3)">EDPA v${VERSION} — Open Source</div>
</div>`,

// 1: WHAT WE DELIVER
`<div class="s-tag fade">Presentation contents</div>
<div class="s-h1 fade d1">What we present today</div>
<div class="s-sub fade d2">Complete governance solution for the project — from methodology through evidence to automation. All local in git, no GitHub required.</div>
<div class="sg sg5 fade d3">
<div class="sc a" style="min-height:140px"><div class="sc-i">&#x1F4AC;</div><div class="sc-t">1. Dependencies</div><div class="sc-l">Just git locally<br>GitHub optional<br>0 PM/timesheet tool</div></div>
<div class="sc c" style="min-height:140px"><div class="sc-i">&#x1F511;</div><div class="sc-t">2. Identity</div><div class="sc-l">Your domain<br>Members + guests<br>Hybrid model</div></div>
<div class="sc g" style="min-height:140px"><div class="sc-i">&#x26A1;</div><div class="sc-t">3. EDPA</div><div class="sc-l">No timesheets<br>Dual-view CW<br>BankID audit</div></div>
<div class="sc y" style="min-height:140px"><div class="sc-i">&#x1F916;</div><div class="sc-t">4. AI Skills</div><div class="sc-l">4 composable<br>26+ platforms<br>Auto-calibration</div></div>
<div class="sc o" style="min-height:140px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">5. Local-first</div><div class="sc-l"><code>.edpa/</code> in git<br>Vendored engine<br>No GitHub Project</div></div>
</div>`,

// 2: PROBLEM
`<div class="s-tag fade">Context</div>
<div class="s-h1 fade d1">Why you need your own solution</div>
<div class="sg sg2 fade d2">
<div class="sc o"><div class="sc-i">&#x1F500;</div><div class="sc-l"><b>Multiple tenants</b><br>Multiple organizations = tenant switching, lost notifications, fragmented communication.</div></div>
<div class="sc o"><div class="sc-i">&#x1F512;</div><div class="sc-l"><b>IT dependency</b><br>Every permission change = IT department request. Weeks of waiting.</div></div>
<div class="sc o"><div class="sc-i">&#x1F4DD;</div><div class="sc-l"><b>Manual timesheets</b><br>Subjective, administratively demanding, unauditable, nobody likes them.</div></div>
<div class="sc o"><div class="sc-i">&#x1F504;</div><div class="sc-l"><b>Migration risk</b><br>During spin-off everything must be moved. The later, the more expensive.</div></div>
</div>
<div class="qt fade d3">Goal: Local-first governance in git from day 1. Tooling stays the team's choice, GitHub optional. Automated reporting. No future migration.</div>`,

// 3: TOOLING
`<div class="s-tag fade">Dependencies &amp; tooling</div>
<div class="s-h1 fade d1">EDPA needs only git &middot; tooling is the team's choice</div>
<div class="cols fade d2">
<div class="col">
<table>
<thead><tr><th>Tool</th><th>Role</th><th>Cost</th></tr></thead>
<tbody>
<tr style="background:rgba(16,185,129,.06)"><td><b>git (local)</b></td><td>EDPA governance</td><td style="color:var(--gn)"><b>$0 — required</b></td></tr>
<tr><td><b>M365 Business Basic</b></td><td>Comms (optional)</td><td>6 $/user/month</td></tr>
<tr><td><b>GitHub Team</b></td><td>Code hosting / PRs / CI (optional)</td><td>4 $/user/month</td></tr>
<tr><td><b>Custom domain</b></td><td>Registrar (optional)</td><td>~1 $/month</td></tr>
<tr style="background:rgba(99,102,241,.05)"><td><b>EDPA itself</b></td><td><b>Just git</b></td><td style="color:var(--gn)"><b>0 extra tooling</b></td></tr>
</tbody>
</table>
<div style="margin-top:8px;font-size:11px;color:var(--t3)">Collaboration tooling is optional — hundreds per month for the entire team</div>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px;padding:10px"><div class="sc-l"><b>Git (local) replaces:</b><br>Jira &#x2192; <code>.edpa/backlog/</code> (YAML in git)<br>Tempo / timesheets &#x2192; EDPA (derived hours)<br>Roadmaps &#x2192; <code>/edpa:board</code> (local HTML)<br>Automation &#x2192; git hooks locally<br><span style="opacity:.7">(+ optional <code>--with-ci</code> contribution-sync)</span></div></div>
<div class="s-note"><b>No separate PM/timesheet tooling.</b> Governance lives in git in <code>.edpa/</code> — no GitHub Project, Actions or custom fields required. GitHub is optional.</div>
</div></div>`,

// 4: IDENTITY
`<div class="s-tag fade">Identity</div>
<div class="s-h1 fade d1">Custom domain — hybrid model</div>
<div class="cols fade d2">
<div class="col">
<div class="sc o" style="margin-bottom:10px;padding:12px"><div style="font-size:12px"><b>&#x26A0;&#xFE0F; Key limitation:</b> Guests in Teams <b>cannot schedule meetings</b>. Hardcoded in Entra ID.</div></div>
<table>
<thead><tr><th>Account</th><th>Role</th><th>Type</th></tr></thead>
<tbody>
<tr style="background:rgba(99,102,241,.04)"><td><b>lead@yourdomain.com</b></td><td>Lead Architect</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>devops@yourdomain.com</b></td><td>DevSecOps</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>pm@yourdomain.com</b></td><td>Project Manager</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr><td>@partnera.com</td><td>Developer</td><td style="color:var(--yl)">Guest</td></tr>
<tr><td>@partnerb.com</td><td>Developer</td><td style="color:var(--yl)">Guest</td></tr>
</tbody>
</table>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px"><div class="sc-t">Layer 1 &middot; Full members</div><div class="sc-l">Core team &middot; M365 Basic &middot; Schedule meetings</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Layer 2 &middot; Shared channels</div><div class="sc-l">B2B Direct Connect &middot; No tenant switching</div></div>
<div class="sc y"><div class="sc-t">Layer 3 &middot; Guest fallback</div><div class="sc-l">If IT does not cooperate &middot; Functional, worse UX</div></div>
</div></div>`,

// 5: EDPA CORE
`<div class="s-tag fade">EDPA v${VERSION}</div>
<div class="s-h1 fade d1">Time is not measured — it is derived</div>
<div class="qt fade d2">A person declares capacity. The system identifies work items they contributed to. Capacity is proportionally split based on evidence.</div>
<div class="cols fade d3">
<div class="col">
<div class="fm">Score = JobSize x CW

DerivedHours = (Score / &#x2211;Scores) x Capacity

<b>Guarantee: &#x2211; DerivedHours = Capacity</b>
Always. No exceptions.</div>
<div class="s-p">Gated calculation: we credit Story <code>Done</code> + Feature/Epic/Initiative gate transitions from git history. CW is the per-item normalized share from evidence.</div>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-l"><b>Nobody logs hours.</b> The report is a byproduct of delivery.</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-l"><b>Evidence from git.</b> Commits (local) &#x2192; auto-detection. PRs/reviews/comments optionally via CI.</div></div>
<div class="sc a"><div class="sc-l"><b>BankID signature.</b> Frozen snapshot + BankID = legally stronger than paper.</div></div>
</div></div>`,

// 6: DUAL VIEW
`<div class="s-tag fade">Dual-View</div>
<div class="s-h1 fade d1">Two views, one dataset</div>
<div class="sg sg2 fade d2" style="margin-top:16px">
<div class="sc g" style="min-height:180px"><div class="sc-i">&#x1F464;</div><div class="sc-t">Per-Person</div>
<div style="font-size:14px;font-weight:600;color:var(--gn);margin-bottom:6px">How is a person's capacity distributed?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--gn);margin:6px 0">DerivedHours = (Score / &#x2211;Scores) x Capacity
Guarantee: &#x2211; = Capacity</div>
<div class="sc-l">&#x2192; <b>Report per person</b> for audit</div></div>
<div class="sc c" style="min-height:180px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">Per-Item</div>
<div style="font-size:14px;font-weight:600;color:var(--cy);margin-bottom:6px">How many people and hours did item X cost?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--cy);margin:6px 0">ItemShare = DerivedHours[P] / &#x2211; DerivedHours[*]
Guarantee: &#x2211; shares = 100%</div>
<div class="sc-l">&#x2192; <b>Cost card</b> per deliverable</div></div>
</div>
<div class="s-note fade d3">Both views from the same data (CW, JS, Capacity). No duplication, no conflict.</div>`,

// 7: THREE LAYERS
`<div class="s-tag fade">Architecture</div>
<div class="s-h1 fade d1">Three separate layers</div>
<div class="sg sg3 fade d2" style="margin-top:16px">
<div class="sc a" style="min-height:170px"><div class="sc-i">&#x2699;&#xFE0F;</div><div class="sc-t">Operational Metadata</div><div class="sc-v" style="color:var(--ac2);font-size:14px"><code>.edpa/backlog/</code> in git</div><div class="sc-l" style="margin-top:6px">Live delivery data &middot; Hierarchy &middot; Status &middot; Job Size &middot; WSJF</div></div>
<div class="sc c" style="min-height:170px"><div class="sc-i">&#x1F4CB;</div><div class="sc-t">Capacity Registry</div><div class="sc-v" style="color:var(--cy);font-size:14px"><code>.edpa/config/</code> in git</div><div class="sc-l" style="margin-top:6px">Capacity &middot; Roles &middot; FTE &middot; Confirmed at Iteration Planning</div></div>
<div class="sc g" style="min-height:170px"><div class="sc-i">&#x1F512;</div><div class="sc-t">Evidence &amp; Reporting</div><div class="sc-v" style="color:var(--gn);font-size:14px">/snapshots &middot; /reports &middot; /signed</div><div class="sc-l" style="margin-top:6px">Frozen snapshots &middot; Reports &middot; BankID &middot; Immutable</div></div>
</div>
<div class="fade d3" style="margin-top:12px;text-align:center;font-size:12px;color:var(--t3)"><code>.edpa/</code> in git is the <b>single source of truth</b> &#x2192; backlog, capacity, derived hours, signatures. No GitHub needed.</div>`,

// 8: HIERARCHY
`<div class="s-tag fade">Hierarchy</div>
<div class="s-h1 fade d1">SAFe-like hierarchy in <code>.edpa/backlog/</code></div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:13px;line-height:2;border-left-color:var(--ac)"><span style="color:var(--pk)">Initiative</span> (entire project)
  &#x2514;&#x2500;&#x2500; <span style="color:var(--ac2)">Epic</span> (strategic goal, 6-9 months)
       &#x2514;&#x2500;&#x2500; <span style="color:var(--cy)">Feature</span> (fits within a PI)
            &#x251C;&#x2500;&#x2500; <span style="color:var(--or)">Story</span> (delivered in an Iteration)
            &#x2502;    &#x2514;&#x2500;&#x2500; <span style="color:var(--yl)">Task</span> (technical work)
            &#x2514;&#x2500;&#x2500; <span style="color:var(--rd)">Defect</span> (fix, at the Story level)</div>
<div class="s-p"><b>WSJF = (<span style="color:var(--gn)">BV</span> + <span style="color:var(--or)">TC</span> + <span style="color:var(--cy)">RR&amp;OE</span>) / <span style="color:var(--yl)">JS</span></b> — independent per level, layers are not compared.</div>
<div class="s-p">Naming: <code>PI-2026-1.3</code> = 3rd iteration in 1st PI of 2026.</div>
</div>
<div class="col">
<table><thead><tr><th>Level</th><th>Job Size</th><th>File</th></tr></thead><tbody>
<tr><td style="color:var(--pk)"><b>Initiative</b></td><td>1&ndash;100</td><td>initiatives/I-XXX.md</td></tr>
<tr><td style="color:var(--ac2)"><b>Epic</b></td><td>1&ndash;100</td><td>epics/E-XXX.md</td></tr>
<tr><td style="color:var(--cy)"><b>Feature</b></td><td>1&ndash;100</td><td>features/F-XXX.md</td></tr>
<tr><td style="color:var(--or)"><b>Story</b></td><td>1&ndash;100</td><td>stories/S-XXX.md</td></tr>
<tr><td style="color:var(--rd)"><b>Defect</b></td><td>1&ndash;100</td><td>defects/D-XXX.md</td></tr>
<tr><td style="color:var(--yl)"><b>Task</b></td><td>&#x2014;</td><td>Checklist</td></tr>
</tbody></table>
<div class="s-note" style="margin-top:8px">Hierarchy via YAML frontmatter (<code>parent</code>): 7 levels, validated by MCP. All in git.</div>
</div></div>`,

// 9: EVIDENCE
`<div class="s-tag fade">Evidence detection</div>
<div class="s-h1 fade d1">Automatic contributor detection</div>
<div class="cols fade d2">
<div class="col">
<table><thead><tr><th>Signal</th><th>Source</th><th style="text-align:right">CW</th></tr></thead><tbody>
<tr><td>Item assignee</td><td style="color:var(--cy)">CI</td><td style="text-align:right;color:var(--gn)">1.0</td></tr>
<tr><td><code>/contribute</code> command</td><td style="color:var(--gn)">git</td><td style="text-align:right;color:var(--cy)">0.6</td></tr>
<tr><td>PR author &#x2192; item</td><td style="color:var(--cy)">CI</td><td style="text-align:right;color:var(--cy)">0.6</td></tr>
<tr><td>Commit with S-/F-/E-XXX</td><td style="color:var(--gn)">git</td><td style="text-align:right;color:var(--yl)">0.25</td></tr>
<tr><td>PR reviewer</td><td style="color:var(--cy)">CI</td><td style="text-align:right;color:var(--yl)">0.25</td></tr>
<tr><td>Issue comment</td><td style="color:var(--cy)">CI</td><td style="text-align:right;color:var(--or)">0.15</td></tr>
</tbody></table>
<div style="margin-top:6px;font-size:10px;color:var(--t3)"><b style="color:var(--gn)">git</b> = local hook (always) &middot; <b style="color:var(--cy)">CI</b> = optional contribution-sync workflow</div>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-t">Additive aggregation</div><div class="sc-l">Signals sum into <code>contribution_score</code>; CW is the per-item normalized share (&Sigma; = 1.0 per item)</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Manual signal</div><div class="sc-l"><code>/contribute @username weight:0.6</code> &middot; additively adds weight 0.6, does not override auto-detection</div></div>
<div class="sc y" style="margin-bottom:8px"><div class="sc-t">Item reference</div><div class="sc-l"><code>commit-msg</code> hook requires an item ID in the commit (or <code>no-ticket:</code>)</div></div>
<div class="sc o"><div class="sc-t">Commit &#x2260; time</div><div class="sc-l">Commits = relevance signal, not hours. AI changes patterns.</div></div>
</div></div>`,

// 10: SKILLS
`<div class="s-tag fade">AI Agent Skills</div>
<div class="s-h1 fade d1">4 composable EDPA skills</div>
<div class="s-sub fade d2">Claude Code skills = governance automation. Agent in terminal understands EDPA and executes it for you.</div>
<div class="sg sg2 fade d3">
<div class="sc a" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F3D7;&#xFE0F;</div><div><div style="font-weight:600">/edpa:setup</div><div class="sc-l">~450 tokens &middot; "Set up governance for my project"<br>Vendors engine into <code>.edpa/engine/</code>, seeds <code>.edpa/config/</code>, installs git hooks</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x26A1;</div><div><div style="font-weight:600">/edpa:engine</div><div class="sc-l">~760 tokens &middot; "Close iteration PI-2026-1.3"<br>Evidence gathering, EDPA calculation, invariant validation</div></div></div>
<div class="sc g" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F4C4;</div><div><div style="font-weight:600">/edpa:reports</div><div class="sc-l">~505 tokens &middot; "Generate reports"<br>MD/JSON/XLSX reports, frozen snapshots, per-item allocation</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F52C;</div><div><div style="font-weight:600">/edpa:autocalib</div><div class="sc-l">~625 tokens &middot; "Calibrate CW heuristics"<br>Karpathy autoresearch: 50 experiments overnight, MAD optimization</div></div></div>
</div>
<div class="s-note fade d4"><b>26+ platforms:</b> Claude Code (native), Codex CLI, Gemini CLI, Cursor, Windsurf, Aider... Skills live in repo — every team member gets them automatically.</div>`,

// 11: HOW SKILLS WORK
`<div class="s-tag fade">How it works</div>
<div class="s-h1 fade d1">Daily workflow with EDPA skills</div>
<div class="sg fade d2" style="gap:8px">
<div class="sc g" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--gn);width:30px">1</div><div><div style="font-weight:500">Team works normally</div><div class="sc-l">Coding on <code>feature/S-200-omop-parser</code> branches. PR, review, merge. Nothing extra.</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--cy);width:30px">2</div><div><div style="font-weight:500">Git hooks collect evidence locally</div><div class="sc-l">post-commit &#x2192; <code>local_evidence.py</code> writes commit_author + <code>/contribute</code> into <code>evidence[]</code> in <code>.edpa/backlog/</code>. No manual intervention, no GitHub.</div></div></div>
<div class="sc a" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--ac2);width:30px">3</div><div><div style="font-weight:500">End of iteration: "Close iteration PI-2026-1.3"</div><div class="sc-l">Claude Code runs <b>/edpa:engine</b> &#x2192; pulls evidence &#x2192; computes Score &#x2192; derives hours &#x2192; validates invariants.</div></div></div>
<div class="sc y" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--yl);width:30px">4</div><div><div style="font-weight:500">"Generate reports"</div><div class="sc-l"><b>/edpa:reports</b> &#x2192; MD/JSON reports per person + per-item allocation + frozen snapshot + Excel. 30 seconds.</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--or);width:30px">5</div><div><div style="font-weight:500">BankID signature</div><div class="sc-l">Member reviews report &#x2192; signs with BankID &#x2192; stored in <code>/signed/</code>. Legally stronger than paper.</div></div></div>
</div>`,

// 12: REPO TEMPLATE
`<div class="s-tag fade">GitHub Template</div>
<div class="s-h1 fade d1">Plugin + GitHub Actions, ready to use</div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:10px;line-height:1.7;border-left-color:var(--ac)"><b>.edpa/</b> (single source of truth, all in git)
&#x251C;&#x2500;&#x2500; engine/ (vendored by <code>/edpa:setup</code> from plugin)
&#x2502;    &#x251C;&#x2500;&#x2500; scripts/ (engine.py, backlog.py, board.py,
&#x2502;    &#x2502;    detect_contributors.py, reports.py, local_evidence.py, &hellip;)
&#x2502;    &#x251C;&#x2500;&#x2500; schemas/ (JSON Schemas)
&#x2502;    &#x2514;&#x2500;&#x2500; templates/ (cw_heuristics, edpa, people, &hellip;)
&#x251C;&#x2500;&#x2500; config/ (edpa.yaml, people.yaml, cw_heuristics.yaml, id_counters.yaml)
&#x251C;&#x2500;&#x2500; backlog/ (initiatives, epics, features, stories, defects, events, risks)
&#x2514;&#x2500;&#x2500; iterations/, reports/, snapshots/

<b>.git/hooks/</b> (installed by <code>/edpa:setup --with-hooks</code>)
&#x251C;&#x2500;&#x2500; pre-commit (ID-safety), commit-msg (item reference)
&#x2514;&#x2500;&#x2500; post-commit (local_evidence &#x2192; evidence[]), pre-push (collision check)

<b>.github/workflows/</b> (optional, <code>--with-ci</code> only)
&#x2514;&#x2500;&#x2500; edpa-contribution-sync.yml (PR-thread signals &#x2192; evidence[])</div>
