---
import '../../../styles/global.css';
import '../../../styles/presentation.css';
import Header from '../../../components/Header.astro';

const title = 'EDPA Presentation — kashealth.cz';
const description = `EDPA v${VERSION} governance presentation for kashealth.cz — Medical Platform and Data e-shop.`;
import { VERSION } from '../../../lib/version';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | EDPA v{VERSION}</title>
</head>
<body class="presentation-body">
  <Header currentPath="/en/presentation/" />
  <div class="deck" id="deck"></div>
  <div class="pres-nav">
    <div class="nav-l"><a href="/en/" class="pres-exit" title="Back to website" style="color:var(--t3);text-decoration:none;margin-right:12px;font-family:'JetBrains Mono',monospace;font-size:12px;border:1px solid var(--bd);padding:4px 8px;border-radius:4px;">&larr; Web</a><span class="logo">kashealth.cz</span><span class="nav-label">&middot; EDPA v{VERSION} &middot; Complete solution</span></div>
    <div class="nav-c" id="dots"></div>
    <div class="nav-r">
      <button class="pres-btn" id="btnPrev">&larr; Back</button>
      <span class="pg" id="pgN">1/20</span>
      <button class="pres-btn" id="btnNext">Next &rarr;</button>
    </div>
  </div>

<script>
import { initSlideDeck } from '../../../scripts/slide-engine';
import { VERSION } from '../../../lib/version';

const S=[

// 0: TITLE
`<div style="text-align:center;max-width:850px;margin:0 auto">
<div class="s-tag fade">Medical Platform and Data e-shop &middot; CZ.01.01.01/01/24_062/0007440 &middot; OP TAK</div>
<div class="s-h1 fade d1" style="font-size:44px;background:linear-gradient(135deg,var(--ac2),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent">Complete governance solution</div>
<div class="fade d2" style="font-size:18px;color:var(--t2);margin:16px 0 6px">EDPA — Evidence-Driven Proportional Allocation</div>
<div class="fade d3" style="font-size:14px;color:var(--t3);font-style:italic;margin-bottom:24px">Capacity derivation from delivery evidence</div>
<div class="sg sg4 fade d4" style="max-width:700px;margin:0 auto">
<div class="sc a" style="text-align:center;padding:12px"><div class="sc-t">Tooling</div><div style="font-size:12px;color:var(--ac2)">Teams + GitHub</div></div>
<div class="sc c" style="text-align:center;padding:12px"><div class="sc-t">Methodology</div><div style="font-size:12px;color:var(--cy)">EDPA v${VERSION}</div></div>
<div class="sc g" style="text-align:center;padding:12px"><div class="sc-t">Skills</div><div style="font-size:12px;color:var(--gn)">4 composable</div></div>
<div class="sc y" style="text-align:center;padding:12px"><div class="sc-t">Engine</div><div style="font-size:12px;color:var(--yl)">.edpa/ (local-first)</div></div>
</div>
<div class="fade d5" style="margin-top:20px;font-size:12px;color:var(--t3)">Jaroslav Urbanek &middot; Lead Architect &middot; March 2026<br>CVUT FBMI + Partner s.r.o.</div>
</div>`,

// 1: WHAT WE DELIVER
`<div class="s-tag fade">Presentation contents</div>
<div class="s-h1 fade d1">What we present today</div>
<div class="s-sub fade d2">Complete governance solution for the project — from tooling through methodology to automation. All local in git, no GitHub Project.</div>
<div class="sg sg5 fade d3">
<div class="sc a" style="min-height:140px"><div class="sc-i">&#x1F4AC;</div><div class="sc-t">1. Tooling</div><div class="sc-l">Teams + GitHub (optional)<br>~1,520 CZK/month<br>EDPA adds only git</div></div>
<div class="sc c" style="min-height:140px"><div class="sc-i">&#x1F511;</div><div class="sc-t">2. Identity</div><div class="sc-l">kashealth.cz<br>5 members + guests<br>Hybrid model</div></div>
<div class="sc g" style="min-height:140px"><div class="sc-i">&#x26A1;</div><div class="sc-t">3. EDPA</div><div class="sc-l">No timesheets<br>Dual-view CW<br>BankID audit</div></div>
<div class="sc y" style="min-height:140px"><div class="sc-i">&#x1F916;</div><div class="sc-t">4. AI Skills</div><div class="sc-l">4 composable<br>26+ platforms<br>Auto-calibration</div></div>
<div class="sc o" style="min-height:140px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">5. Engine</div><div class="sc-l">Vendored .edpa/engine/<br>Local, in git<br>Ready to use</div></div>
</div>`,

// 2: PROBLEM
`<div class="s-tag fade">Context</div>
<div class="s-h1 fade d1">Why we need our own solution</div>
<div class="sg sg2 fade d2">
<div class="sc o"><div class="sc-i">&#x1F500;</div><div class="sc-l"><b>Multiple tenants</b><br>CVUT Teams &#x2260; Partner Teams. Switching organizations, lost notifications.</div></div>
<div class="sc o"><div class="sc-i">&#x1F512;</div><div class="sc-l"><b>IT dependency</b><br>Every permission change = IT department request. Weeks of waiting.</div></div>
<div class="sc o"><div class="sc-i">&#x1F4DD;</div><div class="sc-l"><b>Manual timesheets</b><br>Subjective, administratively demanding, unauditable, nobody likes them.</div></div>
<div class="sc o"><div class="sc-i">&#x1F504;</div><div class="sc-l"><b>Migration risk</b><br>During spin-off everything must be moved. The later, the more expensive.</div></div>
</div>
<div class="qt fade d3">Goal: Local-first governance in git from day 1 &mdash; <code>.edpa/</code> is the single source of truth. Automated reporting. Tooling stays the team's choice, GitHub optional.</div>`,

// 3: TOOLING
`<div class="s-tag fade">Tooling stack</div>
<div class="s-h1 fade d1">EDPA = governance in git &middot; tooling is the team's choice</div>
<div class="cols fade d2">
<div class="col">
<table>
<thead><tr><th>Tool</th><th>Plan</th><th>9 months</th></tr></thead>
<tbody>
<tr><td><b>M365 Business Basic</b></td><td>5x @kashealth.cz</td><td>270 $</td></tr>
<tr><td><b>GitHub Team</b></td><td>8 developers</td><td>288 $</td></tr>
<tr><td><b>Domain kashealth.cz</b></td><td>WEDOS</td><td>~8 $</td></tr>
<tr style="background:rgba(99,102,241,.05)"><td><b>TOTAL</b></td><td><b>15 people</b></td><td style="color:var(--gn)"><b>~566 $</b></td></tr>
</tbody>
</table>
<div style="margin-top:8px;font-size:11px;color:var(--t3)">~1,520 CZK/month &middot; 100 CZK/person &middot; optional team collaboration</div>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px;padding:10px"><div class="sc-l"><b>EDPA governance replaces:</b><br>Jira &#x2192; <code>.edpa/backlog/</code> (YAML in git)<br>Timesheets / Tempo &#x2192; EDPA derived hours<br>Roadmaps &#x2192; <code>/edpa:board</code> (local)<br>Automation &#x2192; git hooks (+ optional <code>--with-ci</code>)</div></div>
<div class="s-note"><b>No separate PM/timesheet tooling &mdash; governance lives in git.</b> EDPA needs only <b>git locally</b>; Teams + GitHub are a separate, optional team choice. GitHub optional.</div>
</div></div>`,

// 4: IDENTITY
`<div class="s-tag fade">Identity</div>
<div class="s-h1 fade d1">kashealth.cz — hybrid model</div>
<div class="cols fade d2">
<div class="col">
<div class="sc o" style="margin-bottom:10px;padding:12px"><div style="font-size:12px"><b>&#x26A0;&#xFE0F; Key limitation:</b> Guests in Teams <b>cannot schedule meetings</b>. Hardcoded in Entra ID.</div></div>
<table>
<thead><tr><th>Account</th><th>Role</th><th>Type</th></tr></thead>
<tbody>
<tr style="background:rgba(99,102,241,.04)"><td><b>urbanek@kashealth.cz</b></td><td>Arch</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>tuma@kashealth.cz</b></td><td>DevSecOps</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>batek@kashealth.cz</b></td><td>PM/CVUT</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>pm@kashealth.cz</b></td><td>PM/MC</td><td style="color:var(--gn)">Member &#x2713;</td></tr>
<tr><td>@cvut.cz</td><td>Dev/R&D</td><td style="color:var(--yl)">Guest</td></tr>
<tr><td>@partner.cz</td><td>Dev</td><td style="color:var(--yl)">Guest</td></tr>
</tbody>
</table>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px"><div class="sc-t">Layer 1 &middot; Full members</div><div class="sc-l">5 people &middot; M365 Basic &middot; Schedule meetings</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Layer 2 &middot; Shared channels</div><div class="sc-l">B2B Direct Connect &middot; No tenant switching</div></div>
<div class="sc y"><div class="sc-t">Layer 3 &middot; Guest fallback</div><div class="sc-l">If IT does not cooperate &middot; Functional, worse UX</div></div>
</div></div>`,

// 5: EDPA CORE
`<div class="s-tag fade">EDPA v${VERSION}</div>
<div class="s-h1 fade d1">Time is not measured — it is derived</div>
<div class="qt fade d2">A person declares capacity. The system identifies work items they contributed to. Capacity is proportionally split based on evidence.</div>
<div class="cols fade d3">
<div class="col">
<div class="fm">Score = JobSize x CW

DerivedHours = (Score / &#x2211;Scores) x Capacity

<b>Guarantee: &#x2211; DerivedHours = Capacity</b>
Always. No exceptions.</div>
<div class="s-p">Gated calculation: we credit Story <code>Done</code> + Feature/Epic/Initiative gate transitions from git history. CW is the per-item normalized share from evidence.</div>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-l"><b>Nobody logs hours.</b> The report is a byproduct of delivery.</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-l"><b>Evidence from local git.</b> Commits &#x2192; auto-detection. PR signals optionally via CI.</div></div>
<div class="sc a"><div class="sc-l"><b>BankID signature.</b> Frozen snapshot + BankID = legally stronger than paper.</div></div>
</div></div>`,

// 6: DUAL VIEW
`<div class="s-tag fade">Dual-View</div>
<div class="s-h1 fade d1">Two views, one dataset</div>
<div class="sg sg2 fade d2" style="margin-top:16px">
<div class="sc g" style="min-height:180px"><div class="sc-i">&#x1F464;</div><div class="sc-t">Per-Person</div>
<div style="font-size:14px;font-weight:600;color:var(--gn);margin-bottom:6px">How is a person's capacity distributed?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--gn);margin:6px 0">DerivedHours = (Score / &#x2211;Scores) x Capacity
Guarantee: &#x2211; = Capacity</div>
<div class="sc-l">&#x2192; <b>Report per person</b> for OP TAK</div></div>
<div class="sc c" style="min-height:180px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">Per-Item</div>
<div style="font-size:14px;font-weight:600;color:var(--cy);margin-bottom:6px">How many people and hours did item X cost?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--cy);margin:6px 0">ItemShare = DerivedHours[P] / &#x2211; DerivedHours[*]
Guarantee: &#x2211; shares = 100%</div>
<div class="sc-l">&#x2192; <b>Cost card</b> per deliverable</div></div>
</div>
<div class="s-note fade d3">Both views from the same data (CW, JS, Capacity). No duplication, no conflict.</div>`,

// 7: THREE LAYERS
`<div class="s-tag fade">Architecture</div>
<div class="s-h1 fade d1">Three separate layers</div>
<div class="sg sg3 fade d2" style="margin-top:16px">
<div class="sc a" style="min-height:170px"><div class="sc-i">&#x2699;&#xFE0F;</div><div class="sc-t">Operational Metadata</div><div class="sc-v" style="color:var(--ac2);font-size:14px">.edpa/backlog/ (YAML in git)</div><div class="sc-l" style="margin-top:6px">Live delivery data &middot; Hierarchy &middot; Status &middot; Job Size &middot; WSJF</div></div>
<div class="sc c" style="min-height:170px"><div class="sc-i">&#x1F4CB;</div><div class="sc-t">Capacity Registry</div><div class="sc-v" style="color:var(--cy);font-size:14px">.edpa/config/ (YAML in repo)</div><div class="sc-l" style="margin-top:6px">Capacity &middot; Roles &middot; FTE &middot; Confirmed at Iteration Planning</div></div>
<div class="sc g" style="min-height:170px"><div class="sc-i">&#x1F512;</div><div class="sc-t">Evidence &amp; Reporting</div><div class="sc-v" style="color:var(--gn);font-size:14px">/snapshots &middot; /reports &middot; /signed</div><div class="sc-l" style="margin-top:6px">Frozen snapshots &middot; Reports &middot; BankID &middot; Immutable</div></div>
</div>
<div class="fade d3" style="margin-top:12px;text-align:center;font-size:12px;color:var(--t3)">Everything lives in git &#x2192; <code>.edpa/</code> is the single source of truth for backlog, capacity, FTE, derived hours and signatures. GitHub optional.</div>`,

// 8: HIERARCHY
`<div class="s-tag fade">Hierarchy</div>
<div class="s-h1 fade d1">SAFe-like hierarchy in .edpa/backlog/</div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:13px;line-height:2;border-left-color:var(--ac)"><span style="color:var(--pk)">Initiative</span> (entire project)
  &#x2514;&#x2500;&#x2500; <span style="color:var(--ac2)">Epic</span> (strategic goal, 6-9 months)
       &#x2514;&#x2500;&#x2500; <span style="color:var(--cy)">Feature</span> (fits within a PI)
            &#x251C;&#x2500;&#x2500; <span style="color:var(--or)">Story</span> (delivered in an Iteration)
            &#x2502;    &#x2514;&#x2500;&#x2500; <span style="color:var(--yl)">Task</span> (technical work)
            &#x2514;&#x2500;&#x2500; <span style="color:var(--rd)">Defect</span> (fix, at the Story level)</div>
<div class="s-p"><b>WSJF = (<span style="color:var(--gn)">BV</span> + <span style="color:var(--or)">TC</span> + <span style="color:var(--cy)">RR&amp;OE</span>) / <span style="color:var(--yl)">JS</span></b> — independent per level, layers are not compared.</div>
<div class="s-p">Naming: <code>PI-2026-1.3</code> = 3rd iteration in 1st PI of 2026.</div>
</div>
<div class="col">
<table><thead><tr><th>Level</th><th>Job Size</th><th>File</th></tr></thead><tbody>
<tr><td style="color:var(--pk)"><b>Initiative</b></td><td>1&ndash;100</td><td>initiatives/I-XXX.yaml</td></tr>
<tr><td style="color:var(--ac2)"><b>Epic</b></td><td>1&ndash;100</td><td>epics/E-XXX.yaml</td></tr>
<tr><td style="color:var(--cy)"><b>Feature</b></td><td>1&ndash;100</td><td>features/F-XXX.yaml</td></tr>
<tr><td style="color:var(--or)"><b>Story</b></td><td>1&ndash;100</td><td>stories/S-XXX.yaml</td></tr>
<tr><td style="color:var(--rd)"><b>Defect</b></td><td>1&ndash;100</td><td>defects/D-XXX.yaml</td></tr>
<tr><td style="color:var(--yl)"><b>Task</b></td><td>&#x2014;</td><td>Checklist</td></tr>
</tbody></table>
<div class="s-note" style="margin-top:8px">YAML files in git: <code>parent</code> references form the hierarchy, validated by MCP <code>edpa_item_create</code>.</div>
</div></div>`,

// 9: EVIDENCE
`<div class="s-tag fade">Evidence detection</div>
<div class="s-h1 fade d1">Automatic contributor detection</div>
<div class="cols fade d2">
<div class="col">
<table><thead><tr><th>GitHub signal</th><th style="text-align:right">Points</th><th style="text-align:right">CW</th></tr></thead><tbody>
<tr><td>Issue assignee</td><td style="text-align:right"><b>+4</b></td><td style="text-align:right;color:var(--gn)">1.0</td></tr>
<tr><td><code>/contribute</code> command</td><td style="text-align:right"><b>+3</b></td><td style="text-align:right;color:var(--cy)">0.6</td></tr>
<tr><td>PR author &#x2192; item</td><td style="text-align:right"><b>+2</b></td><td style="text-align:right;color:var(--cy)">0.6</td></tr>
<tr><td>Commit with S-/F-/E-XXX</td><td style="text-align:right"><b>+1</b></td><td style="text-align:right;color:var(--yl)">0.25</td></tr>
<tr><td>PR reviewer</td><td style="text-align:right"><b>+1</b></td><td style="text-align:right;color:var(--yl)">0.25</td></tr>
<tr><td>Issue comment</td><td style="text-align:right"><b>+0.5</b></td><td style="text-align:right;color:var(--or)">0.15</td></tr>
</tbody></table>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-t">Additive aggregation</div><div class="sc-l">Signals sum into <code>contribution_score</code>; CW is the per-item normalized share (&Sigma; = 1.0 per item)</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Override</div><div class="sc-l"><code>/contribute @urbanek weight:0.6</code></div></div>
<div class="sc y" style="margin-bottom:8px"><div class="sc-t">Branch naming</div><div class="sc-l"><code>feature/S-200-omop-parser</code><br>CI blocks PRs without reference</div></div>
<div class="sc o"><div class="sc-t">Commit &#x2260; time</div><div class="sc-l">Commits = relevance signal, not hours. AI changes patterns.</div></div>
</div></div>`,

// 10: SKILLS
`<div class="s-tag fade">AI Agent Skills</div>
<div class="s-h1 fade d1">4 composable EDPA skills</div>
<div class="s-sub fade d2">Claude Code skills = governance automation. Agent in terminal understands EDPA and executes it for you.</div>
<div class="sg sg2 fade d3">
<div class="sc a" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F3D7;&#xFE0F;</div><div><div style="font-weight:600">/edpa:setup</div><div class="sc-l">~450 tokens &middot; "Set up governance for my project"<br>Vendors the engine into <code>.edpa/engine/</code>, seeds <code>.edpa/config/</code>, installs git hooks</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x26A1;</div><div><div style="font-weight:600">/edpa:engine</div><div class="sc-l">~760 tokens &middot; "Close iteration PI-2026-1.3"<br>Evidence gathering, EDPA calculation, invariant validation</div></div></div>
<div class="sc g" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F4C4;</div><div><div style="font-weight:600">/edpa:reports</div><div class="sc-l">~505 tokens &middot; "Generate reports"<br>MD/JSON/XLSX reports, frozen snapshots, per-item allocation</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F52C;</div><div><div style="font-weight:600">/edpa:autocalib</div><div class="sc-l">~625 tokens &middot; "Calibrate CW heuristics"<br>Karpathy autoresearch: 50 experiments overnight, MAD optimization</div></div></div>
</div>
<div class="s-note fade d4"><b>26+ platforms:</b> Claude Code (native), Codex CLI, Gemini CLI, Cursor, Windsurf, Aider... Skills live in repo — every team member gets them automatically.</div>`,

// 11: HOW SKILLS WORK
`<div class="s-tag fade">How it works</div>
<div class="s-h1 fade d1">Daily workflow with EDPA skills</div>
<div class="sg fade d2" style="gap:8px">
<div class="sc g" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--gn);width:30px">1</div><div><div style="font-weight:500">Team works normally</div><div class="sc-l">Coding on <code>feature/S-200-omop-parser</code> branches. PR, review, merge. Nothing extra.</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--cy);width:30px">2</div><div><div style="font-weight:500">Git hooks guard evidence locally</div><div class="sc-l">Pre-commit hook checks the <code>S-/F-/E-XXX</code> reference &#x2192; evidence lives in git history. No manual intervention.</div></div></div>
<div class="sc a" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--ac2);width:30px">3</div><div><div style="font-weight:500">End of iteration: "Close iteration PI-2026-1.3"</div><div class="sc-l">Claude Code runs <b>/edpa:engine</b> &#x2192; reads local git evidence &#x2192; computes Score &#x2192; derives hours &#x2192; validates invariants.</div></div></div>
<div class="sc y" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--yl);width:30px">4</div><div><div style="font-weight:500">"Generate reports"</div><div class="sc-l"><b>/edpa:reports</b> &#x2192; MD/JSON reports per person + per-item allocation + frozen snapshot + Excel. 30 seconds.</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--or);width:30px">5</div><div><div style="font-weight:500">BankID signature</div><div class="sc-l">Member reviews report &#x2192; signs with BankID &#x2192; stored in <code>/signed/</code>. Legally stronger than paper.</div></div></div>
</div>`,

// 12: REPO TEMPLATE
`<div class="s-tag fade">Vendored engine</div>
<div class="s-h1 fade d1">Everything local in .edpa/, ready to use</div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:10px;line-height:1.7;border-left-color:var(--ac)"><b>.edpa/engine/</b> (vendored by /edpa:setup)
&#x251C;&#x2500;&#x2500; scripts/ (31 Python modules)
&#x2502;    &#x251C;&#x2500;&#x2500; engine.py, mcp_server.py, backlog.py
&#x2502;    &#x251C;&#x2500;&#x2500; local_evidence.py, detect_contributors.py
&#x2502;    &#x251C;&#x2500;&#x2500; reports.py, board.py, calibrate_signals.py
&#x2502;    &#x2514;&#x2500;&#x2500; hooks/ (pre-commit, post-commit, validate)
&#x251C;&#x2500;&#x2500; templates/ (cw_heuristics, edpa, people)
&#x2514;&#x2500;&#x2500; schemas/

