  /* Hero */
  .guide-hero {
    text-align: center;
    padding: 80px 0 60px;
  }
  .guide-title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    margin: 12px 0;
    background: linear-gradient(135deg, var(--t1), var(--ac3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .guide-subtitle {
    font-size: 17px;
    color: var(--t2);
    max-width: 600px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }

  /* Steps */
  .guide-step {
    padding: 64px 0;
    border-left: 3px solid var(--step-color);
    margin-left: 24px;
    scroll-margin-top: 120px;
  }
  @media (max-width: 768px) {
    .guide-step {
      margin-left: 0;
      border-left: none;
      border-top: 3px solid var(--step-color);
    }
  }
  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 28px;
  }
  .step-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
    opacity: 0.85;
    flex-shrink: 0;
  }
  .step-title {
    font-size: 26px;
    font-weight: 700;
    color: var(--t1);
    margin-bottom: 6px;
  }
  .step-desc {
    font-size: 15px;
    color: var(--t2);
    line-height: 1.6;
    max-width: 640px;
  }

  /* Code block */
  .step-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 900px) {
    .step-content {
      grid-template-columns: 1fr;
    }
  }
  .step-code {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
  }
  .code-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--s2);
    border-bottom: 1px solid var(--bd);
  }
  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .code-dot.red { background: #f87171; }
