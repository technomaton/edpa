const phases = [
  { label: 'Setup', steps: [1,2,3], color: 'var(--ac)' },
  { label: 'Config', steps: [4,5,6], color: 'var(--cy)' },
  { label: 'Run', steps: [7,8,9], color: 'var(--gn)' },
  { label: 'Report', steps: [10,11,12], color: 'var(--yl)' },
];
---

<Layout title="Guide вҖ” Zero to First Report" lang="en" description="Interactive EDPA framework guide: 12 steps from installation to your first timesheet report.">

  <!-- Progress bar -->
  <div class="guide-progress" id="guideProgress">
    <div class="progress-track">
      {phases.map(phase => (
        <div class="progress-phase" style={`--phase-color: ${phase.color}`}>
          <span class="phase-label">{phase.label}</span>
          <div class="phase-dots">
            {phase.steps.map(s => (
              <span class="phase-dot" data-step={s}></span>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </div>

  <!-- Hero -->
  <section class="section guide-hero">
    <div class="container">
      <p class="tag">Step-by-Step Guide</p>
      <h1 class="guide-title">Zero to First Report</h1>
      <p class="guide-subtitle">
        12 steps that walk you through the entire EDPA framework вҖ”
        from tool installation to a calibrated hour allocation report.
      </p>
      <a href="#step-1" class="btn btn-primary">Start the guide</a>
    </div>
  </section>

  <!-- Steps -->
  {steps.map((step, i) => (
    <section class="guide-step" id={`step-${step.num}`} style={`--step-color: ${step.color}`}>
      <div class="container">
        <div class="step-header">
          <span class="step-number" style={`color: ${step.color}`}>{String(step.num).padStart(2, '0')}</span>
          <div>
            <h2 class="step-title">{step.title}</h2>
            <p class="step-desc">{step.desc}</p>
          </div>
        </div>

        <div class="step-content">
          <div class="step-code">
            <div class="code-header">
              <span class="code-dot red"></span>
              <span class="code-dot yellow"></span>
              <span class="code-dot green"></span>
              <span class="code-label">terminal</span>
            </div>
            <pre><code>{step.code}</code></pre>
          </div>

          <div class="step-result">
            <div class="result-label">Expected output</div>
            <pre><code>{step.result}</code></pre>
          </div>
        </div>

        <div class="step-nav">
          {i > 0 && (
            <a href={`#step-${steps[i - 1].num}`} class="btn btn-secondary step-prev-btn">Back</a>
          )}
          {i < steps.length - 1 ? (
            <a href={`#step-${steps[i + 1].num}`} class="btn btn-primary step-next-btn">Next step &rarr;</a>
          ) : (
            <a href="/en/" class="btn btn-primary step-next-btn">Done вҖ” back to EDPA</a>
          )}
        </div>
      </div>
    </section>
  ))}

</Layout>

<script>
  function initGuideProgress() {
    const sections = document.querySelectorAll('.guide-step');
    const dots = document.querySelectorAll('.phase-dot');
    const fill = document.getElementById('progressFill');
    if (!sections.length || !fill) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          const num = parseInt(id.replace('step-', ''));
          const pct = (num / 12) * 100;
          fill.style.width = pct + '%';
          dots.forEach(d => {
            const ds = parseInt(d.getAttribute('data-step') || '0');
            d.classList.toggle('active', ds <= num);
          });
        }
      });
    }, { threshold: 0.3 });

    sections.forEach(s => observer.observe(s));
  }
  document.addEventListener('DOMContentLoaded', initGuideProgress);
  document.addEventListener('astro:page-load', initGuideProgress);
</script>

<style>
  /* Progress bar вҖ” sticky top */
  .guide-progress {
    position: sticky;
    top: 56px;
    z-index: 90;
    background: rgba(8, 10, 16, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bd);
    padding: 10px 24px 8px;
  }
  .progress-track {
    display: flex;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto 8px;
  }
  .progress-phase {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .phase-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--phase-color);
    opacity: 0.7;
