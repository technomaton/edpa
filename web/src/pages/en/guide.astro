---
import Layout from '../../layouts/Layout.astro';

const steps = [
  {
    num: 1,
    title: 'Prerequisites',
    color: 'var(--ac)',
    desc: 'EDPA is local-first — all you need is Python 3.10+ and Git. Claude Code users: Python deps are installed automatically by the SessionStart hook. Other environments: pip install manually. GitHub CLI is optional, only if you want the PR-signal CI workflow (--with-ci).',
    claude: `# Python 3.10+ must be in PATH
python3 --version   # >= 3.10

# Git for versioning .edpa/ (auto-commits)
git --version

# Python dependencies install automatically
# on first Claude Code session in the project (SessionStart hook)`,
    code: `# Python dependencies (Cursor, Codex CLI, raw)
pip install pyyaml ruamel.yaml openpyxl requests

# Verify
python3 --version   # >= 3.10
git --version

# Optional — only for PR-signal CI (--with-ci):
gh auth login`,
    result: `Python 3.12.1
git version 2.44.0

# Local-first: no org, no PAT, no GitHub Projects
# required for the core flow. Everything lives in .edpa/.`,
  },
  {
    num: 2,
    title: 'Create Repository',
    color: 'var(--cy)',
    desc: 'EDPA lives inside a Git repository. Any repo works — personal or org, on GitHub or a purely local git init. No Issue Types or GitHub Projects required.',
    code: `# Option A — new GitHub repo
gh repo create project-name \\
  --private --clone
cd project-name

# Option B — purely local (no GitHub)
mkdir project-name && cd project-name
git init`,
    result: `✓ Created repository project-name on GitHub
✓ Cloned to ./project-name

# or locally:
Initialized empty Git repository in ./project-name/.git/`,
  },
  {
    num: 3,
    title: 'Install EDPA',
    color: 'var(--gn)',
    desc: 'In Claude Code: install via the marketplace. Other environments (Cursor, Codex CLI): curl|sh. Both options vendor the engine to .edpa/engine/ and scaffold the .edpa/ structure.',
    claude: `/plugin install edpa@technomaton-edpa
# Claude Code downloads the plugin from the marketplace`,
    code: `# Outside Claude Code (Cursor, Codex CLI, raw):
curl -fsSL https://edpa.technomaton.com/install.sh | sh`,
    result: `EDPA Installer
==============
Downloading EDPA plugin...
✓ Engine vendored to .edpa/engine/
✓ Created .edpa/ structure:
  .edpa/engine/    ← scripts, templates, schemas
  .edpa/config/    ← team and project config
  .edpa/backlog/   ← work items (per-item YAML)
  .edpa/reports/   ← generated reports
✓ Created .edpa/config/people.yaml (edit your team)
✓ Created .edpa/config/edpa.yaml (edit project name)

Next: /edpa setup "Project Name"`,
  },
  {
    num: 4,
    title: '/edpa:setup',
    color: 'var(--yl)',
    desc: 'One command vendors the engine into .edpa/engine/ and seeds configs — team, project, and id_counters.yaml. Local-first: no GitHub Project provisioning. Optionally --with-ci adds the PR-signal workflow (edpa-contribution-sync.yml: PR-thread signals → evidence[], plus git hooks).',
    claude: `/edpa:setup "Project Name"
# Claude Code handles everything interactively

# Optional — add the PR-signal CI workflow:
/edpa:setup "Project Name" --with-ci`,
    code: `# Manual alternative (outside Claude Code):
# 1. Edit .edpa/config/people.yaml (team, roles, FTE, capacity)
# 2. Edit .edpa/config/edpa.yaml (project name, governance, naming)
# 3. Seed ID counters:
python3 .edpa/engine/scripts/setup.py

# Optional — PR-signal CI workflow:
python3 .edpa/engine/scripts/setup.py --with-ci`,
    result: `✓ Engine vendored: .edpa/engine/{scripts,templates,schemas}
✓ Team: 3 members configured (2.8 FTE)
✓ Config: .edpa/config/edpa.yaml (project + governance)
✓ Config: .edpa/config/people.yaml (team)
✓ Seeded: .edpa/config/id_counters.yaml
✓ CW heuristics: .edpa/config/cw_heuristics.yaml

# With --with-ci, additionally:
✓ Workflow: .github/workflows/edpa-contribution-sync.yml
  → PR-thread signals → evidence[] on items
✓ Git hooks installed (commit-msg: feat(<ID>): …)

# Local-first: no org, no PAT, no GitHub Projects.`,
  },
  {
    num: 5,
    title: 'Populate Backlog',
    color: 'var(--or)',
    desc: 'Add items via backlog.py add — the ID is allocated from id_counters.yaml, the parent hierarchy is validated, and a .md file is written under .edpa/backlog/ and auto-committed as feat(<ID>):. Hierarchy: Initiative > Epic > Feature > Story. WSJF is calculated automatically.',
    claude: `# In Claude Code, just say:
/edpa:add Story "Implement login endpoint" \\
  --parent F-1 --js 5 --bv 8 --tc 5 --rr-oe 3 \\
  --assignee jnovak --iteration PI-2026-1.1

# Claude, via MCP edpa_item_create:
#  • allocates the ID from id_counters.yaml (S-1)
#  • validates the parent (F-1 must exist)
#  • writes .edpa/backlog/stories/S-1.md
#  • auto-commits: feat(S-1): add story
# Then: "Validate the backlog and show me the tree"`,
    code: `# CLI fallback (outside Claude Code) — add auto-commits feat(<ID>):
python3 .edpa/engine/scripts/backlog.py add Story \\
  "Implement login endpoint" \\
  --parent F-1 --js 5 --bv 8 --tc 5 --rr-oe 3 \\
  --assignee jnovak --iteration PI-2026-1.1

# Writes .edpa/backlog/stories/S-1.md (front-matter + body):
#   id: S-1 / type: Story / js,bv,tc,rr_oe / status: Backlog
#   parent: F-1 / assignee / iteration
#   created_at filled locally, closed_at on transition to Done

python3 .edpa/engine/scripts/backlog.py validate
python3 .edpa/engine/scripts/backlog.py tree`,
    result: `✓ feat(S-1): add story  (auto-commit)
✓ Backlog valid (12 items, 0 errors)

I-1: Medical Platform
└── E-1: Data Processing Pipeline
    ├── F-1: Authentication (JS=8, WSJF=2.0)
    │   ├── S-1: Login endpoint (JS=5) ← jnovak
    │   └── S-2: Token refresh (JS=3) ← emala
    └── F-2: Data Import (JS=13, WSJF=1.8)
        ├── S-3: CSV parser (JS=5) ← emala
        └── S-4: Validation (JS=3) ← pkral`,
  },
  {
    num: 6,
    title: 'Team Starts Working',
    color: 'var(--pk)',
    desc: 'The team works using standard Git flow — branch naming conventions, commits referencing items (feat(<ID>):), PRs and code review. EDPA reads evidence locally from Git history; if the PR-signal CI runs (--with-ci), PR-thread signals are additionally appended to evidence[].',
    code: `# Branch naming (CI enforces format)
git checkout -b feature/S-1-login-endpoint

# Commit referencing item
git commit -m "feat(S-1): implement JWT login"

# Pull Request
gh pr create \\
  --title "S-1: Login endpoint" \\
  --body "Implements JWT auth flow" \\
  --assignee jnovak`,
    result: `Branch: feature/S-1-login-endpoint
Commits: 4 (linked to S-1)
PR #42: "S-1: Login endpoint"
  → Review requested: pkral
  → Status: Approved ✓ → Merged

Evidence (signal weights → contribution_score):
  jnovak: assignee 4.0 + pr_author 3.4 + commit_author 2.78 = 10.18
  pkral:  pr_reviewer 2.25                                  =  2.25
  → cw[jnovak, S-1] = 10.18 / 12.43 = 0.82
  → cw[pkral,  S-1] =  2.25 / 12.43 = 0.18

Timestamps (locally from Git history):
  S-1: created_at=2026-05-10, updated_at=2026-05-15, closed_at=2026-05-15

Flow metrics (MCP tool edpa_flow_metrics):
  S-1 cycle time: 5d | Throughput: 4 items/iter`,
  },
  {
    num: 7,
    title: 'End of Iteration',
    color: 'var(--ac)',
    desc: 'At iteration end, the EDPA engine reads evidence from backlog files in .edpa/backlog/ and proportionally allocates hours based on actual work.',
    claude: `/edpa:close-iteration PI-2026-1.1
# Claude Code reads evidence and computes allocation`,
    code: `python3 .edpa/engine/scripts/engine.py \\
  --edpa-root .edpa \\
  --iteration PI-2026-1.1

# The engine automatically:
# 1. Reads evidence from .edpa/backlog/ files
# 2. Computes contribution weight (CW)
# 3. Allocates hours: Score / Total × Capacity
# 4. Generates reports`,
    result: `EDPA Engine v${VERSION} — PI-2026-1.1
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Team:     3 members, 2.8 FTE
Capacity: 448 hours (2 weeks)

Allocation:
  jnovak  │████████████████░░│ 178.2h (39.8%)
  emala   │█████████████░░░░░│ 142.6h (31.8%)
  pkral   │████████████░░░░░░│ 127.2h (28.4%)
                        Total: 448.0h ✓
Invariants: ALL PASSED`,
  },
  {
    num: 8,
    title: 'Reports & Timesheets',
    color: 'var(--cy)',
    desc: 'EDPA generates per-person timesheets, per-item cost allocation, JSON exports, and frozen snapshots. All auditable and reproducible.',
    claude: `/edpa:reports
# Claude Code generates all reports and timesheets`,
    code: `# Generated files
.edpa/reports/
├── iteration-PI-2026-1.1/
│   ├── vykaz-jnovak.md      # per-person timesheet
│   ├── vykaz-emala.md
│   ├── vykaz-pkral.md
│   ├── edpa_results.json    # machine-readable
│   └── summary.xlsx         # Excel export
.edpa/snapshots/
└── iteration-PI-2026-1.1.json  # frozen snapshot`,
    result: `Per-person timesheet (vykaz-jnovak.md):
┌──────────┬────────┬────────┬────────┐
│ Person   │ Hours  │ Share  │ Items  │
├──────────┼────────┼────────┼────────┤
│ jnovak   │ 178.2  │ 39.8%  │ 7      │
│ emala    │ 142.6  │ 31.8%  │ 5      │
│ pkral    │ 127.2  │ 28.4%  │ 6      │
├──────────┼────────┼────────┼────────┤
│ TOTAL    │ 448.0  │ 100%   │ 18     │
└──────────┴────────┴────────┴────────┘`,
  },
  {
    num: 9,
    title: 'Retrospective + Calibration',
    color: 'var(--gn)',
    desc: 'Calibrate signal weights against a synthetic Monte Carlo corpus. calibrate_signals.py runs MC random sampling + coordinate descent and reports MAD baseline vs. calibrated.',
    claude: `/edpa:calibrate
# Claude Code runs MC calibration and shows MAD results`,
    code: `# Monte Carlo signal-weight calibration
python3 .edpa/engine/scripts/calibrate_signals.py \\
  --scenarios 1000 --seed 42

# MAD < 0.06 → excellent calibration
# MAD 0.06-0.10 → good calibration
# MAD > 0.10 → weight adjustment needed`,
    result: `Calibration: 1000 scenarios, seed=42
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Phase 1 (random sample):  MAD baseline   = 0.0861
Phase 2 (coord descent):  MAD calibrated = 0.0805
Improvement: +6.5%

Verdict: GOOD (defaults are already near optimum)`,
  },
  {
    num: 10,
    title: 'Next PI',
    color: 'var(--yl)',
    desc: 'Repeat for each iteration. With every cycle, calibration improves. Target: predictability > 80%, MAD < 0.05 by the third PI.',
    claude: `/edpa:close-iteration PI-2026-1.2
# Next iteration — same workflow`,
    code: `# New iteration
python3 .edpa/engine/scripts/engine.py \\
  --edpa-root .edpa \\
  --iteration PI-2026-1.2

# Compare iteration results in .edpa/reports/`,
    result: `Trend: PI-2026-1.1 → PI-2026-1.4
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MAD:            0.032 → 0.018  ↓ improving
Predictability: 78%   → 91%   ↑ on target
Correlation:    0.94  → 0.98  ↑ strong

Status: Mature — framework calibrated.`,
  },
];

const phases = [
  { label: 'Setup', steps: [1,2,3], color: 'var(--ac)' },
  { label: 'Config', steps: [4,5], color: 'var(--cy)' },
  { label: 'Run', steps: [6,7,8], color: 'var(--gn)' },
  { label: 'Report', steps: [9,10], color: 'var(--yl)' },
];
import { VERSION } from '../../lib/version';
---

<Layout title="Guide — Zero to First Report" lang="en" description="Interactive EDPA framework guide: 10 steps from installation to your first timesheet report.">

  <!-- Progress bar -->
  <div class="guide-progress" id="guideProgress">
    <div class="progress-track">
      {phases.map(phase => (
        <div class="progress-phase" style={`--phase-color: ${phase.color}`}>
          <span class="phase-label">{phase.label}</span>
          <div class="phase-dots">
            {phase.steps.map(s => (
              <span class="phase-dot" data-step={s}></span>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>
  </div>

  <!-- Hero -->
  <section class="section guide-hero">
    <div class="container">
      <p class="tag">Step-by-Step Guide</p>
      <h1 class="guide-title">Zero to First Report</h1>
      <p class="guide-subtitle">
        10 steps that walk you through the entire EDPA framework —
        from tool installation to a calibrated hour allocation report.
      </p>
      <a href="#step-1" class="btn btn-primary">Start the guide</a>
    </div>
  </section>

  <!-- Steps -->
  {steps.map((step, i) => (
    <section class="guide-step" id={`step-${step.num}`} style={`--step-color: ${step.color}`}>
      <div class="container">
        <div class="step-header">
          <span class="step-number" style={`color: ${step.color}`}>{String(step.num).padStart(2, '0')}</span>
          <div>
            <h2 class="step-title">{step.title}</h2>
            <p class="step-desc">{step.desc}</p>
          </div>
        </div>

        <div class="step-content">
          <div class="step-code">
            {step.claude && (
              <div class="cmd-tabs">
                <button class="cmd-tab active" data-tab="claude">Claude Code</button>
                <button class="cmd-tab" data-tab="cli">CLI</button>
              </div>
            )}
            {step.claude && (
              <div class="cmd-panel" data-panel="claude">
                <div class="code-header">
                  <span class="code-dot red"></span>
                  <span class="code-dot yellow"></span>
                  <span class="code-dot green"></span>
                  <span class="code-label">claude code (recommended)</span>
                </div>
                <pre><code>{step.claude}</code></pre>
              </div>
            )}
            <div class={step.claude ? "cmd-panel" : undefined} data-panel={step.claude ? "cli" : undefined} style={step.claude ? "display:none" : undefined}>
              <div class="code-header">
                <span class="code-dot red"></span>
                <span class="code-dot yellow"></span>
                <span class="code-dot green"></span>
                <span class="code-label">terminal</span>
              </div>
              <pre><code>{step.code}</code></pre>
            </div>
          </div>

          <div class="step-result">
            <div class="result-label">Expected output</div>
            <pre><code>{step.result}</code></pre>
          </div>
        </div>

        <div class="step-nav">
          {i > 0 && (
            <a href={`#step-${steps[i - 1].num}`} class="btn btn-secondary step-prev-btn">Back</a>
          )}
          {i < steps.length - 1 ? (
            <a href={`#step-${steps[i + 1].num}`} class="btn btn-primary step-next-btn">Next step &rarr;</a>
          ) : (
            <a href="/en/" class="btn btn-primary step-next-btn">Done — back to EDPA</a>
          )}
        </div>
      </div>
    </section>
  ))}

</Layout>

<script>
  function initGuideProgress() {
    const sections = document.querySelectorAll('.guide-step');
    const dots = document.querySelectorAll('.phase-dot');
    const fill = document.getElementById('progressFill');
    if (!sections.length || !fill) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          const num = parseInt(id.replace('step-', ''));
          const pct = (num / 10) * 100;
          fill.style.width = pct + '%';
          dots.forEach(d => {
            const ds = parseInt(d.getAttribute('data-step') || '0');
            d.classList.toggle('active', ds <= num);
          });
        }
      });
    }, { threshold: 0.3 });

    sections.forEach(s => observer.observe(s));
  }
  function initCmdTabs() {
    document.querySelectorAll('.cmd-tabs').forEach(tabs => {
      tabs.querySelectorAll('.cmd-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const parent = tabs.closest('.step-code');
          if (!parent) return;
          const target = btn.getAttribute('data-tab');
          tabs.querySelectorAll('.cmd-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          parent.querySelectorAll('.cmd-panel').forEach(p => {
            (p as HTMLElement).style.display = p.getAttribute('data-panel') === target ? '' : 'none';
          });
        });
      });
    });
  }
  document.addEventListener('DOMContentLoaded', () => { initGuideProgress(); initCmdTabs(); });
  document.addEventListener('astro:page-load', () => { initGuideProgress(); initCmdTabs(); });
</script>

<style>
  /* Progress bar — sticky top */
  .guide-progress {
    position: sticky;
    top: 56px;
    z-index: 90;
    background: rgba(8, 10, 16, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--bd);
    padding: 10px 24px 8px;
  }
  .progress-track {
    display: flex;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto 8px;
  }
  .progress-phase {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .phase-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--phase-color);
    opacity: 0.7;
  }
  .phase-dots {
    display: flex;
    gap: 6px;
  }
  .phase-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--s3);
    transition: background 0.3s, box-shadow 0.3s;
  }
  .phase-dot.active {
    background: var(--phase-color);
    box-shadow: 0 0 8px var(--phase-color);
  }
  .progress-bar {
    max-width: 1200px;
    margin: 0 auto;
    height: 3px;
    background: var(--s2);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--ac), var(--cy), var(--gn), var(--yl));
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  /* Hero */
  .guide-hero {
    text-align: center;
    padding: 80px 0 60px;
  }
  .guide-title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    margin: 12px 0;
    background: linear-gradient(135deg, var(--t1), var(--ac3));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .guide-subtitle {
    font-size: 17px;
    color: var(--t2);
    max-width: 600px;
    margin: 0 auto 28px;
    line-height: 1.6;
  }

  /* Steps */
  .guide-step {
    padding: 64px 0;
    border-left: 3px solid var(--step-color);
    margin-left: 24px;
    scroll-margin-top: 120px;
  }
  @media (max-width: 768px) {
    .guide-step {
      margin-left: 0;
      border-left: none;
      border-top: 3px solid var(--step-color);
    }
  }
  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 28px;
  }
  .step-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
    opacity: 0.85;
    flex-shrink: 0;
  }
  .step-title {
    font-size: 26px;
    font-weight: 700;
    color: var(--t1);
    margin-bottom: 6px;
  }
  .step-desc {
    font-size: 15px;
    color: var(--t2);
    line-height: 1.6;
    max-width: 640px;
  }

  /* Code block */
  .step-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 900px) {
    .step-content {
      grid-template-columns: 1fr;
    }
  }
  .step-code {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
  }
  .code-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--s2);
    border-bottom: 1px solid var(--bd);
  }
  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .code-dot.red { background: #f87171; }
  .code-dot.yellow { background: #fbbf24; }
  .code-dot.green { background: #34d399; }
  .code-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--t3);
    margin-left: auto;
  }
  /* Command tabs */
  .cmd-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--bd);
    background: var(--s2);
  }
  .cmd-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 8px 16px;
    background: none;
    border: none;
    color: var(--t3);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .cmd-tab:hover {
    color: var(--t1);
  }
  .cmd-tab.active {
    color: var(--ac);
    border-bottom-color: var(--ac);
  }

  .step-code pre {
    padding: 16px;
    overflow-x: auto;
  }
  .step-code code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
    color: var(--gn);
    background: none;
    padding: 0;
  }

  /* Result box */
  .step-result {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
  }
  .result-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--t3);
    padding: 10px 14px;
    background: var(--s2);
    border-bottom: 1px solid var(--bd);
  }
  .step-result pre {
    padding: 16px;
    overflow-x: auto;
  }
  .step-result code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    color: var(--t2);
    background: none;
    padding: 0;
  }

  /* Navigation */
  .step-nav {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }
  .step-prev-btn {
    margin-right: auto;
  }
</style>
