  .code-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--t3);
    margin-left: auto;
  }
  .step-code pre {
    padding: 16px;
    overflow-x: auto;
  }
  .step-code code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.7;
    color: var(--gn);
