    padding: 0;
  }

  /* Result box */
  .step-result {
    background: var(--s1);
    border: 1px solid var(--bd);
    border-radius: var(--r);
    overflow: hidden;
  }
  .result-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--t3);
    padding: 10px 14px;
    background: var(--s2);
    border-bottom: 1px solid var(--bd);
  }
  .step-result pre {
    padding: 16px;
    overflow-x: auto;
  }
  .step-result code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    color: var(--t2);
    background: none;
