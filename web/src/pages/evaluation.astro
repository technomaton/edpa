        description: 'WSJF se správně počítá jako (BV + TC + RR) / JS.',
        expected: 'WSJF = (BV + TC + RR) / JS',
      },
      {
        name: 'test_job_size_guardrails_story',
        description: 'Job Size guardrails pro Story: JS \u2264 8 (ideálně \u2264 5).',
        expected: 'Story JS \u2264 8 (recommended \u2264 5)',
      },
      {
        name: 'test_job_size_guardrails_feature',
        description: 'Job Size guardrails pro Feature: JS \u2264 13.',
        expected: 'Feature JS \u2264 13',
      },
      {
        name: 'test_job_size_guardrails_epic',
        description: 'Job Size guardrails pro Epic: JS \u2264 20.',
        expected: 'Epic JS \u2264 20',
      },
      {
        name: 'test_dor_checklist_validation',
        description: 'Definition of Ready checklist: popis, AC, odhad, parent linked.',
        expected: 'DoR: description, AC, estimate, parent linked',
      },
      {
        name: 'test_dod_checklist_validation',
        description: 'Definition of Done checklist: code reviewed, testy prošly, PR mergnuto.',
        expected: 'DoD: code reviewed, tests passed, PR merged',
      },
      {
        name: 'test_wip_limit_enforcement',
        description: 'WIP limit: ideálně 1 Story na osobu v daném okamžiku.',
        expected: 'WIP limit: 1 Story per person (ideal)',
      },
      {
        name: 'test_bankid_signature_support',
        description: 'Podpora BankID elektronického podpisu (zákon 21/2020 Sb.).',
        expected: 'BankID signature: zákon 21/2020 Sb.',
      },
      {
        name: 'test_reproducible_calculation',
        description: 'Reprodukovatelný výpočet: stejné vstupy musí vždy produkovat stejné výstupy.',
        expected: 'same inputs \u2192 same outputs (deterministic)',
      },
      {
        name: 'test_audit_trail_five_pillars',
        description: 'Audit trail pokrývá 5 pilířů: GitHub evidence, kapacita, snapshot, reprodukovatelný výpočet, podpis.',
        expected: '5 pillars: evidence, capacity, snapshot, calc, signature',
      },
    ],
  },
  {
    id: 'capacity-planning',
    title: 'Pl\u00E1nov\u00E1n\u00ED kapacity',
    icon: '\uD83D\uDCC8',
    color: 'cy',
    cardClass: 'cyan',
    description: 'Ov\u011B\u0159en\u00ED Iteration Planning Protocol \u2014 planning_factor jako vlastnost t\u00FDmu, pravidlo 80%, sledov\u00E1n\u00ED buffer usage a workflow potvrzen\u00ED kapacity.',
    expandedCount: 5,
    tests: [
      {
        name: 'test_planning_factor_team_level',
        description: 'planning_factor mus\u00ED b\u00FDt vlastnost t\u00FDmu, ne kadence ani osoby.',
        expected: 'teams[].planning_factor (not cadence, not person)',
      },
      {
        name: 'test_planning_factor_default',
        description: 'V\u00FDchoz\u00ED planning_factor mus\u00ED b\u00FDt 0.8 (pl\u00E1nuj na 80% celkov\u00E9 kapacity).',
        expected: 'planning_factor default = 0.8',
      },
      {
        name: 'test_planning_factor_range',
        description: 'planning_factor mus\u00ED b\u00FDt v rozsahu (0, 1.0] \u2014 nikdy nula, nikdy nad 100%.',
        expected: '0 < planning_factor \u2264 1.0',
      },
      {
        name: 'test_planning_capacity_formula',
        description: 'Planning Capacity = Total Capacity \u00D7 planning_factor pro ka\u017Ed\u00FD t\u00FDm.',
        expected: 'Planning_Capacity = \u03A3 Capacity[P] \u00D7 planning_factor',
      },
      {
        name: 'test_different_teams_different_factors',
        description: 'R\u016Fzn\u00E9 t\u00FDmy mohou m\u00EDt r\u016Fzn\u00E9 hodnoty planning_factor.',
        expected: 'teams[A].planning_factor \u2260 teams[B].planning_factor allowed',
      },
      {
        name: 'test_edpa_uses_total_not_planning',
        description: 'EDPA v\u00FDpo\u010Det v\u017Edy pou\u017E\u00EDv\u00E1 Total Capacity (100%), ne Planning Capacity.',
        expected: 'DerivedHours uses Capacity[P], not Planning_Capacity',
      },
      {
        name: 'test_buffer_absorbs_unplanned',
        description: 'Buffer (v\u00FDchoz\u00ED 20%) absorbuje support, maintenance, incidenty a nepl\u00E1novanou pr\u00E1ci.',
        expected: 'buffer = Total - Planning \u2192 unplanned work',
      },
      {
        name: 'test_unplanned_items_generate_evidence',
        description: 'Nepl\u00E1novan\u00E9 polo\u017Eky v bufferu generuj\u00ED evidenci a jsou alokov\u00E1ny norm\u00E1ln\u011B pomoc\u00ED EDPA.',
        expected: 'unplanned items \u2192 evidence \u2192 normal EDPA allocation',
      },
      {
        name: 'test_capacity_confirmed_at_planning',
        description: 'Ka\u017Ed\u00FD \u010Dlen t\u00FDmu mus\u00ED potvrdit dostupnost na Iteration Planning (availability: confirmed).',
        expected: 'availability = confirmed required',
      },
      {
        name: 'test_planning_factor_no_affect_invariant',
        description: 'planning_factor nesm\u00ED ovlivnit matematickou z\u00E1ruku \u03A3 DerivedHours = Capacity.',
        expected: 'planning_factor \u2192 no effect on \u03A3 = Capacity',
      },
      {
        name: 'test_buffer_usage_metric',
        description: 'Metrika Buffer_Usage sleduje, kolik rezervy bylo spot\u0159ebov\u00E1no nepl\u00E1novanou prac\u00ED.',
        expected: 'Buffer_Usage = unplanned / (Total - Planning) \u00D7 100%',
      },
      {
        name: 'test_high_buffer_usage_warning',
        description: 'Trvale vysok\u00FD buffer usage (>90%) by m\u011Bl vyvolat varov\u00E1n\u00ED k \u00FAprav\u011B kapacity nebo rozsahu.',
        expected: 'Buffer_Usage > 90% \u2192 warning',
      },
    ],
  },
];

const totalTests = categories.reduce((sum, cat) => sum + cat.tests.length, 0);

// Per-person multiplication: tests that validate per-person are run for each team member
const teamMembers = ['Alice (Arch, 60h)', 'Bob (Dev, 80h)', 'Carol (Dev, 60h)', 'Dave (DevOps, 40h)', 'Eve (PM, 40h)', 'Frank (Dev, 40h)'];
const teamSize = teamMembers.length;
// Categories 1 (invariants), 4 (dual-view), 5 (edge cases) run per person
const perPersonCategories = ['matematicke-invarianty', 'dual-view-konzistence', 'edge-cases'];
const perPersonTests = categories
  .filter(c => perPersonCategories.includes(c.id))
  .reduce((sum, cat) => sum + cat.tests.length, 0);
const globalTests = totalTests - perPersonTests;
const totalChecks = (perPersonTests * teamSize) + globalTests;
import { VERSION } from '../lib/version';
---
<Layout title="Evaluace a testy" description="302 verifikačních kontrol EDPA — invarianty, evidence detection, CW heuristika, edge cases, governance audit.">
<div class="container section evaluation-page">

  <div class="page-header">
    <div class="tag">Evaluace</div>
    <h1>Testy a evaluace EDPA v{VERSION}</h1>
    <p class="subtitle">{totalChecks} verifikačních kontrol — {totalTests} scénářů × {teamSize} členů týmu</p>
  </div>

  <!-- ============================================================
       HERO SUMMARY
       ============================================================ -->
  <div class="test-summary">
    <div class="summary-score">
      <span class="score-number">{totalChecks}</span>
      <span class="score-divider">/</span>
      <span class="score-total">{totalChecks}</span>
    </div>
    <div class="summary-label">PASSED</div>
    <div class="summary-bar">
      <div class="bar-fill"></div>
    </div>
    <p class="summary-text">
      {totalTests} testových scénářů v 8 kategoriích. Per-person testy (invarianty, dual-view, edge cases)
      běží pro každého z {teamSize} členů týmu → <strong>{totalChecks} celkových kontrol</strong>. Vše prochází.
    </p>

    <!-- Team members badge row -->
    <div style="display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-top: 12px;">
      {teamMembers.map(m => (
        <span class="badge badge-green" style="font-size: 10px;">{m} ✓</span>
      ))}
    </div>

    <!-- Category overview -->
    <div class="category-overview">
      <button type="button" class="category-pill category-pill-active" data-filter="all">
        <span class="pill-icon">*</span>
        <span class="pill-name">Vše</span>
        <span class="pill-count pill-count-ac">{totalTests}</span>
      </button>
      {categories.map((cat) => (
        <button type="button" class="category-pill" data-filter={cat.id}>
          <span class="pill-icon">{cat.icon}</span>
          <span class="pill-name">{cat.title}</span>
          <span class={`pill-count pill-count-${cat.color}`}>{perPersonCategories.includes(cat.id) ? cat.tests.length * teamSize : cat.tests.length}</span>
        </button>
      ))}
    </div>

    <!-- Search bar -->
    <div class="search-bar">
      <input type="text" id="testSearch" placeholder="Hledat test..." class="search-input" />
      <span class="search-count" id="searchCount"></span>
    </div>
  </div>

  <!-- ============================================================
       TEST CATEGORIES
       ============================================================ -->
  {categories.map((cat, catIndex) => (
    <section id={cat.id} data-category={cat.id} class="test-category-section">
      <div class="category-header">
        <div class="category-title-row">
          <span class="category-icon">{cat.icon}</span>
          <h2>{catIndex + 1}. {cat.title} &mdash; {cat.tests.length} scénářů{perPersonCategories.includes(cat.id) ? ` × ${teamSize} osob = ${cat.tests.length * teamSize} kontrol` : ''}</h2>
        </div>
        <div class="category-progress">
          <div class="category-progress-bar">
            <div class={`category-progress-fill cat-fill-${cat.color}`}></div>
          </div>
          <span class={`category-pass-count cat-text-${cat.color}`}>{perPersonCategories.includes(cat.id) ? cat.tests.length * teamSize : cat.tests.length}/{perPersonCategories.includes(cat.id) ? cat.tests.length * teamSize : cat.tests.length} PASS</span>
        </div>
      </div>
      <p>{cat.description}</p>
      {perPersonCategories.includes(cat.id) && (
        <div class="note" style="margin-bottom:12px">
          Každý scénář běží per osoba: {teamMembers.map(m => m.split(' ')[0]).join(', ')} — celkem {cat.tests.length * teamSize} kontrol.
        </div>
      )}

      <div class="tests-grid">
        {cat.tests.map((test, i) => (
          <details class={`card test-card ${cat.cardClass}`} data-category={cat.id} data-testname={test.name} data-testdesc={test.description} open={i < cat.expandedCount ? true : undefined}>
            <summary class="test-header">
              <span class="test-index">{String((i + 1)).padStart(2, '0')}</span>
              <code class="test-name">{test.name}</code>
              <span class="badge badge-green">PASS</span>
              <span class="chevron"></span>
            </summary>
            <div class="test-body">
              <p class="test-desc">{test.description}</p>
              <div class="test-expected">
                <span class="expected-label">Očekávání:</span>
                <code>{test.expected}</code>
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>
  ))}

  <!-- ============================================================
       AUTO-KALIBRACE (existing section preserved)
       ============================================================ -->
  <section id="auto-kalibrace">
    <h2>Auto-kalibrace (Karpathy loop)</h2>
    <p>Automatický kalibrační systém inspirovaný Karpathyho autoresearch vzorem. Jeden soubor, jedna metrika, jedna smyčka.</p>

    <div class="grid grid-2" style="margin-top:16px">
      <div class="card accent">
        <div class="tag" style="color:var(--ac3)">Konfigurace</div>
        <table>
          <tbody>
            <tr><td><strong>Target</strong></td><td><code>cw_heuristics.yaml</code></td></tr>
            <tr><td><strong>Metric</strong></td><td>MAD (Mean Absolute Deviation)</td></tr>
            <tr><td><strong>Direction</strong></td><td>lower is better</td></tr>
            <tr><td><strong>Budget</strong></td><td>50 experimentů (~2h)</td></tr>
            <tr><td><strong>Memory</strong></td><td><code>git log</code> na kalibrační větvi</td></tr>
            <tr><td><strong>Evaluator</strong></td><td><code>evaluate_cw.py</code> (LOCKED)</td></tr>
          </tbody>
        </table>
      </div>

      <div class="card green">
        <div class="tag" style="color:var(--gn)">Očekávané výsledky</div>
        <ul>
          <li>Typické zlepšení: <strong>15&ndash;30% redukce MAD</strong></li>
          <li>Po 50 experimentech: heuristika odpovídá reálným vzorcům týmu</li>
          <li>Diminishing returns po ~30 experimentech</li>
          <li>Prerequisite: &ge; 20 manuálně potvrzených CW záznamů</li>
        </ul>
      </div>
    </div>

    <h3>Smyčka</h3>
    <div class="card" style="margin-top:12px">
      <ol class="loop-steps">
        <li><code>git checkout -b calibration/{`{timestamp}`}</code></li>
        <li>Pro každý experiment (1..budget):
          <ol class="loop-substeps">
            <li>Načti aktuální heuristiku + historii experimentů</li>
            <li>Navrhni JEDNU změnu parametru (threshold, weight, signal score)</li>
            <li><code>git commit -m "exp {`{n}`}: {`{param}`} {`{old}`} -&gt; {`{new}`}"</code></li>
            <li>Spusť: <code>python evaluate_cw.py --ground-truth ... --heuristics ...</code></li>
            <li>Parsuj MAD z výstupu</li>
            <li>Pokud MAD &lt; předchozí_best: <span style="color:var(--gn)">KEEP</span> | Jinak: <span style="color:var(--rd)">REVERT</span></li>
            <li>Loguj do <code>calibration_log.tsv</code></li>
          </ol>
        </li>
        <li>Vytiskni souhrn: initial MAD, final MAD, % zlepšení</li>
        <li>Zeptej se uživatele: merge kalibrační větev do main?</li>
      </ol>
    </div>

    <h3>Bezpečnostní omezení</h3>
    <div class="grid grid-2" style="margin-top:12px">
      <div class="note"><strong>Evaluator je LOCKED</strong> — agent nesmí editovat <code>evaluate_cw.py</code>. Oddělení optimalizéru od objektivní funkce.</div>
      <div class="note"><strong>Jedna změna per experiment</strong> — pokud změníš 5 věcí, nevíš co fungovalo.</div>
    </div>

    <h3>Strategie eskalace</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Experimenty</th><th>Focus</th><th>Parametry</th></tr>
        </thead>
        <tbody>
          <tr><td>1&ndash;10</td><td>role_weights</td><td>4 parametry (největší impact)</td></tr>
          <tr><td>11&ndash;25</td><td>signal weights</td><td>6 parametrů</td></tr>
          <tr><td>26&ndash;50</td><td>threshold + fine-tuning</td><td>kombinované ladění</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============================================================
       CW HEURISTIKA (existing section preserved)
       ============================================================ -->
  <section id="cw-heuristika">
    <h2>CW Heuristika</h2>
    <p>Výchozí váhy pro automatické přiřazení Contribution Weight na základě GitHub signálů. Hodnoty kalibrované Monte Carlo simulací.</p>

    <div class="grid grid-2" style="margin-top:16px">
      <div class="card cyan">
        <div class="tag" style="color:var(--cy)">Role weights <span class="badge" style="margin-left:8px;font-size:10px;background:var(--gn);color:var(--bg);padding:2px 6px;border-radius:4px">Monte Carlo calibrated</span></div>
        <table>
          <thead>
            <tr><th>Role</th><th style="text-align:right">CW</th><th>Vizualizace</th></tr>
          </thead>
          <tbody>
            <tr><td><strong>owner</strong></td><td style="text-align:right">1.0</td><td><div class="cw-bar" style="width:100%;background:var(--gn)"></div></td></tr>
            <tr><td><strong>key</strong></td><td style="text-align:right">0.6</td><td><div class="cw-bar" style="width:60%;background:var(--cy)"></div></td></tr>
            <tr><td><strong>reviewer</strong></td><td style="text-align:right">0.25</td><td><div class="cw-bar" style="width:25%;background:var(--yl)"></div></td></tr>
            <tr><td><strong>consulted</strong></td><td style="text-align:right">0.15</td><td><div class="cw-bar" style="width:15%;background:var(--or)"></div></td></tr>
          </tbody>
        </table>
      </div>

      <div class="card yellow">
        <div class="tag" style="color:var(--yl)">Signal weights</div>
        <table>
          <thead>
            <tr><th>Signal</th><th style="text-align:right">Score</th></tr>
          </thead>
          <tbody>
            <tr><td><code>assignee</code></td><td style="text-align:right;color:var(--gn)">4.0</td></tr>
            <tr><td><code>contribute_command</code></td><td style="text-align:right;color:var(--cy)">3.0</td></tr>
            <tr><td><code>pr_author</code></td><td style="text-align:right;color:var(--cy)">2.0</td></tr>
            <tr><td><code>commit_author</code></td><td style="text-align:right;color:var(--yl)">1.0</td></tr>
            <tr><td><code>pr_reviewer</code></td><td style="text-align:right;color:var(--yl)">1.0</td></tr>
            <tr><td><code>issue_comment</code></td><td style="text-align:right;color:var(--or)">0.5</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="note" style="margin-top:16px"><strong>Pravidlo:</strong> Nejsilnější signál určuje CW. Evidence Score = součet všech signálů. Pokud Evidence Score &ge; threshold (default 1.0), osoba je přiřazena k itemu.</div>

    <h3 style="margin-top:28px">Validace <span class="badge" style="font-size:11px;background:var(--gn);color:var(--bg);padding:2px 8px;border-radius:4px;margin-left:8px">Monte Carlo</span></h3>
    <p style="color:var(--t2);font-size:13px;margin-bottom:12px">1000 sc&eacute;n&aacute;řů, 68 156 z&aacute;znamů, p&lt;0.001</p>

    <div class="card green" style="margin-top:12px">
      <div class="tag" style="color:var(--gn)">Role bias (Git activity vs. actual contribution)</div>
      <table>
        <thead>
          <tr><th>Role</th><th style="text-align:right">Bias</th><th>Korekce</th></tr>
        </thead>
        <tbody>
          <tr><td><strong>BO</strong></td><td style="text-align:right;color:var(--or)">+0.15</td><td>Systematicky podhodnocen &mdash; m&aacute;lo commitů, velk&yacute; dopad</td></tr>
          <tr><td><strong>PM</strong></td><td style="text-align:right;color:var(--yl)">+0.05</td><td>Koordinace se projevuje v koment&aacute;řích, ne v k&oacute;du</td></tr>
          <tr><td><strong>Arch</strong></td><td style="text-align:right;color:var(--yl)">+0.05</td><td>Review a design rozhodnut&iacute; maj&iacute; n&iacute;zkou git stopu</td></tr>
          <tr><td><strong>Dev</strong></td><td style="text-align:right;color:var(--gn)">0.00</td><td>Referen&ccedil;n&iacute; baseline &mdash; git přesně zachycuje</td></tr>
          <tr><td><strong>QA</strong></td><td style="text-align:right;color:var(--gn)">0.00</td><td>Testov&aacute;n&iacute; generuje dostatečn&eacute; sign&aacute;ly</td></tr>
        </tbody>
      </table>
    </div>

    <div class="note" style="margin-top:12px"><strong>Poznámka:</strong> Git měří aktivitu, ne hodnotu. Strategické role (BO, PM, Arch) jsou systematicky podhodnoceny. Monte Carlo simulace kvantifikuje bias a umožňuje per-role korekce (<code>role_overrides</code>).</div>
  </section>

  <!-- ============================================================
       SROVNANI METOD (existing section preserved)
       ============================================================ -->
  <section id="srovnani">
    <h2>Srovnání metod</h2>
    <div class="card">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>Kritérium</th>
            <th style="color:var(--gn)">EDPA v{VERSION}</th>
            <th>Ruční timesheets</th>
            <th>Fixní alokace</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Přesnost</td>
            <td><span class="badge badge-green">Vysoká</span></td>
            <td><span class="badge badge-yellow">Střední</span></td>
            <td><span class="badge badge-red">Nízká</span></td>
          </tr>
          <tr>
            <td>Úsilí</td>
            <td><span class="badge badge-green">Minimální</span></td>
            <td><span class="badge badge-red">Vysoké</span></td>
            <td><span class="badge badge-green">Žádné</span></td>
          </tr>
          <tr>
            <td>Auditovatelnost</td>
            <td><span class="badge badge-green">Plná</span></td>
            <td><span class="badge badge-yellow">Částečná</span></td>
            <td><span class="badge badge-red">Žádná</span></td>
          </tr>
          <tr>
            <td>Dual-view</td>
            <td><span class="badge badge-green">Ano</span></td>
            <td><span class="badge badge-red">Ne</span></td>
            <td><span class="badge badge-red">Ne</span></td>
          </tr>
          <tr>
            <td>Mat. garance</td>
            <td><span class="badge badge-green">&Sigma; = capacity</span></td>
            <td><span class="badge badge-red">Žádná</span></td>
            <td><span class="badge badge-yellow">Složitější</span></td>
          </tr>
          <tr>
            <td>Automatizace</td>
            <td><span class="badge badge-green">GitHub Actions</span></td>
            <td><span class="badge badge-red">Manuální</span></td>
            <td><span class="badge badge-yellow">Částečná</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ============================================================
       DEMO VYPOCET (existing section preserved)
       ============================================================ -->
  <section id="demo">
    <h2>Demo výpočet</h2>
    <p>Statická ukázka výpočtu EDPA pro 3 osoby a 5 work items. Provozní varianta (Simple mode).</p>

    <h3>Kapacita</h3>
    <div class="card" style="margin-top:12px">
      <table>
        <thead>
          <tr><th>Osoba</th><th>FTE</th><th style="text-align:right">Kapacita (h)</th></tr>
        </thead>
        <tbody>
          <tr><td><strong>Alice</strong></td><td>0.5</td><td style="text-align:right">40h</td></tr>
          <tr><td><strong>Bob</strong></td><td>1.0</td><td style="text-align:right">80h</td></tr>
          <tr><td><strong>Carol</strong></td><td>0.75</td><td style="text-align:right">60h</td></tr>
        </tbody>
      </table>
