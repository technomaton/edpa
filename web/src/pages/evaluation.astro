<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('testSearch') as HTMLInputElement;
    const searchCount = document.getElementById('searchCount') as HTMLSpanElement;
    const pills = document.querySelectorAll<HTMLButtonElement>('.category-pill[data-filter]');
    const allCards = document.querySelectorAll<HTMLDetailsElement>('details.test-card');
    const allSections = document.querySelectorAll<HTMLElement>('section.test-category-section');
    const totalTests = allCards.length;

    let activeCategory = 'all';

    function applyFilters() {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      allCards.forEach((card) => {
        const cardCategory = card.getAttribute('data-category') || '';
        const testName = (card.getAttribute('data-testname') || '').toLowerCase();
        const testDesc = (card.getAttribute('data-testdesc') || '').toLowerCase();

        const matchesCategory = activeCategory === 'all' || cardCategory === activeCategory;
        const matchesSearch = !query || testName.includes(query) || testDesc.includes(query);

        if (matchesCategory && matchesSearch) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Hide sections where all tests are hidden
      allSections.forEach((section) => {
        const sectionId = section.getAttribute('data-category') || '';
        const visibleCards = section.querySelectorAll('details.test-card:not(.hidden)');
        if (visibleCards.length === 0) {
          section.classList.add('hidden');
        } else {
          section.classList.remove('hidden');
        }
      });

      // Update count display
      if (query || activeCategory !== 'all') {
        searchCount.textContent = `${visibleCount} z ${totalTests}`;
      } else {
        searchCount.textContent = '';
      }
    }

    // Search input handler
    searchInput.addEventListener('input', () => {
      applyFilters();
    });

    // Category pill click handler
    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        // Update active state
        pills.forEach((p) => p.classList.remove('category-pill-active'));
        pill.classList.add('category-pill-active');

        activeCategory = pill.getAttribute('data-filter') || 'all';
        applyFilters();
      });
    });
  });
</script>
