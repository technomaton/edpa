---
import '../../styles/global.css';
import '../../styles/presentation.css';
import Header from '../../components/Header.astro';

const title = 'EDPA Prezentace — kashealth.cz';
const description = 'EDPA prezentace pro kashealth.cz — kompletní governance řešení pro projekt Medical Platform.';
import { VERSION } from '../../lib/version';
---
<!doctype html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | EDPA v{VERSION}</title>
</head>
<body class="presentation-body">
  <Header currentPath="/presentation/" />
  <div class="deck" id="deck"></div>
  <div class="pres-nav">
    <div class="nav-l"><a href="/" class="pres-exit" title="Back to website" style="color:var(--t3);text-decoration:none;margin-right:12px;font-family:'JetBrains Mono',monospace;font-size:12px;border:1px solid var(--bd);padding:4px 8px;border-radius:4px;">&larr; Web</a><span class="logo">kashealth.cz</span><span class="nav-label">&middot; EDPA v{VERSION} &middot; Kompletní řešení</span></div>
    <div class="nav-c" id="dots"></div>
    <div class="nav-r">
      <button class="pres-btn" id="btnPrev">&larr; Zpět</button>
      <span class="pg" id="pgN">1/20</span>
      <button class="pres-btn" id="btnNext">Dále &rarr;</button>
    </div>
  </div>

<script>
import { initSlideDeck } from '../../scripts/slide-engine';
import { VERSION } from '../../lib/version';

const S=[

// 0: TITLE
`<div style="text-align:center;max-width:850px;margin:0 auto">
<div class="s-tag fade">Medical Platform a Datový e-shop &middot; CZ.01.01.01/01/24_062/0007440 &middot; OP TAK</div>
<div class="s-h1 fade d1" style="font-size:44px;background:linear-gradient(135deg,var(--ac2),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent">Kompletní governance řešení</div>
<div class="fade d2" style="font-size:18px;color:var(--t2);margin:16px 0 6px">EDPA — Evidence-Driven Proportional Allocation</div>
<div class="fade d3" style="font-size:14px;color:var(--t3);font-style:italic;margin-bottom:24px">Capacity derivation from delivery evidence</div>
<div class="sg sg4 fade d4" style="max-width:700px;margin:0 auto">
<div class="sc a" style="text-align:center;padding:12px"><div class="sc-t">Tooling</div><div style="font-size:12px;color:var(--ac2)">Teams + GitHub</div></div>
<div class="sc c" style="text-align:center;padding:12px"><div class="sc-t">Metodika</div><div style="font-size:12px;color:var(--cy)">EDPA v${VERSION}</div></div>
<div class="sc g" style="text-align:center;padding:12px"><div class="sc-t">Skills</div><div style="font-size:12px;color:var(--gn)">4 composable</div></div>
<div class="sc y" style="text-align:center;padding:12px"><div class="sc-t">Engine</div><div style="font-size:12px;color:var(--yl)">.edpa/ (local-first)</div></div>
</div>
<div class="fade d5" style="margin-top:20px;font-size:12px;color:var(--t3)">Jaroslav Urbanek &middot; Lead Architect &middot; Březen 2026<br>CVUT FBMI + Partner s.r.o.</div>
</div>`,

// 1: WHAT WE DELIVER
`<div class="s-tag fade">Obsah prezentace</div>
<div class="s-h1 fade d1">Co dnes předkládáme</div>
<div class="s-sub fade d2">Kompletní governance řešení pro projekt — od toolingu přes metodiku po automatizaci. Vše lokálně v gitu, žádný GitHub Project.</div>
<div class="sg sg5 fade d3">
<div class="sc a" style="min-height:140px"><div class="sc-i">&#x1F4AC;</div><div class="sc-t">1. Tooling</div><div class="sc-l">Teams + GitHub (volitelné)<br>~1 520 Kč/měsíc<br>EDPA navíc jen git</div></div>
<div class="sc c" style="min-height:140px"><div class="sc-i">&#x1F511;</div><div class="sc-t">2. Identita</div><div class="sc-l">kashealth.cz<br>5 členů + guests<br>Hybridní model</div></div>
<div class="sc g" style="min-height:140px"><div class="sc-i">&#x26A1;</div><div class="sc-t">3. EDPA</div><div class="sc-l">Bez timesheetů<br>Dual-view CW<br>BankID audit</div></div>
<div class="sc y" style="min-height:140px"><div class="sc-i">&#x1F916;</div><div class="sc-t">4. AI Skills</div><div class="sc-l">4 composable<br>26+ platforem<br>Auto-kalibrace</div></div>
<div class="sc o" style="min-height:140px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">5. Engine</div><div class="sc-l">Vendored .edpa/engine/<br>Lokální, v gitu<br>Okamžitě použitelné</div></div>
</div>`,

// 2: PROBLEM
`<div class="s-tag fade">Kontext</div>
<div class="s-h1 fade d1">Proč potřebujeme vlastní řešení</div>
<div class="sg sg2 fade d2">
<div class="sc o"><div class="sc-i">&#x1F500;</div><div class="sc-l"><b>Různé tenanty</b><br>CVUT Teams &#x2260; Partner Teams. Přepínání organizací, ztracené notifikace.</div></div>
<div class="sc o"><div class="sc-i">&#x1F512;</div><div class="sc-l"><b>Závislost na IT</b><br>Každá změna oprávnění = žádost na IT oddělení. Týdny čekání.</div></div>
<div class="sc o"><div class="sc-i">&#x1F4DD;</div><div class="sc-l"><b>Ruční timesheets</b><br>Subjektivní, administrativně náročné, neauditovatelné, nikdo je nemá rád.</div></div>
<div class="sc o"><div class="sc-i">&#x1F504;</div><div class="sc-l"><b>Riziko migrace</b><br>Při spin-offu bude nutné vše přesunout. Čím později, tím dražší.</div></div>
</div>
<div class="qt fade d3">Cíl: Local-first governance v gitu od dne 1 &mdash; <code>.edpa/</code> je jediný zdroj pravdy. Automatizované vykazování. Tooling zůstává volbou týmu, GitHub volitelný.</div>`,

// 3: TOOLING
`<div class="s-tag fade">Tooling stack</div>
<div class="s-h1 fade d1">EDPA = governance v gitu &middot; tooling je volba týmu</div>
<div class="cols fade d2">
<div class="col">
<table>
<thead><tr><th>Nástroj</th><th>Plan</th><th>9 mes.</th></tr></thead>
<tbody>
<tr><td><b>M365 Business Basic</b></td><td>5x @kashealth.cz</td><td>270 $</td></tr>
<tr><td><b>GitHub Team</b></td><td>8 vývojářů</td><td>288 $</td></tr>
<tr><td><b>Domena kashealth.cz</b></td><td>WEDOS</td><td>~8 $</td></tr>
<tr style="background:rgba(99,102,241,.05)"><td><b>CELKEM</b></td><td><b>15 lidí</b></td><td style="color:var(--gn)"><b>~566 $</b></td></tr>
</tbody>
</table>
<div style="margin-top:8px;font-size:11px;color:var(--t3)">~1 520 Kč/měs &middot; 100 Kč/osobu &middot; volitelná kolaborace týmu</div>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px;padding:10px"><div class="sc-l"><b>EDPA governance nahrazuje:</b><br>Jira &#x2192; <code>.edpa/backlog/</code> (YAML v gitu)<br>Timesheety / Tempo &#x2192; EDPA odvozené hodiny<br>Roadmaps &#x2192; <code>/edpa:board</code> (lokálně)<br>Automation &#x2192; git hooks (+ volitelný <code>--with-ci</code>)</div></div>
<div class="s-note"><b>Žádné samostatné PM/timesheet nástroje &mdash; governance žije v gitu.</b> EDPA potřebuje jen <b>git lokálně</b>; Teams + GitHub jsou samostatná, volitelná volba týmu. GitHub volitelný.</div>
</div></div>`,

// 4: IDENTITY
`<div class="s-tag fade">Identita</div>
<div class="s-h1 fade d1">kashealth.cz — hybridní model</div>
<div class="cols fade d2">
<div class="col">
<div class="sc o" style="margin-bottom:10px;padding:12px"><div style="font-size:12px"><b>&#x26A0;&#xFE0F; Klíčové omezení:</b> Hosté v Teams <b>nemohou plánovat schůzky</b>. Hardcoded v Entra ID.</div></div>
<table>
<thead><tr><th>Účet</th><th>Role</th><th>Typ</th></tr></thead>
<tbody>
<tr style="background:rgba(99,102,241,.04)"><td><b>urbanek@kashealth.cz</b></td><td>Arch</td><td style="color:var(--gn)">Člen &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>tuma@kashealth.cz</b></td><td>DevSecOps</td><td style="color:var(--gn)">Člen &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>batek@kashealth.cz</b></td><td>PM/CVUT</td><td style="color:var(--gn)">Člen &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>pm@kashealth.cz</b></td><td>PM/MC</td><td style="color:var(--gn)">Člen &#x2713;</td></tr>
<tr><td>@cvut.cz</td><td>Dev/VaV</td><td style="color:var(--yl)">Guest</td></tr>
<tr><td>@partner.cz</td><td>Dev</td><td style="color:var(--yl)">Guest</td></tr>
</tbody>
</table>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px"><div class="sc-t">Vrstva 1 &middot; Plní členové</div><div class="sc-l">5 osob &middot; M365 Basic &middot; Plánují schůzky</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Vrstva 2 &middot; Sdílené kanály</div><div class="sc-l">B2B Direct Connect &middot; Bez přepínání tenantů</div></div>
<div class="sc y"><div class="sc-t">Vrstva 3 &middot; Guest fallback</div><div class="sc-l">Pokud IT nekooperuje &middot; Funkční, horší UX</div></div>
</div></div>`,

// 5: EDPA CORE
`<div class="s-tag fade">EDPA v${VERSION}</div>
<div class="s-h1 fade d1">Čas se neměří — odvozuje se</div>
<div class="qt fade d2">Člověk deklaruje kapacitu. Systém identifikuje work items, na nichž se podílel. Kapacita se rozpadne poměrově podle evidence.</div>
<div class="cols fade d3">
<div class="col">
<div class="fm">Score = JobSize x CW

DerivedHours = (Score / &#x2211;Scores) x Capacity

<b>Garance: &#x2211; DerivedHours = Capacity</b>
Vždy. Bez výjimky.</div>
<div class="s-p">Gated calculation: kreditujeme Story <code>Done</code> + Feature/Epic/Initiative gate transitions z git historie. CW je per-item normalizovaný podíl z evidence.</div>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-l"><b>Nikdo neloguje hodiny.</b> Výkaz je vedlejší produkt dodávky.</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-l"><b>Evidence z lokálního gitu.</b> Commity &#x2192; auto-detekce. PR signály volitelně přes CI.</div></div>
<div class="sc a"><div class="sc-l"><b>BankID podpis.</b> Frozen snapshot + BankID = právně silnější než papír.</div></div>
</div></div>`,

// 6: DUAL VIEW
`<div class="s-tag fade">Dual-View</div>
<div class="s-h1 fade d1">Dva pohledy, jeden dataset</div>
<div class="sg sg2 fade d2" style="margin-top:16px">
<div class="sc g" style="min-height:180px"><div class="sc-i">&#x1F464;</div><div class="sc-t">Per-Person</div>
<div style="font-size:14px;font-weight:600;color:var(--gn);margin-bottom:6px">Jak se kapacita člověka rozloží?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--gn);margin:6px 0">DerivedHours = (Score / &#x2211;Scores) x Capacity
Garance: &#x2211; = Capacity</div>
<div class="sc-l">&#x2192; <b>Výkaz per osoba</b> pro OP TAK</div></div>
<div class="sc c" style="min-height:180px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">Per-Item</div>
<div style="font-size:14px;font-weight:600;color:var(--cy);margin-bottom:6px">Kolik lidí a hodin stál item X?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--cy);margin:6px 0">ItemShare = DerivedHours[P] / &#x2211; DerivedHours[*]
Garance: &#x2211; podilu = 100%</div>
<div class="sc-l">&#x2192; <b>Nákladová karta</b> per deliverable</div></div>
</div>
<div class="s-note fade d3">Oba pohledy ze stejných dat (CW, JS, Capacity). Žádná duplikace, žádný konflikt.</div>`,

// 7: THREE LAYERS
`<div class="s-tag fade">Architektura</div>
<div class="s-h1 fade d1">Tři oddělené vrstvy</div>
<div class="sg sg3 fade d2" style="margin-top:16px">
<div class="sc a" style="min-height:170px"><div class="sc-i">&#x2699;&#xFE0F;</div><div class="sc-t">Operational Metadata</div><div class="sc-v" style="color:var(--ac2);font-size:14px">.edpa/backlog/ (YAML v gitu)</div><div class="sc-l" style="margin-top:6px">Živá delivery data &middot; Hierarchie &middot; Status &middot; Job Size &middot; WSJF</div></div>
<div class="sc c" style="min-height:170px"><div class="sc-i">&#x1F4CB;</div><div class="sc-t">Capacity Registry</div><div class="sc-v" style="color:var(--cy);font-size:14px">.edpa/config/ (YAML v repo)</div><div class="sc-l" style="margin-top:6px">Kapacita &middot; Role &middot; FTE &middot; Potvrzeno pri Iteration Planning</div></div>
<div class="sc g" style="min-height:170px"><div class="sc-i">&#x1F512;</div><div class="sc-t">Evidence &amp; Reporting</div><div class="sc-v" style="color:var(--gn);font-size:14px">/snapshots &middot; /reports &middot; /signed</div><div class="sc-l" style="margin-top:6px">Frozen snapshoty &middot; Výkazy &middot; BankID &middot; Immutable</div></div>
</div>
<div class="fade d3" style="margin-top:12px;text-align:center;font-size:12px;color:var(--t3)">Vše žije v gitu &#x2192; <code>.edpa/</code> je jediný zdroj pravdy pro backlog, kapacitu, FTE, derived hours i podpisy. GitHub volitelný.</div>`,

// 8: HIERARCHY
`<div class="s-tag fade">Hierarchie</div>
<div class="s-h1 fade d1">SAFe-like hierarchie v .edpa/backlog/</div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:13px;line-height:2;border-left-color:var(--ac)"><span style="color:var(--pk)">Initiative</span> (celý projekt)
  &#x2514;&#x2500;&#x2500; <span style="color:var(--ac2)">Epic</span> (strategický cíl, 6-9 měs.)
       &#x2514;&#x2500;&#x2500; <span style="color:var(--cy)">Feature</span> (vejde se do PI)
            &#x251C;&#x2500;&#x2500; <span style="color:var(--or)">Story</span> (dodáváno v Iteraci)
            &#x2502;    &#x2514;&#x2500;&#x2500; <span style="color:var(--yl)">Task</span> (technická práce)
            &#x2514;&#x2500;&#x2500; <span style="color:var(--rd)">Defect</span> (oprava, na úrovni Story)</div>
<div class="s-p"><b>WSJF = (<span style="color:var(--gn)">BV</span> + <span style="color:var(--or)">TC</span> + <span style="color:var(--cy)">RR&amp;OE</span>) / <span style="color:var(--yl)">JS</span></b> — nezávislý per úroveň, vrstvy se neporovnávají.</div>
<div class="s-p">Naming: <code>PI-2026-1.3</code> = 3. iterace v 1. PI roku 2026.</div>
</div>
<div class="col">
<table><thead><tr><th>Uroven</th><th>Job Size</th><th>Soubor</th></tr></thead><tbody>
<tr><td style="color:var(--pk)"><b>Initiative</b></td><td>1&ndash;100</td><td>initiatives/I-XXX.yaml</td></tr>
<tr><td style="color:var(--ac2)"><b>Epic</b></td><td>1&ndash;100</td><td>epics/E-XXX.yaml</td></tr>
<tr><td style="color:var(--cy)"><b>Feature</b></td><td>1&ndash;100</td><td>features/F-XXX.yaml</td></tr>
<tr><td style="color:var(--or)"><b>Story</b></td><td>1&ndash;100</td><td>stories/S-XXX.yaml</td></tr>
<tr><td style="color:var(--rd)"><b>Defect</b></td><td>1&ndash;100</td><td>defects/D-XXX.yaml</td></tr>
<tr><td style="color:var(--yl)"><b>Task</b></td><td>&#x2014;</td><td>Checklist</td></tr>
</tbody></table>
<div class="s-note" style="margin-top:8px">YAML soubory v gitu: <code>parent</code> reference tvoří hierarchii, validuje MCP <code>edpa_item_create</code>.</div>
</div></div>`,

// 9: EVIDENCE
`<div class="s-tag fade">Evidence detection</div>
<div class="s-h1 fade d1">Automatická detekce kontributorů</div>
<div class="cols fade d2">
<div class="col">
<table><thead><tr><th>Signal</th><th style="text-align:right">Signal weight</th></tr></thead><tbody>
<tr><td>Commit s S-/F-/E-/I-XXX</td><td style="text-align:right;color:var(--gn)"><b>4.00</b></td></tr>
<tr><td>PR reviewer</td><td style="text-align:right;color:var(--cy)"><b>2.17</b></td></tr>
<tr><td>Issue / PR comment</td><td style="text-align:right;color:var(--or)"><b>1.46</b></td></tr>
<tr><td><code>/contribute @osoba weight:X</code></td><td style="text-align:right;color:var(--ac2)"><b>explicit</b></td></tr>
</tbody></table>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-t">Additivní agregace</div><div class="sc-l">Signály se sčítají do <code>contribution_score</code>; CW je per-item normalizovaný podíl (&Sigma; = 1.0 na položce)</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Override</div><div class="sc-l"><code>/contribute @urbanek weight:0.6</code></div></div>
<div class="sc y" style="margin-bottom:8px"><div class="sc-t">Branch naming</div><div class="sc-l"><code>feature/S-200-omop-parser</code><br>CI blokuje PR bez reference</div></div>
<div class="sc o"><div class="sc-t">Commit &#x2260; cas</div><div class="sc-l">Commity = signál relevance, ne hodiny. AI mění patterns.</div></div>
<div class="sc p"><div class="sc-t">Signal calibrace</div><div class="sc-l">3 signal weights (commit_author 4.00, pr_reviewer 2.17, issue_comment 1.46) &middot; Monte Carlo na 1000 syntetických scénářích</div></div>
</div></div>`,

// 10: SKILLS
`<div class="s-tag fade">AI Agent Skills</div>
<div class="s-h1 fade d1">4 composable EDPA skills</div>
<div class="s-sub fade d2">Claude Code skills = automatizace governance. Agent v terminálu rozumí EDPA a provádí ho za vás.</div>
<div class="sg sg2 fade d3">
<div class="sc a" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F3D7;&#xFE0F;</div><div><div style="font-weight:600">/edpa:setup</div><div class="sc-l">~450 tokenu &middot; "Set up governance for my project"<br>Vendoruje engine do <code>.edpa/engine/</code>, seeduje <code>.edpa/config/</code>, instaluje git hooks</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x26A1;</div><div><div style="font-weight:600">/edpa:engine</div><div class="sc-l">~760 tokenu &middot; "Close iteration PI-2026-1.3"<br>Evidence gathering, EDPA výpočet, invariant validace</div></div></div>
<div class="sc g" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F4C4;</div><div><div style="font-weight:600">/edpa:reports</div><div class="sc-l">~505 tokenu &middot; "Generate reports"<br>MD/JSON/XLSX výkazy, frozen snapshots, per-item alokace</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F52C;</div><div><div style="font-weight:600">/edpa:autocalib</div><div class="sc-l">~625 tokenu &middot; "Calibrate CW heuristics"<br>Karpathy autoresearch: 50 experimentů overnight, MAD optimalizace</div></div></div>
</div>
<div class="s-note fade d4"><b>26+ platforem:</b> Claude Code (nativni), Codex CLI, Gemini CLI, Cursor, Windsurf, Aider... Skills žijí v repo — každý člen týmu je má automaticky.</div>`,

// 11: HOW SKILLS WORK
`<div class="s-tag fade">Jak to funguje</div>
<div class="s-h1 fade d1">Denní workflow s EDPA skills</div>
<div class="sg fade d2" style="gap:8px">
<div class="sc g" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--gn);width:30px">1</div><div><div style="font-weight:500">Tým pracuje normálně</div><div class="sc-l">Kódují na <code>feature/S-200-omop-parser</code> branchích. PR, review, merge. Nic navíc.</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--cy);width:30px">2</div><div><div style="font-weight:500">Git hooks hlídají evidence lokálně</div><div class="sc-l">Pre-commit hook ověří <code>S-/F-/E-XXX</code> referenci &#x2192; evidence žije v git historii. Žádný ruční zásah.</div></div></div>
<div class="sc a" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--ac2);width:30px">3</div><div><div style="font-weight:500">Konec iterace: "Close iteration PI-2026-1.3"</div><div class="sc-l">Claude Code spusti <b>/edpa:engine</b> &#x2192; načte lokální git evidence &#x2192; spočítá Score &#x2192; odvodí hodiny &#x2192; zvaliduje invarianty.</div></div></div>
