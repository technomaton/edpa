---
import '../../styles/global.css';
import '../../styles/presentation.css';
import Header from '../../components/Header.astro';

const title = 'EDPA Prezentace — Generic';
const description = 'EDPA v2.2 governance prezentace — Evidence-Driven Proportional Allocation pro libovolny tym.';
---
<!doctype html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | EDPA v2.2</title>
</head>
<body class="presentation-body">
  <Header currentPath="/presentation/" />
  <div class="deck" id="deck"></div>
  <div class="pres-nav">
    <div class="nav-l"><span class="logo">EDPA v2.2</span><span class="nav-label">&middot; Open Source Governance</span></div>
    <div class="nav-c" id="dots"></div>
    <div class="nav-r">
      <button class="pres-btn" id="btnPrev">&larr; Zpet</button>
      <span class="pg" id="pgN">1/20</span>
      <button class="pres-btn" id="btnNext">Dale &rarr;</button>
    </div>
  </div>

<script>
import { initSlideDeck } from '../../scripts/slide-engine';

const S=[

// 0: TITLE
`<div style="text-align:center;max-width:850px;margin:0 auto">
<div class="s-tag fade">Vas projekt &middot; Evidence-driven governance pro vas tym</div>
<div class="s-h1 fade d1" style="font-size:44px;background:linear-gradient(135deg,var(--ac2),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent">Kompletni governance reseni</div>
<div class="fade d2" style="font-size:18px;color:var(--t2);margin:16px 0 6px">EDPA — Evidence-Driven Proportional Allocation</div>
<div class="fade d3" style="font-size:14px;color:var(--t3);font-style:italic;margin-bottom:24px">Capacity derivation from delivery evidence</div>
<div class="sg sg4 fade d4" style="max-width:700px;margin:0 auto">
<div class="sc a" style="text-align:center;padding:12px"><div class="sc-t">Tooling</div><div style="font-size:12px;color:var(--ac2)">Teams + GitHub</div></div>
<div class="sc c" style="text-align:center;padding:12px"><div class="sc-t">Metodika</div><div style="font-size:12px;color:var(--cy)">EDPA v2.2</div></div>
<div class="sc g" style="text-align:center;padding:12px"><div class="sc-t">Skills</div><div style="font-size:12px;color:var(--gn)">4 composable</div></div>
<div class="sc y" style="text-align:center;padding:12px"><div class="sc-t">Template</div><div style="font-size:12px;color:var(--yl)">GitHub repo</div></div>
</div>
<div class="fade d5" style="margin-top:20px;font-size:12px;color:var(--t3)">EDPA v2.2 — Open Source</div>
</div>`,

// 1: WHAT WE DELIVER
`<div class="s-tag fade">Obsah prezentace</div>
<div class="s-h1 fade d1">Co dnes predkladame</div>
<div class="s-sub fade d2">Kompletni governance reseni pro projekt — od toolingu pres metodiku po automatizaci. Vse v jednom GitHub repo template.</div>
<div class="sg sg5 fade d3">
<div class="sc a" style="min-height:140px"><div class="sc-i">&#x1F4AC;</div><div class="sc-t">1. Tooling</div><div class="sc-l">Teams + GitHub<br>Minimalni naklady<br>0 Jira</div></div>
<div class="sc c" style="min-height:140px"><div class="sc-i">&#x1F511;</div><div class="sc-t">2. Identita</div><div class="sc-l">Vase domena<br>Clenove + guests<br>Hybridni model</div></div>
<div class="sc g" style="min-height:140px"><div class="sc-i">&#x26A1;</div><div class="sc-t">3. EDPA</div><div class="sc-l">Bez timesheetu<br>Dual-view CW<br>BankID audit</div></div>
<div class="sc y" style="min-height:140px"><div class="sc-i">&#x1F916;</div><div class="sc-t">4. AI Skills</div><div class="sc-l">4 composable<br>26+ platforem<br>Auto-kalibrace</div></div>
<div class="sc o" style="min-height:140px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">5. Template</div><div class="sc-l">GitHub repo<br>30 souboru, 24KB<br>Okamzite pouzitelne</div></div>
</div>`,

// 2: PROBLEM
`<div class="s-tag fade">Kontext</div>
<div class="s-h1 fade d1">Proc potrebujete vlastni reseni</div>
<div class="sg sg2 fade d2">
<div class="sc o"><div class="sc-i">&#x1F500;</div><div class="sc-l"><b>Ruzne tenanty</b><br>Vice organizaci = prepinani tenantu, ztracene notifikace, fragmentovana komunikace.</div></div>
<div class="sc o"><div class="sc-i">&#x1F512;</div><div class="sc-l"><b>Zavislost na IT</b><br>Kazda zmena opravneni = zadost na IT oddeleni. Tydny cekani.</div></div>
<div class="sc o"><div class="sc-i">&#x1F4DD;</div><div class="sc-l"><b>Rucni timesheets</b><br>Subjektivni, administrativne narocne, neauditovatelne, nikdo je nema rad.</div></div>
<div class="sc o"><div class="sc-i">&#x1F504;</div><div class="sc-l"><b>Riziko migrace</b><br>Pri spin-offu bude nutne vse presunout. Cim pozdeji, tim drazsi.</div></div>
</div>
<div class="qt fade d3">Cil: Centralni stack vlastneny projektem od dne 1. Automatizovane vykazovani. Zadna budouci migrace.</div>`,

// 3: TOOLING
`<div class="s-tag fade">Tooling stack</div>
<div class="s-h1 fade d1">Teams + GitHub = kompletni stack</div>
<div class="cols fade d2">
<div class="col">
<table>
<thead><tr><th>Nastroj</th><th>Plan</th><th>Naklady</th></tr></thead>
<tbody>
<tr><td><b>M365 Business Basic</b></td><td>Clenove tymu</td><td>6 $/uzivatel/mes</td></tr>
<tr><td><b>GitHub Team</b></td><td>Vyvojari</td><td>4 $/uzivatel/mes</td></tr>
<tr><td><b>Vlastni domena</b></td><td>Registrator</td><td>~1 $/mes</td></tr>
<tr style="background:rgba(99,102,241,.05)"><td><b>CELKEM</b></td><td><b>Vas tym</b></td><td style="color:var(--gn)"><b>Minimalni naklady</b></td></tr>
</tbody>
</table>
<div style="margin-top:8px;font-size:11px;color:var(--t3)">Radove stovky Kc/mesic za cely tym</div>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px;padding:10px"><div class="sc-l"><b>GitHub nahrazuje:</b><br>Jira &#x2192; Issues + Projects<br>Confluence &#x2192; Wiki + Pages<br>Tempo &#x2192; EDPA (odvozene hodiny)<br>Roadmaps &#x2192; Projects Roadmap<br>Automation &#x2192; GitHub Actions</div></div>
<div class="s-note"><b>0 Jira, 0 Confluence.</b> GitHub-only governance s sub-issues (8 urovni), issue types, custom fields.</div>
</div></div>`,

// 4: IDENTITY
`<div class="s-tag fade">Identita</div>
<div class="s-h1 fade d1">Vlastni domena — hybridni model</div>
<div class="cols fade d2">
<div class="col">
<div class="sc o" style="margin-bottom:10px;padding:12px"><div style="font-size:12px"><b>&#x26A0;&#xFE0F; Klicove omezeni:</b> Hoste v Teams <b>nemohou planovat schuzky</b>. Hardcoded v Entra ID.</div></div>
<table>
<thead><tr><th>Ucet</th><th>Role</th><th>Typ</th></tr></thead>
<tbody>
<tr style="background:rgba(99,102,241,.04)"><td><b>lead@vasedomena.cz</b></td><td>Lead Architect</td><td style="color:var(--gn)">Clen &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>devops@vasedomena.cz</b></td><td>DevSecOps</td><td style="color:var(--gn)">Clen &#x2713;</td></tr>
<tr style="background:rgba(99,102,241,.04)"><td><b>pm@vasedomena.cz</b></td><td>Project Manager</td><td style="color:var(--gn)">Clen &#x2713;</td></tr>
<tr><td>@partnera.cz</td><td>Developer</td><td style="color:var(--yl)">Guest</td></tr>
<tr><td>@partnerb.cz</td><td>Developer</td><td style="color:var(--yl)">Guest</td></tr>
</tbody>
</table>
</div>
<div class="col">
<div class="sc a" style="margin-bottom:8px"><div class="sc-t">Vrstva 1 &middot; Plni clenove</div><div class="sc-l">Kmenovy tym &middot; M365 Basic &middot; Planuji schuzky</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Vrstva 2 &middot; Sdilene kanaly</div><div class="sc-l">B2B Direct Connect &middot; Bez prepinani tenantu</div></div>
<div class="sc y"><div class="sc-t">Vrstva 3 &middot; Guest fallback</div><div class="sc-l">Pokud IT nekooperuje &middot; Funkcni, horsi UX</div></div>
</div></div>`,

// 5: EDPA CORE
`<div class="s-tag fade">EDPA v2.2</div>
<div class="s-h1 fade d1">Cas se nemeri — odvozuje se</div>
<div class="qt fade d2">Clovek deklaruje kapacitu. System identifikuje work items, na nichz se podilel. Kapacita se rozpadne pomerove podle evidence.</div>
<div class="cols fade d3">
<div class="col">
<div class="fm">Score = JobSize x CW x RS

DerivedHours = (Score / &#x2211;Scores) x Capacity

<b>Garance: &#x2211; DerivedHours = Capacity</b>
Vzdy. Bez vyjimky.</div>
<div class="s-p">Dve varianty: <code>JS x CW</code> (provozni) a <code>JS x CW x RS</code> (auditni)</div>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-l"><b>Nikdo neloguje hodiny.</b> Vykaz je vedlejsi produkt dodavky.</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-l"><b>Evidence z GitHubu.</b> Commity, PR, reviews, comments &#x2192; auto-detekce.</div></div>
<div class="sc a"><div class="sc-l"><b>BankID podpis.</b> Frozen snapshot + BankID = pravne silnejsi nez papir.</div></div>
</div></div>`,

// 6: DUAL VIEW
`<div class="s-tag fade">Dual-View</div>
<div class="s-h1 fade d1">Dva pohledy, jeden dataset</div>
<div class="sg sg2 fade d2" style="margin-top:16px">
<div class="sc g" style="min-height:180px"><div class="sc-i">&#x1F464;</div><div class="sc-t">Per-Person</div>
<div style="font-size:14px;font-weight:600;color:var(--gn);margin-bottom:6px">Jak se kapacita cloveka rozlozi?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--gn);margin:6px 0">DerivedHours = (Score / &#x2211;Scores) x Capacity
Garance: &#x2211; = Capacity</div>
<div class="sc-l">&#x2192; <b>Vykaz per osoba</b> pro audit</div></div>
<div class="sc c" style="min-height:180px"><div class="sc-i">&#x1F4E6;</div><div class="sc-t">Per-Item</div>
<div style="font-size:14px;font-weight:600;color:var(--cy);margin-bottom:6px">Kolik lidi a hodin stal item X?</div>
<div class="fm" style="font-size:11px;border-left-color:var(--cy);margin:6px 0">ItemShare = DerivedHours[P] / &#x2211; DerivedHours[*]
Garance: &#x2211; podilu = 100%</div>
<div class="sc-l">&#x2192; <b>Nakladova karta</b> per deliverable</div></div>
</div>
<div class="s-note fade d3">Oba pohledy ze stejnych dat (CW, JS, Capacity). Zadna duplikace, zadny konflikt.</div>`,

// 7: THREE LAYERS
`<div class="s-tag fade">Architektura</div>
<div class="s-h1 fade d1">Tri oddelene vrstvy</div>
<div class="sg sg3 fade d2" style="margin-top:16px">
<div class="sc a" style="min-height:170px"><div class="sc-i">&#x2699;&#xFE0F;</div><div class="sc-t">Operational Metadata</div><div class="sc-v" style="color:var(--ac2);font-size:14px">GitHub Issues + Projects</div><div class="sc-l" style="margin-top:6px">Ziva delivery data &middot; Hierarchie &middot; Status &middot; Job Size &middot; WSJF</div></div>
<div class="sc c" style="min-height:170px"><div class="sc-i">&#x1F4CB;</div><div class="sc-t">Capacity Registry</div><div class="sc-v" style="color:var(--cy);font-size:14px">YAML config v repo</div><div class="sc-l" style="margin-top:6px">Kapacita &middot; Role &middot; FTE &middot; Potvrzeno pri Iteration Planning</div></div>
<div class="sc g" style="min-height:170px"><div class="sc-i">&#x1F512;</div><div class="sc-t">Evidence &amp; Reporting</div><div class="sc-v" style="color:var(--gn);font-size:14px">/snapshots &middot; /reports &middot; /signed</div><div class="sc-l" style="margin-top:6px">Frozen snapshoty &middot; Vykazy &middot; BankID &middot; Immutable</div></div>
</div>
<div class="fade d3" style="margin-top:12px;text-align:center;font-size:12px;color:var(--t3)">GitHub <b>neni</b> source of truth pro: kapacitu, FTE, derived hours, podpisy &#x2192; ty ziji v evidence vrstve.</div>`,

// 8: HIERARCHY
`<div class="s-tag fade">Hierarchie</div>
<div class="s-h1 fade d1">SAFe-like hierarchie v GitHubu</div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:13px;line-height:2;border-left-color:var(--ac)"><span style="color:var(--pk)">Initiative</span> (cely projekt)
  &#x2514;&#x2500;&#x2500; <span style="color:var(--ac2)">Epic</span> (strategicky cil, 6-9 mes.)
       &#x2514;&#x2500;&#x2500; <span style="color:var(--cy)">Feature</span> (vejde se do PI)
            &#x2514;&#x2500;&#x2500; <span style="color:var(--gn)">Story</span> (dodavano v Iteraci)
                 &#x2514;&#x2500;&#x2500; <span style="color:var(--yl)">Task</span> (technicka prace)</div>
<div class="s-p"><b>WSJF = (BV + TC + RR) / JS</b> — nezavisly per uroven, vrstvy se neporovnavaji.</div>
<div class="s-p">Naming: <code>PI-2026-1.3</code> = 3. iterace v 1. PI roku 2026.</div>
</div>
<div class="col">
<table><thead><tr><th>Uroven</th><th>JS max</th><th>GitHub</th></tr></thead><tbody>
<tr><td style="color:var(--pk)"><b>Initiative</b></td><td>&#x2014;</td><td>Top-level issue</td></tr>
<tr><td style="color:var(--ac2)"><b>Epic</b></td><td>20</td><td>Sub-issue</td></tr>
<tr><td style="color:var(--cy)"><b>Feature</b></td><td>13</td><td>Sub-issue</td></tr>
<tr><td style="color:var(--gn)"><b>Story</b></td><td>8 / 5</td><td>Sub-issue</td></tr>
<tr><td style="color:var(--yl)"><b>Task</b></td><td>&#x2014;</td><td>Checklist</td></tr>
</tbody></table>
<div class="s-note" style="margin-top:8px">GitHub sub-issues (GA 04/2025): 8 urovni, issue types, custom fields.</div>
</div></div>`,

// 9: EVIDENCE
`<div class="s-tag fade">Evidence detection</div>
<div class="s-h1 fade d1">Automaticka detekce kontributoru</div>
<div class="cols fade d2">
<div class="col">
<table><thead><tr><th>GitHub signal</th><th style="text-align:right">Body</th><th style="text-align:right">CW</th></tr></thead><tbody>
<tr><td>Assignee na issue</td><td style="text-align:right"><b>+4</b></td><td style="text-align:right;color:var(--gn)">1.0</td></tr>
<tr><td><code>/contribute</code> prikaz</td><td style="text-align:right"><b>+3</b></td><td style="text-align:right;color:var(--cy)">0.6</td></tr>
<tr><td>PR author &#x2192; item</td><td style="text-align:right"><b>+2</b></td><td style="text-align:right;color:var(--cy)">0.6</td></tr>
<tr><td>Commit s S-/F-/E-XXX</td><td style="text-align:right"><b>+1</b></td><td style="text-align:right;color:var(--yl)">0.25</td></tr>
<tr><td>PR reviewer</td><td style="text-align:right"><b>+1</b></td><td style="text-align:right;color:var(--yl)">0.25</td></tr>
<tr><td>Issue comment</td><td style="text-align:right"><b>+0.5</b></td><td style="text-align:right;color:var(--or)">0.15</td></tr>
</tbody></table>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-t">Threshold</div><div class="sc-l">Evidence Score &#x2265; 1.0 &#x2192; relevantni kontributor</div></div>
<div class="sc c" style="margin-bottom:8px"><div class="sc-t">Override</div><div class="sc-l"><code>/contribute @username weight:0.6</code></div></div>
<div class="sc y" style="margin-bottom:8px"><div class="sc-t">Branch naming</div><div class="sc-l"><code>feature/S-200-omop-parser</code><br>CI blokuje PR bez reference</div></div>
<div class="sc o"><div class="sc-t">Commit &#x2260; cas</div><div class="sc-l">Commity = signal relevance, ne hodiny. AI meni patterns.</div></div>
</div></div>`,

// 10: SKILLS
`<div class="s-tag fade">AI Agent Skills</div>
<div class="s-h1 fade d1">4 composable EDPA skills</div>
<div class="s-sub fade d2">Claude Code skills = automatizace governance. Agent v terminalu rozumi EDPA a provadi ho za vas.</div>
<div class="sg sg2 fade d3">
<div class="sc a" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F3D7;&#xFE0F;</div><div><div style="font-weight:600">edpa-setup</div><div class="sc-l">~450 tokenu &middot; "Set up governance for my project"<br>GitHub Projects, capacity registry, CW heuristics, branch naming</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x26A1;</div><div><div style="font-weight:600">edpa-engine</div><div class="sc-l">~760 tokenu &middot; "Close iteration PI-2026-1.3"<br>Evidence gathering, EDPA vypocet, invariant validace</div></div></div>
<div class="sc g" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F4C4;</div><div><div style="font-weight:600">edpa-reports</div><div class="sc-l">~505 tokenu &middot; "Generate reports"<br>MD/JSON/XLSX vykazy, frozen snapshots, per-item alokace</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center"><div style="font-size:28px">&#x1F52C;</div><div><div style="font-weight:600">edpa-autocalib</div><div class="sc-l">~625 tokenu &middot; "Calibrate CW heuristics"<br>Karpathy autoresearch: 50 experimentu overnight, MAD optimalizace</div></div></div>
</div>
<div class="s-note fade d4"><b>26+ platforem:</b> Claude Code (nativni), Codex CLI, Gemini CLI, Cursor, Windsurf, Aider... Skills ziji v repo — kazdy clen tymu je ma automaticky.</div>`,

// 11: HOW SKILLS WORK
`<div class="s-tag fade">Jak to funguje</div>
<div class="s-h1 fade d1">Denni workflow s EDPA skills</div>
<div class="sg fade d2" style="gap:8px">
<div class="sc g" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--gn);width:30px">1</div><div><div style="font-weight:500">Tym pracuje normalne</div><div class="sc-l">Koduji na <code>feature/S-200-omop-parser</code> branchich. PR, review, merge. Nic navic.</div></div></div>
<div class="sc c" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--cy);width:30px">2</div><div><div style="font-weight:500">CI sbira evidence automaticky</div><div class="sc-l">Branch naming check &#x2192; evidence detection &#x2192; contributor metadata na issues. Zadny rucni zasah.</div></div></div>
<div class="sc a" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--ac2);width:30px">3</div><div><div style="font-weight:500">Konec iterace: "Close iteration PI-2026-1.3"</div><div class="sc-l">Claude Code spusti <b>edpa-engine</b> &#x2192; stahne evidence &#x2192; spocita Score &#x2192; odvodi hodiny &#x2192; zvaliduje invarianty.</div></div></div>
<div class="sc y" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--yl);width:30px">4</div><div><div style="font-weight:500">"Generate reports"</div><div class="sc-l"><b>edpa-reports</b> &#x2192; MD/JSON vykazy per osoba + per-item alokace + frozen snapshot + Excel. 30 sekund.</div></div></div>
<div class="sc o" style="display:flex;gap:14px;align-items:center;padding:12px"><div style="font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;color:var(--or);width:30px">5</div><div><div style="font-weight:500">BankID podpis</div><div class="sc-l">Clen zkontroluje vykaz &#x2192; podepise BankID &#x2192; ulozeno v <code>/signed/</code>. Pravne silnejsi nez papir.</div></div></div>
</div>`,

// 12: REPO TEMPLATE
`<div class="s-tag fade">GitHub Template</div>
<div class="s-h1 fade d1">30 souboru, okamzite pouzitelne</div>
<div class="cols fade d2">
<div class="col">
<div class="fm" style="font-size:10px;line-height:1.7;border-left-color:var(--ac)"><b>.claude/skills/edpa-governance/</b>
&#x251C;&#x2500;&#x2500; edpa-setup/SKILL.md
&#x251C;&#x2500;&#x2500; edpa-engine/SKILL.md
&#x251C;&#x2500;&#x2500; edpa-reports/SKILL.md
&#x251C;&#x2500;&#x2500; edpa-autocalib/SKILL.md
&#x251C;&#x2500;&#x2500; references/ (7 souboru)
&#x251C;&#x2500;&#x2500; scripts/evaluate_cw.py
&#x251C;&#x2500;&#x2500; examples/capacity-example.yaml
&#x2514;&#x2500;&#x2500; plugin.json

<b>.github/</b>
&#x251C;&#x2500;&#x2500; workflows/branch-naming.yml
&#x251C;&#x2500;&#x2500; ISSUE_TEMPLATE/ (epic, feature, story)
&#x2514;&#x2500;&#x2500; PULL_REQUEST_TEMPLATE.md

<b>config/</b> (capacity, heuristics, project)
<b>docs/</b> methodology.md
<b>data/</b> ground_truth.yaml
<b>snapshots/</b> + <b>reports/</b> (auto-generated)</div>
</div>
<div class="col">
<div class="sc g" style="margin-bottom:8px"><div class="sc-t">Pro vas projekt</div><div class="sc-l">
