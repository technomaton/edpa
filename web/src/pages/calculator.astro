---
import Layout from '../layouts/Layout.astro';
import { edpa, itemView } from '../lib/edpa-engine';
import { people, items, iterations } from '../lib/demo-data-walkthrough';

const defaultHpw = 40;
const defaultIterPerPI = 5;
const iter = iterations[0];
const results = people.map(p => edpa(p.id, iter.id, people, items, 'simple')!);
const itemResults = items.map(w => itemView(w.id, iter.id, people, items, 'simple')!);
---

<Layout title="Kalkulátor EDPA" description="EDPA krok po kroku — konkrétní příklad výpočtu s reálnými čísly. Od vstupů po odvozené hodiny.">

  <!-- Hero -->
  <section class="calc-hero section">
    <div class="container" style="text-align:center;">
      <p class="tag">Kalkulátor</p>
      <h1 class="calc-headline">EDPA krok po kroku</h1>
      <p class="calc-subtitle">
        Konkrétní příklad výpočtu s reálnými čísly.<br>
        Od vstupů po odvozené hodiny — ověřitelné ručně.
      </p>
      <div class="mode-switch" id="modeSwitch">
        <button class="mode-btn active" data-mode="simple">Simple: JS &times; CW</button>
        <button class="mode-btn" data-mode="full">Full: JS &times; CW &times; RS</button>
      </div>
    </div>
  </section>

  <!-- Config panel -->
  <section class="section" style="padding-top:0;padding-bottom:0;">
    <div class="container">
      <div class="card config-panel fade-in">
        <div class="tag">Konfigurace</div>
        <div class="config-grid">
          <div class="config-item">
            <label for="cfgHpw">Hodin v týdnu</label>
            <input type="number" id="cfgHpw" value={defaultHpw} min="10" max="60" step="5" class="config-input">
          </div>
          <div class="config-item">
            <label for="cfgIterPI">Iterací v PI</label>
            <input type="number" id="cfgIterPI" value={defaultIterPerPI} min="2" max="12" step="1" class="config-input">
          </div>
          <div class="config-item">
            <label>Kapacita na iteraci</label>
            <span class="config-derived" id="cfgCapSummary">
              {people.map(p => `${p.name} ${p.capacity}h`).join(' · ')}
            </span>
          </div>
          <div class="config-item">
            <label>PI celkem</label>
            <span class="config-derived" id="cfgPISummary">
              {people.map(p => `${p.name} ${p.capacity * defaultIterPerPI}h`).join(' · ')}
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 01: Inputs -->
  <section class="section calc-section" id="inputs">
    <div class="container">
      <div class="calc-step fade-in">
        <span class="step-number">01</span>
        <p class="tag">Vstupy</p>
        <h2 class="section-title">Tým a work items</h2>
        <p class="calc-desc">
          Tři lidé s různou kapacitou pracují na čtyřech Stories v jedné iteraci.
          Každý člověk má různou míru zapojení (CW) na různých itemech.
        </p>
      </div>

      <div class="grid grid-3 calc-people fade-in" id="peopleCards">
        {people.map(p => (
          <div class={`card ${p.role === 'Architect' ? 'accent' : p.role === 'Developer' ? 'cyan' : 'yellow'}`}>
            <div class="person-name">{p.name}</div>
            <div class="person-role">{p.role}</div>
            <div class="person-stats">
              <span>{p.fte} FTE</span>
              <span class="person-cap" data-fte={p.fte}>{p.capacity}h / iterace</span>
            </div>
          </div>
        ))}
      </div>

      <div class="card fade-in" style="margin-top:20px;">
        <div class="tag">Work items &amp; Contribution Weight (CW)</div>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>Item</th>
                <th>JS</th>
                <th>Alice (Arch)</th>
                <th>Bob (Dev)</th>
                <th>Carol (PM)</th>
              </tr>
            </thead>
            <tbody>
              {items.map(w => (
                <tr>
                  <td><code>{w.id}</code> {w.title}</td>
                  <td class="td-js">{w.js}</td>
                  {people.map(p => {
                    const cn = w.contributions.find(c => c.personId === p.id);
                    return (
                      <td class={cn ? 'td-cw-active' : 'td-cw-empty'}>
                        {cn ? (
                          <span>
                            <span class="cw-val">{cn.cw}</span>
                            <span class="rs-val" data-rs={cn.rs}> / {cn.rs}</span>
                          </span>
                        ) : '—'}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="note" style="margin-top:12px;">
          CW = Contribution Weight (míra zapojení). RS = Relevance Signal (ve Full módu).
          Zobrazeno jako <span class="cw-val">CW</span> / <span class="rs-val">RS</span>.
        </div>
      </div>

      <div class="formula fade-in" style="margin-top:20px;" id="formulaBox">
        <strong>Score</strong> = JobSize &times; CW
        <br><strong>DerivedHours</strong> = (Score / &Sigma;Scores) &times; Capacity
      </div>
    </div>
  </section>

  <!-- Step 02: Score -->
  <section class="section calc-section" id="score">
    <div class="container">
      <div class="calc-step fade-in">
        <span class="step-number">02</span>
        <p class="tag">Score</p>
        <h2 class="section-title">Výpočet skóre</h2>
        <p class="calc-desc">
          Pro každý pár (osoba, item) vynásobíme JobSize &times; CW.
          Výsledkem je surový Score, který určuje relativní podíl na kapacitě.
        </p>
      </div>

      <div class="grid grid-3 fade-in" id="scoreCards">
        {results.map(r => (
          <div class={`card ${r.person.role === 'Architect' ? 'accent' : r.person.role === 'Developer' ? 'cyan' : 'yellow'}`}>
            <div class="person-name">{r.person.name}</div>
            <div class="person-role">{r.person.role} &middot; <span class="cap-display">{r.person.capacity}h</span></div>
            <table class="score-table">
              <thead>
                <tr><th>Item</th><th>JS</th><th>CW</th><th class="rs-col">RS</th><th>Score</th></tr>
              </thead>
              <tbody>
                {r.items.map(x => (
                  <tr>
                    <td><code>{x.id}</code></td>
                    <td class="td-js">{x.js}</td>
                    <td class="td-cw">{x.cw}</td>
                    <td class="td-rs rs-col">{x.rs}</td>
                    <td class="td-score">{x.score.toFixed(2)}</td>
                  </tr>
                ))}
                <tr class="total-row">
                  <td colspan="3" class="rs-hide-span">Celkem</td>
                  <td colspan="4" class="rs-show-span" style="display:none;">Celkem</td>
                  <td></td>
                  <td class="td-score total-score">&Sigma; {r.totalScore.toFixed(2)}</td>
                </tr>
              </tbody>
            </table>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Step 03: Per-Person -->
  <section class="section calc-section" id="per-person">
    <div class="container">
      <div class="calc-step fade-in">
        <span class="step-number">03</span>
        <p class="tag">Per-Person</p>
        <h2 class="section-title">Odvozené hodiny</h2>
        <p class="calc-desc">
          Každý Score vydělíme celkovým součtem a vynásobíme kapacitou.
          Výsledek: kolik hodin člověk strávil na každém itemu.
        </p>
      </div>

      <div id="personCards">
        {results.map(r => (
          <div class={`card fade-in ${r.person.role === 'Architect' ? 'accent' : r.person.role === 'Developer' ? 'cyan' : 'yellow'}`} style="margin-bottom:20px;">
            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
              <div>
                <span class="person-name">{r.person.name}</span>
                <span class="person-role" style="margin-left:8px;">{r.person.role}</span>
              </div>
              <div class="guarantee-badge">
                <span class="guarantee-check">&check;</span>
                &Sigma; = {r.totalHours.toFixed(1)}h = {r.person.capacity}h
              </div>
            </div>
            <div class="table-scroll">
              <table>
                <thead>
                  <tr><th>Item</th><th>Score</th><th>Výpočet</th><th>Ratio</th><th>Hours</th><th></th></tr>
                </thead>
                <tbody>
                  {r.items.map(x => {
                    const pct = x.ratio * 100;
                    return (
                      <tr>
                        <td><code>{x.id}</code> {x.title}</td>
                        <td class="td-score">{x.score.toFixed(2)}</td>
                        <td class="td-computation">
                          {x.score.toFixed(2)} / {r.totalScore.toFixed(2)} &times; {r.person.capacity}
                        </td>
                        <td>{pct.toFixed(1)}%</td>
                        <td class="td-hours">{x.hours.toFixed(1)}h</td>
                        <td style="width:100px;">
                          <div class="bar-bg">
                            <div class="bar-fill" style={`width:${pct}%`}></div>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                  <tr class="total-row">
                    <td>Celkem</td>
                    <td class="td-score">{r.totalScore.toFixed(2)}</td>
                    <td></td>
                    <td>100%</td>
                    <td class="td-hours total-hours">{r.totalHours.toFixed(1)}h</td>
                    <td></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Step 04: Per-Item -->
  <section class="section calc-section" id="per-item">
    <div class="container">
      <div class="calc-step fade-in">
        <span class="step-number">04</span>
        <p class="tag">Per-Item</p>
        <h2 class="section-title">Kolik stály jednotlivé položky?</h2>
        <p class="calc-desc">
          Stejná data, jiný pohled. Pro každý item vidíme, kdo a kolik hodin přispěl.
          Podíly se vždy sečtou na 100 %.
        </p>
      </div>

      <div class="grid grid-2 fade-in" id="itemCards">
        {itemResults.map(ir => (
          <div class="card green">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
              <div>
                <code style="color:var(--gn);font-weight:600;">{ir.item.id}</code>
                <span style="margin-left:6px;">{ir.item.title}</span>
              </div>
              <span class="badge badge-yellow">JS {ir.item.js}</span>
            </div>
            <table class="item-table">
              <thead>
                <tr><th>Osoba</th><th>Role</th><th>CW</th><th>Hours</th><th>Podíl</th><th></th></tr>
              </thead>
              <tbody>
                {ir.contributors.map(c => {
                  const share = ir.totalHours > 0 ? (c.hours / ir.totalHours * 100) : 0;
                  return (
                    <tr>
                      <td>{c.person.name}</td>
                      <td class="td-role">{c.person.role}</td>
                      <td class="td-cw">{c.cw}</td>
                      <td class="td-hours">{c.hours.toFixed(1)}h</td>
                      <td>{share.toFixed(1)}%</td>
                      <td style="width:80px;">
                        <div class="bar-bg">
                          <div class="bar-fill bar-green" style={`width:${share}%`}></div>
                        </div>
                      </td>
                    </tr>
                  );
                })}
                <tr class="total-row">
                  <td colspan="3">Celkem</td>
                  <td class="td-hours">{ir.totalHours.toFixed(1)}h</td>
                  <td>100%</td>
                  <td></td>
                </tr>
              </tbody>
            </table>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Step 05: Guarantee -->
  <section class="section calc-section" id="guarantee">
    <div class="container">
      <div class="calc-step fade-in">
        <span class="step-number">05</span>
        <p class="tag">Garance</p>
        <h2 class="section-title">Matematická garance</h2>
      </div>

      <div class="grid grid-3 fade-in" id="guaranteeCards">
        {results.map(r => (
          <div class={`card ${r.ok ? 'green' : ''}`} style="text-align:center;">
            <div class="person-name">{r.person.name}</div>
            <div class="guarantee-big">
              <span class="guarantee-check-big">&check;</span>
            </div>
            <div class="guarantee-eq">
              <span class="guarantee-sum">&Sigma; {r.totalHours.toFixed(1)}h</span>
              <span class="guarantee-equals">=</span>
              <span class="guarantee-cap">{r.person.capacity}h</span>
            </div>
            <div class="guarantee-label">Capacity</div>
          </div>
        ))}
      </div>

      <div class="formula fade-in" style="margin-top:24px;text-align:center;font-size:15px;">
        &Sigma; DerivedHours = Capacity — vždy, bez výjimky.
        <br><span style="font-size:12px;color:var(--t3);">Proporcionální alokace garantuje, že součet poměrů = 1.0 a součet hodin = kapacita.</span>
      </div>

      <div class="cta-box fade-in">
        <p>Chcete vidět EDPA na reálných datech?</p>
        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
          <a href="/dashboard/" class="btn btn-primary">Dashboard demo</a>
          <a href="/methodology/" class="btn btn-secondary">Metodika</a>
          <a href="/evaluation/" class="btn btn-secondary">Evaluace &amp; testy</a>
        </div>
      </div>
    </div>
  </section>

<script>
  import { edpa, itemView } from '../lib/edpa-engine';
  import { people, items, iterations } from '../lib/demo-data-walkthrough';

  let mode: 'simple' | 'full' = 'simple';
  let hpw = 40;
  let iterPerPI = 5;
  const iter = iterations[0];

  // Mode toggle
  const btns = document.querySelectorAll('.mode-btn');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const newMode = (btn as HTMLElement).dataset.mode as 'simple' | 'full';
      if (newMode === mode) return;
      mode = newMode;
      btns.forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.mode === mode));
      recompute();
    });
  });

  // Config inputs
  const cfgHpwEl = document.getElementById('cfgHpw') as HTMLInputElement;
  const cfgIterPIEl = document.getElementById('cfgIterPI') as HTMLInputElement;

  cfgHpwEl?.addEventListener('input', () => {
    hpw = parseInt(cfgHpwEl.value) || 40;
    updateCapacities();
  });
  cfgIterPIEl?.addEventListener('input', () => {
    iterPerPI = parseInt(cfgIterPIEl.value) || 5;
    updateSummaries();
  });

  function updateCapacities() {
    people.forEach(p => { p.capacity = p.fte * hpw; });
    updateSummaries();
    updatePeopleCards();
    recompute();
  }

  function updateSummaries() {
    const capSummary = document.getElementById('cfgCapSummary');
    const piSummary = document.getElementById('cfgPISummary');
    if (capSummary) capSummary.textContent = people.map(p => `${p.name} ${p.capacity}h`).join(' · ');
    if (piSummary) piSummary.textContent = people.map(p => `${p.name} ${p.capacity * iterPerPI}h`).join(' · ');
  }

  function updatePeopleCards() {
    document.querySelectorAll('.person-cap').forEach(el => {
      const fte = parseFloat((el as HTMLElement).dataset.fte || '0');
      el.textContent = `${fte * hpw}h / iterace`;
    });
    document.querySelectorAll('.cap-display').forEach((el, i) => {
      if (people[i]) el.textContent = people[i].capacity + 'h';
    });
  }

  function recompute() {
    const results = people.map(p => edpa(p.id, iter.id, people, items, mode)!);
    const itemResults = items.map(w => itemView(w.id, iter.id, people, items, mode)!);
    const isFullMode = mode === 'full';

    const formulaBox = document.getElementById('formulaBox');
    if (formulaBox) {
      formulaBox.innerHTML = isFullMode
        ? '<strong>Score</strong> = JobSize × CW × RS<br><strong>DerivedHours</strong> = (Score / ΣScores) × Capacity'
        : '<strong>Score</strong> = JobSize × CW<br><strong>DerivedHours</strong> = (Score / ΣScores) × Capacity';
    }

    document.querySelectorAll('.rs-col').forEach(el => { (el as HTMLElement).style.display = isFullMode ? '' : 'none'; });
    document.querySelectorAll('.rs-val').forEach(el => { (el as HTMLElement).style.display = isFullMode ? '' : 'none'; });

    // Score cards
    const scoreCards = document.getElementById('scoreCards');
    if (scoreCards) {
      const cards = scoreCards.querySelectorAll('.card');
      results.forEach((r, i) => {
        const card = cards[i];
        if (!card) return;
        const capEl = card.querySelector('.cap-display');
        if (capEl) capEl.textContent = r.person.capacity + 'h';
        const rows = card.querySelectorAll('.score-table tbody tr:not(.total-row)');
        r.items.forEach((x, j) => {
          const row = rows[j];
          if (!row) return;
          const cells = row.querySelectorAll('td');
          cells[1].textContent = String(x.js);
          cells[2].textContent = String(x.cw);
          cells[3].textContent = String(x.rs);
          cells[4].textContent = x.score.toFixed(2);
        });
        const totalCell = card.querySelector('.total-score');
        if (totalCell) totalCell.innerHTML = '&Sigma; ' + r.totalScore.toFixed(2);
      });
    }

    // Per-person cards
    const personCards = document.getElementById('personCards');
    if (personCards) {
      const cards = personCards.querySelectorAll('.card');
      results.forEach((r, i) => {
        const card = cards[i];
        if (!card) return;
        const badge = card.querySelector('.guarantee-badge');
        if (badge) badge.innerHTML = `<span class="guarantee-check">✓</span> Σ = ${r.totalHours.toFixed(1)}h = ${r.person.capacity}h`;
        const rows = card.querySelectorAll('tbody tr:not(.total-row)');
        r.items.forEach((x, j) => {
          const row = rows[j];
          if (!row) return;
          const pct = x.ratio * 100;
          const cells = row.querySelectorAll('td');
          cells[1].textContent = x.score.toFixed(2);
          cells[2].textContent = `${x.score.toFixed(2)} / ${r.totalScore.toFixed(2)} × ${r.person.capacity}`;
          cells[3].textContent = pct.toFixed(1) + '%';
          cells[4].textContent = x.hours.toFixed(1) + 'h';
          const fill = row.querySelector('.bar-fill') as HTMLElement;
          if (fill) fill.style.width = pct + '%';
        });
        const totalRow = card.querySelector('.total-row');
        if (totalRow) {
          const cells = totalRow.querySelectorAll('td');
          cells[1].textContent = r.totalScore.toFixed(2);
          cells[4].textContent = r.totalHours.toFixed(1) + 'h';
        }
      });
    }

    // Per-item cards
    const itemCardsEl = document.getElementById('itemCards');
    if (itemCardsEl) {
      const cards = itemCardsEl.querySelectorAll('.card');
      itemResults.forEach((ir, i) => {
        const card = cards[i];
        if (!card) return;
        const rows = card.querySelectorAll('tbody tr:not(.total-row)');
        ir.contributors.forEach((c, j) => {
          const row = rows[j];
          if (!row) return;
          const share = ir.totalHours > 0 ? (c.hours / ir.totalHours * 100) : 0;
          const cells = row.querySelectorAll('td');
          cells[2].textContent = String(c.cw);
          cells[3].textContent = c.hours.toFixed(1) + 'h';
          cells[4].textContent = share.toFixed(1) + '%';
          const fill = row.querySelector('.bar-fill') as HTMLElement;
          if (fill) fill.style.width = share + '%';
        });
        const totalRow = card.querySelector('.total-row');
        if (totalRow) {
          const cells = totalRow.querySelectorAll('td');
          cells[1].textContent = ir.totalHours.toFixed(1) + 'h';
        }
      });
    }

    // Guarantee cards
    const guaranteeCards = document.getElementById('guaranteeCards');
    if (guaranteeCards) {
      const cards = guaranteeCards.querySelectorAll('.card');
      results.forEach((r, i) => {
        const card = cards[i];
        if (!card) return;
        const sum = card.querySelector('.guarantee-sum');
        if (sum) sum.innerHTML = '&Sigma; ' + r.totalHours.toFixed(1) + 'h';
        const cap = card.querySelector('.guarantee-cap');
        if (cap) cap.textContent = r.person.capacity + 'h';
      });
    }
  }

  // Scroll fade-in
  function initFadeIn() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { (e.target as HTMLElement).classList.add('visible'); observer.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  }
  document.addEventListener('DOMContentLoaded', initFadeIn);
  document.addEventListener('astro:page-load', initFadeIn);

  // Initialize RS column visibility
  document.querySelectorAll('.rs-col').forEach(el => { (el as HTMLElement).style.display = 'none'; });
  document.querySelectorAll('.rs-val').forEach(el => { (el as HTMLElement).style.display = 'none'; });
</script>

</Layout>

<style>
  .calc-hero { padding-top: 80px; padding-bottom: 40px; }
  .calc-headline {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(26px, 4vw, 38px); font-weight: 700;
    background: linear-gradient(135deg, var(--ac2), var(--cy));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin-bottom: 12px;
  }
  .calc-subtitle { font-size: 15px; color: var(--t2); line-height: 1.6; margin-bottom: 24px; }
  .mode-switch { display: inline-flex; background: var(--s1); border: 1px solid var(--bd); border-radius: 8px; overflow: hidden; }
  .mode-btn { font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 8px 16px; background: none; border: none; color: var(--t3); cursor: pointer; transition: all 0.2s; }
  .mode-btn.active { background: rgba(99,102,241,0.15); color: var(--ac2); }
  .mode-btn:hover:not(.active) { color: var(--t1); }

  /* Config */
  .config-panel { margin-bottom: 0; }
  .config-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 12px; }
  .config-item { display: flex; flex-direction: column; gap: 4px; }
  .config-item label { font-family: 'JetBrains Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--t3); }
  .config-input {
    font-family: 'JetBrains Mono', monospace; font-size: 16px; font-weight: 700;
    color: var(--ac2); background: var(--s2); border: 1px solid var(--bd); border-radius: 6px;
    padding: 6px 10px; width: 80px; text-align: center;
  }
  .config-input:focus { outline: none; border-color: var(--ac); }
  .config-derived { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--gn); font-weight: 600; }

  /* Steps */
  .calc-section { position: relative; }
  .calc-step { margin-bottom: 20px; }
