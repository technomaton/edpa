---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'EDPA v1.0.0 — Evidence-Driven Proportional Allocation. Automaticke odvozeni hodin z delivery evidence.', lang = 'cs' } = Astro.props;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="TECHNOMATON" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | EDPA v1.0.0</title>
</head>
<body>
  <Header currentPath={Astro.url.pathname} />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
