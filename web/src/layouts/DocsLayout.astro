---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<Layout title={title} description={description}>
  <section class="section">
    <article class="docs-prose">
      <slot />
    </article>
  </section>
</Layout>

<style is:global>
  .docs-prose {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
    line-height: 1.65;
    color: var(--fg);
  }
  .docs-prose h1 {
    font-size: 2.25rem;
    margin: 0 0 1.5rem;
    line-height: 1.2;
  }
  .docs-prose h2 {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--bd, rgba(255,255,255,0.08));
  }
  .docs-prose h3 {
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
    line-height: 1.35;
  }
  .docs-prose h4 {
    font-size: 1.05rem;
    margin: 1.5rem 0 0.5rem;
  }
  .docs-prose p,
  .docs-prose ul,
  .docs-prose ol {
    margin: 0 0 1.1rem;
  }
  .docs-prose ul,
  .docs-prose ol {
    padding-left: 1.5rem;
  }
  .docs-prose li {
    margin: 0.3rem 0;
  }
  .docs-prose li > ul,
  .docs-prose li > ol {
    margin: 0.3rem 0 0.3rem;
  }
  .docs-prose a {
    color: var(--ac);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .docs-prose a:hover {
    text-decoration-thickness: 2px;
  }
  .docs-prose code {
    background: rgba(255,255,255,0.06);
    padding: 0.12em 0.4em;
    border-radius: 4px;
    font-size: 0.92em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .docs-prose pre {
    background: rgba(0,0,0,0.35);
    border: 1px solid var(--bd, rgba(255,255,255,0.08));
    border-radius: 8px;
    padding: 16px 20px;
    overflow-x: auto;
    margin: 1.2rem 0 1.5rem;
    line-height: 1.5;
    font-size: 0.9rem;
  }
  .docs-prose pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }
  .docs-prose blockquote {
    border-left: 3px solid var(--ac);
    padding: 0.4rem 1rem;
    margin: 1.2rem 0;
    background: rgba(255,255,255,0.03);
    border-radius: 0 6px 6px 0;
    color: var(--fg-dim, rgba(255,255,255,0.85));
  }
  .docs-prose blockquote p:last-child {
    margin-bottom: 0;
  }
  .docs-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.2rem 0 1.5rem;
    font-size: 0.92rem;
  }
  .docs-prose th,
  .docs-prose td {
    border: 1px solid var(--bd, rgba(255,255,255,0.1));
    padding: 8px 12px;
    text-align: left;
    vertical-align: top;
  }
  .docs-prose th {
    background: rgba(255,255,255,0.04);
    font-weight: 600;
  }
  .docs-prose hr {
    border: 0;
    border-top: 1px solid var(--bd, rgba(255,255,255,0.1));
    margin: 2.5rem 0;
  }
  .docs-prose strong {
    color: var(--fg-bright, #fff);
  }
  @media (max-width: 640px) {
    .docs-prose h1 { font-size: 1.75rem; }
    .docs-prose h2 { font-size: 1.3rem; }
    .docs-prose { padding: 0 16px; }
    .docs-prose table { font-size: 0.85rem; }
    .docs-prose th, .docs-prose td { padding: 6px 8px; }
  }
</style>
