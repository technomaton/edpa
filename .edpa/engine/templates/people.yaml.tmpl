# EDPA Capacity Registry
# Edit this file with your team details
# Updated at each Iteration Planning

# Cadence (iteration_weeks / pi_iterations) is NOT configured here. It is set
# per Planning Interval in the `pi:` block of .edpa/iterations/PI-*.yaml, or
# auto-derived from each iteration's `weeks:`/dates. See docs/cadence.md.

# Teams — planning_factor is a team-level decision, not a cadence property
teams:
  - id: "Org A"
    planning_factor: 0.8                      # Plan to 80% of team capacity
    # Buffer absorbs: support, maintenance, incidents, unplanned work
    # EDPA calculation always uses 100% capacity — planning_factor is a planning heuristic only

# Team members — add/remove as needed
people:
  # EXAMPLE — replace with your team:
  - id: example-arch
    name: "Architect Name"
    role: Arch                                # Arch, Dev, DevSecOps, PM, QA
    team: "Org A"                             # Organization name
    fte: 0.5
    capacity_per_iteration: 20                # hours: FTE × 40 for 1-week iter
                                              # (use 40 for 2-week iter)
    email: "arch@example.com"
    # hourly_rate: 1500                        # OPTIONAL: used by /edpa:export for billable-hours CSV
    # currency: CZK                            # OPTIONAL: per-person currency override (e.g. CZK, EUR, USD)
    github: "arch-handle"                     # OPTIONAL: GitHub login. When set,
                                              # sync push uses `gh issue --assignee`
                                              # so GH shows the right user. Without
                                              # it, the assignee is recorded only in
                                              # the issue body.
    availability: confirmed                   # confirmed, partial, unavailable

  - id: example-dev
    name: "Developer Name"
    role: Dev
    team: "Org A"
    fte: 1.0
    capacity_per_iteration: 40                # FTE × 40 for 1-week iter
    email: "dev@example.com"
    github: "dev-handle"
    availability: confirmed

# ─────────────────────────────────────────────────────────────────────
# MULTI-ROLE: One person, multiple contracts/roles (v1.11+)
# ─────────────────────────────────────────────────────────────────────
# When a person has multiple contracts (e.g., full-time Dev + part-time
# PM), create a separate entry for each contract with a distinct id:
#
#   - id: smith-arch              # Contract 1: Full-time, Architect
#     name: "John Smith"
#     role: Arch
#     contract: "Full-time"
#     fte: 1.0
#     capacity_per_iteration: 40
#     github: "smith-dev"         # primary GH login
#
#   - id: smith-pm                # Contract 2: Part-time, PM
#     name: "John Smith"
#     role: PM
#     contract: "Part-time"
#     fte: 0.2
#     capacity_per_iteration: 8
#     github: ""                  # leave empty so auto-detect doesn't ambiguously route
#
# Routing in v1.11:
#   Auto-detection (detect_contributors.py) maps GH login → people[].id
#   via the github: field. If two entries share the same github login,
#   the FIRST entry wins. To distribute contributions across both
#   contracts, use manual `/contribute @smith-pm weight:N` directives in
#   PR/issue/commit bodies — those land directly on the named person id.
#
#   Pre-v1.11 had `evidence_default` / `evidence_scope` fields for
#   automatic per-item routing by ID pattern. v1.11 dropped them; if
#   you need scope routing back, raise it in the v1.14 design discussion.
#
# Capacity invariants hold per id (each entry's Σ DerivedHours equals
# its capacity_per_iteration), so multi-contract people get correctly
# split timesheets.

# Calculated at runtime by EDPA engine:
# total_fte: sum of people[].fte
# total_capacity_per_iteration: sum of people[].capacity_per_iteration
# total_capacity_per_pi: total_capacity_per_iteration × delivery iterations in the PI

# ─────────────────────────────────────────────────────────────────────
# Backlog item evidence schema (v1.11 — referenced from .edpa/backlog/**/*.yaml)
# ─────────────────────────────────────────────────────────────────────
# `people[].role` here = HUMAN job role (Dev, Arch, QA, PM, DevSecOps).
# `contributors[]` block in backlog YAMLs is now signal-driven (no
# evidence-role classifier). detect_contributors.py populates it from
# real GitHub state; engine reads `cw` directly without further mapping.
#
# Example of a v1.11 backlog story (auto-generated by
# detect_contributors.py from real PR + commit + comment evidence):
#
#   id: S-200
#   type: Story
#   parent: F-100
#   js: 5
#   status: Done
#   iteration: PI-2026-1.3
#   contributors:
#     - person: bob-dev          # must match people[].id above
#       cw: 0.65                 # per-item share (Σ across persons = 1.0)
#       contribution_score: 6.78 # raw sum of signal weights (audit input)
#       signals:
#         - type: assignee
#           ref: issue#137
#           weight: 4.00
#           detected_at: 2026-05-08T15:23:11Z
#         - type: pr_author
#           ref: pr#146
#           weight: 3.40
#           detected_at: 2026-05-08T15:23:11Z
#     - person: carol-qa
#       cw: 0.35
#       contribution_score: 3.65
#       signals:
#         - type: pr_reviewer
#           ref: pr#146/review/r2
#           weight: 2.25
#           detected_at: 2026-05-08T15:23:11Z
#         - type: commit_author
#           ref: pr#146/commit/abc
#           weight: 2.78    # contribution_score adds these two: 2.25 + 2.78 → wait
#           # actually 2.25 + 2.78 = 5.03 ≠ 3.65 (illustrative only — real
#           # detect output is internally consistent)
#
# Manual contribution attribution:
#   Add `/contribute @<person-id> weight:<float>` in PR body, commit
#   message, issue body, or any comment. detect_contributors.py picks
#   it up as `manual:*` signal type and adds it to contribution_score.
#   See docs/contribute-directive.md for full usage patterns.
#
# Schema validation:
#   `python3 .edpa/engine/scripts/validate_syntax.py --strict .edpa/backlog/`
#   blocks commits that don't match v1.11 schema. Legacy v1.7-v1.10
#   `as:` field is rejected with migration breadcrumb pointing at
#   detect_contributors.py to regenerate.
